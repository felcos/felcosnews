@using ANews.Web.Services
@inject ToastService Toast
@implements IDisposable

@if (_toasts.Count > 0)
{
    <div class="toast-container">
        @foreach (var toast in _toasts.TakeLast(5))
        {
            <div class="toast toast-@toast.Type.ToString().ToLower()">
                <span class="toast-icon">@GetIcon(toast.Type)</span>
                <span class="toast-message">@toast.Message</span>
                <button class="toast-close" @onclick="() => Remove(toast)">
                    <i class="fa fa-times"></i>
                </button>
            </div>
        }
    </div>
}

@code {
    private readonly List<ToastMessage> _toasts = [];

    protected override void OnInitialized()
    {
        Toast.OnToast += HandleToast;
    }

    private void HandleToast(ToastMessage toast)
    {
        InvokeAsync(async () =>
        {
            _toasts.Add(toast);
            StateHasChanged();

            var timer = new System.Threading.Timer(_ =>
            {
                InvokeAsync(() =>
                {
                    _toasts.Remove(toast);
                    StateHasChanged();
                });
            }, null, 3500, System.Threading.Timeout.Infinite);

            await Task.Delay(4000);
            timer.Dispose();
        });
    }

    private void Remove(ToastMessage toast)
    {
        _toasts.Remove(toast);
    }

    private static string GetIcon(ToastType type) => type switch
    {
        ToastType.Success => "✓",
        ToastType.Error   => "✗",
        ToastType.Warning => "⚠",
        ToastType.Info    => "ℹ",
        _                 => "•"
    };

    public void Dispose()
    {
        Toast.OnToast -= HandleToast;
    }
}
