@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using ANews.Web.Components.Shared
@inject NavigationManager Nav

<div class="user-shell">
    <header class="user-header">
        <a href="/" class="user-logo">
            <i class="fa fa-satellite"></i>
            <span>AGENTE<strong>NEWS</strong></span>
        </a>

        <nav class="user-nav">
            <NavLink href="/user" Match="NavLinkMatch.All" class="user-nav-link">
                <i class="fa fa-home"></i> Mi Panel
            </NavLink>
            <NavLink href="/user/modules" class="user-nav-link">
                <i class="fa fa-th-large"></i> Modulos
            </NavLink>
            <NavLink href="/user/notifications" class="user-nav-link">
                <i class="fa fa-bell"></i> Notificaciones
            </NavLink>
            <NavLink href="/user/bookmarks" class="user-nav-link">
                <i class="fa fa-bookmark"></i> Guardados
            </NavLink>
            <NavLink href="/user/api-tokens" class="user-nav-link">
                <i class="fa fa-key"></i> API Tokens
            </NavLink>
            <NavLink href="/user/profile" class="user-nav-link">
                <i class="fa fa-user-circle"></i> Perfil
            </NavLink>
        </nav>

        <div class="user-header-right">
            <a href="/" class="user-nav-link" title="Ver universo de noticias">
                <i class="fa fa-globe"></i>
            </a>
            <AuthorizeView Roles="Admin,SuperAdmin">
                <Authorized>
                    <a href="/admin" class="user-nav-link" title="Panel Admin">
                        <i class="fa fa-cog"></i>
                    </a>
                </Authorized>
            </AuthorizeView>
            <a href="/logout" class="user-nav-link" title="Cerrar sesion">
                <i class="fa fa-sign-out-alt"></i>
            </a>
        </div>
    </header>

    <main class="user-main">
        <div class="user-content">
            @Body
        </div>
    </main>
</div>

<ToastContainer />

<div id="blazor-error-ui" style="display:none">
    <i class="fa fa-exclamation-triangle"></i>
    Error de conexion. <a href="" class="reload">Recargar</a>
    <a class="dismiss" onclick="this.parentElement.style.display='none'">X</a>
</div>
