@code {
    [SupplyParameterFromQuery(Name = "eventId")]
    private int? AutoOpenEventId { get; set; }

    private HubConnection? _hub;
    private bool IsConnected => _hub?.State == HubConnectionState.Connected;
    private bool IsLoading = true;
    private string SelectedSection = "all";
    private string ViewMode = "grid";
    private DateTime LastUpdate = DateTime.Now;

    private string _searchQuery = "";
    private int _daysBack = 7;
    private List<SectionItem> Sections = [];
    private List<EventItem> Events = [];
    private List<ModuleFilterItem> UserModules = [];

    // ── Quota limit modal ──────────────────────────────────────────────
    private bool _showQuotaModal = false;
    private string _quotaPlanTier = "Free";

    // ── Full-text search ──────────────────────────────────────────────
    private string _ftSearchQuery = "";
    private bool _showFtSearch = false;
    private List<SearchResultItem> _ftSearchResults = [];
    private System.Threading.Timer? _searchTimer;

    private record SearchResultItem(string Type, int Id, string Title, string Description, string Section, string Priority, DateTime Date);

    private async Task OnSearchInputChanged()
    {
        _searchTimer?.Dispose();
        var query = _ftSearchQuery;
        if (string.IsNullOrWhiteSpace(query) || query.Trim().Length < 2)
        {
            _ftSearchResults.Clear();
            _showFtSearch = false;
            return;
        }
        _searchTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                try
                {
                    var pattern = $"%{query.Trim()}%";
                    var events = await Ctx.NewsEvents
                        .Include(e => e.Section)
                        .Where(e => !e.IsDeleted && e.IsActive
                            && (EF.Functions.ILike(e.Title, pattern)
                                || EF.Functions.ILike(e.Description ?? "", pattern)))
                        .OrderByDescending(e => e.CreatedAt)
                        .Take(10)
                        .Select(e => new SearchResultItem(
                            "event", e.Id, e.Title,
                            e.Description != null ? (e.Description.Length > 120 ? e.Description.Substring(0, 120) + "…" : e.Description) : "",
                            e.Section != null ? e.Section.Name : "",
                            e.Priority.ToString(), e.CreatedAt))
                        .ToListAsync();

                    var articles = await Ctx.NewsArticles
                        .Include(a => a.Event).ThenInclude(ev => ev.Section)
                        .Where(a => !a.IsDeleted
                            && (EF.Functions.ILike(a.Title, pattern)
                                || EF.Functions.ILike(a.Summary ?? "", pattern)))
                        .OrderByDescending(a => a.PublishedAt)
                        .Take(10)
                        .Select(a => new SearchResultItem(
                            "article", a.Id, a.Title,
                            a.Summary != null ? (a.Summary.Length > 120 ? a.Summary.Substring(0, 120) + "…" : a.Summary) : "",
                            a.Event != null && a.Event.Section != null ? a.Event.Section.Name : "",
                            a.Event != null ? a.Event.Priority.ToString() : "Medium", a.PublishedAt))
                        .ToListAsync();

                    _ftSearchResults = events.Concat(articles).Take(20).ToList();
                    _showFtSearch = _ftSearchResults.Any();
                    StateHasChanged();
                }
                catch { /* search silently fails */ }
            });
        }, null, 300, Timeout.Infinite);
    }

    private void OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") { _showFtSearch = false; }
    }

    private async Task OnSearchResultClick(SearchResultItem r)
    {
        _showFtSearch = false;
        if (r.Type == "event")
            await OpenEventById(r.Id);
        else
            Nav.NavigateTo($"/article/{r.Id}");
    }

    private void ClearFullSearch()
    {
        _ftSearchQuery = "";
        _ftSearchResults.Clear();
        _showFtSearch = false;
        _searchTimer?.Dispose();
    }

    // ── Workspace (geo-focus) ──────────────────────────────────────────
    private bool _showWorkspacePicker = false;
    private string _workspaceName = "Global";
    private string[] _geoFilter = [];
    private string _customGeoInput = "";

    // Workspace zones loaded from DB
    private List<WorkspaceZone> _wsPresets = [];

    private string[] GetGeoTerms(string zoneName)
    {
        var zone = _wsPresets.FirstOrDefault(z => z.Name.Equals(zoneName, StringComparison.OrdinalIgnoreCase));
        if (zone != null && zone.GeoTerms.Count > 0) return zone.GeoTerms.ToArray();
        return [zoneName]; // fallback: use name itself as search term
    }

    private bool MatchesGeoFilter(EventItem ev) => MatchesGeoFilterFor(ev, null);

    private bool MatchesGeoFilterFor(EventItem ev, string? singleGeo)
    {
        var filter = singleGeo != null ? new[] { singleGeo } : _geoFilter;
        if (filter.Length == 0) return true;
        var terms = filter
            .SelectMany(g => GetGeoTerms(g))
            .Select(t => t.ToLowerInvariant())
            .ToArray();
        var text = $"{ev.Location} {ev.Title} {ev.Description}".ToLowerInvariant();
        return terms.Any(t => text.Contains(t));
    }

    private async Task SelectWorkspace(string name, string[] geos)
    {
        _workspaceName = name;
        _geoFilter = geos;
        _showWorkspacePicker = false;
        try { await JS.InvokeVoidAsync("localStorage.setItem", "anews-workspace", name); } catch { }
        if (ViewMode == "universe")
            try { await JS.InvokeVoidAsync("universe.updateData", FilteredEvents, Sections); } catch { }
        else if (ViewMode == "universe3d")
            try { await JS.InvokeVoidAsync("universe3d.updateData", FilteredEvents, Sections); } catch { }
        else if (ViewMode == "map")
            try { await JS.InvokeVoidAsync("newsMap.updateData", FilteredEvents); } catch { }
    }

    private async Task SelectCustomWorkspace()
    {
        if (string.IsNullOrWhiteSpace(_customGeoInput)) return;
        var geos = _customGeoInput.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        await SelectWorkspace(string.Join(" + ", geos), geos);
    }

    record ModuleFilterItem(int Id, string Name, string Color, List<string> Keywords);

    private List<EventItem> FilteredEvents
    {
        get
        {
            var cutoff = DateTime.UtcNow.AddDays(-_daysBack);
            IEnumerable<EventItem> q = Events.Where(e => e.StartDate >= cutoff).Where(MatchesGeoFilter);
            if (SelectedSection.StartsWith("module:") && int.TryParse(SelectedSection[7..], out var modId))
            {
                var mod = UserModules.FirstOrDefault(m => m.Id == modId);
                if (mod != null)
                {
                    var kws = mod.Keywords.Select(k => k.ToLowerInvariant()).ToList();
                    q = Events.Where(e =>
                    {
                        var txt = $"{e.Title} {e.Description} {string.Join(" ", e.Tags)}".ToLowerInvariant();
                        return kws.Any(k => txt.Contains(k));
                    });
                }
            }
            else if (SelectedSection != "all")
            {
                q = Events.Where(e => e.SectionSlug == SelectedSection);
            }
            if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                var s = _searchQuery.Trim().ToLowerInvariant();
                q = q.Where(e =>
                    (e.Title?.ToLowerInvariant().Contains(s) ?? false) ||
                    (e.Description?.ToLowerInvariant().Contains(s) ?? false) ||
                    e.Tags.Any(t => t.ToLowerInvariant().Contains(s)));
            }
            return q.ToList();
        }
    }

    private List<AlertItem> CriticalAlerts = [];
    private EventItem? SelectedEvent;
    private List<ArticleItem> SelectedEventArticles = [];
    private HashSet<int> _expandedArticles = [];
    private string _modalSummaryLang = "es";
    private Dictionary<int, string> _articleSummariesEn = [];
    private HashSet<int> _generatingEnSummary = [];
    private DotNetObjectReference<Index>? _dotnetRef;
    private Dictionary<DateTime, List<ArticleItem>> _articlesByDay = [];
    private List<RelatedEventItem> _relatedEvents = [];
    private DateTime? _selectedEventEnd;
    private bool _selectedEventIsActive = true;

    // Morning Brief + Story Threads
    private MorningBrief? _morningBrief;
    private bool _briefDismissed = false;
    private List<StoryThreadItem> _storyThreads = [];
    private List<StoryThreadFull> _storyThreadsFull = [];
    private EventBriefing? _eventBriefing;
    private ANews.Domain.Entities.StoryThread? _selectedEventThread;
    private EventItem? _serendipityEvent;

    protected override async Task OnInitializedAsync()
    {
        Sections = await Ctx.NewsSections
            .Where(s => s.IsPublic && !s.IsDeleted)
            .OrderBy(s => s.SortOrder)
            .Select(s => new SectionItem(s.Id, s.Name, s.Slug, s.Color ?? "#4a90e2", s.IconClass ?? "fa-newspaper"))
            .ToListAsync();

        _wsPresets = await Ctx.WorkspaceZones
            .Where(z => z.IsActive && !z.IsDeleted)
            .OrderBy(z => z.SortOrder)
            .ToListAsync();

        await LoadEventsAsync();

        // Serendipity: pick a high-impact event from a section the user doesn't follow
        PickSerendipityEvent();

        // Load morning brief for today
        var today = DateTime.UtcNow.Date;
        _morningBrief = await Ctx.MorningBriefs
            .Where(m => m.BriefDate == today)
            .FirstOrDefaultAsync();

        if (_morningBrief != null)
            _ = TrackActivity(ActivityType.MorningBriefViewed);

        // Load active story threads
        _storyThreads = await Ctx.StoryThreads
            .Where(t => t.Status == ANews.Domain.Enums.StoryStatus.Developing
                     || t.Status == ANews.Domain.Enums.StoryStatus.Active)
            .OrderByDescending(t => t.MaxImpactScore)
            .Take(10)
            .Select(t => new StoryThreadItem(t.Id, t.Title, t.Status.ToString(), t.EventCount, t.MaxImpactScore))
            .ToListAsync();

        _storyThreadsFull = await Ctx.StoryThreads
            .Include(t => t.PrimarySection)
            .Where(t => !t.IsDeleted)
            .OrderByDescending(t => t.LastEventDate)
            .Take(20)
            .Select(t => new StoryThreadFull(t.Id, t.Title, t.Summary, t.WhyItMatters, t.WhatToWatch,
                t.Status.ToString(), t.MaxPriority.ToString(), t.EventCount, t.TotalArticles,
                t.PrimarySection != null ? t.PrimarySection.Name : null,
                t.PrimarySection != null ? t.PrimarySection.Color : null,
                t.KeyActors, t.FirstEventDate, t.LastEventDate))
            .ToListAsync();

        IsLoading = false;
    }

    private int? _lastOpenedEventId;

    protected override async Task OnParametersSetAsync()
    {
        // Handle eventId query parameter changes (internal Blazor navigation)
        if (AutoOpenEventId.HasValue && AutoOpenEventId != _lastOpenedEventId && !IsLoading)
        {
            _lastOpenedEventId = AutoOpenEventId;
            await OpenEventById(AutoOpenEventId.Value);
        }
    }

    private async Task LoadEventsAsync()
    {
        var baseQuery = Ctx.NewsEvents
            .Include(e => e.Section)
            .Where(e => e.IsActive && e.EventType != "Unclassified");

        // Always load global top events
        var globalTop = await baseQuery
            .OrderByDescending(e => e.Priority)
            .ThenByDescending(e => e.ImpactScore)
            .Take(200)
            .Select(e => new EventItem(
                e.Id, e.Title, e.Description, e.Priority.ToString(),
                e.ImpactScore, e.Trend.ToString(), e.Tags,
                e.Section.Name, e.Section.Slug, e.StartDate,
                e.Articles.Count(a => !a.IsDeleted),
                e.Articles.Where(a => !a.IsDeleted)
                    .OrderByDescending(a => a.Relevance)
                    .Take(6)
                    .Select(a => new MoonArticle(a.Id, a.Title, a.SourceName))
                    .ToArray(),
                e.Latitude, e.Longitude, e.Location,
                e.StoryThreadId, e.SourceDiversity))
            .ToListAsync();

        // When a workspace is active, also load geo-specific events that may not be in top 200
        if (_geoFilter.Length > 0)
        {
            var geoTerms = _geoFilter
                .SelectMany(g => GetGeoTerms(g))
                .Select(t => t.ToLowerInvariant())
                .ToList();

            var loadedIds = globalTop.Select(e => e.Id).ToHashSet();

            // Load recent events matching geo terms in location/title/description
            var geoEvents = await baseQuery
                .Where(e => !loadedIds.Contains(e.Id) &&
                    (geoTerms.Any(t => e.Location != null && e.Location.ToLower().Contains(t)) ||
                     geoTerms.Any(t => e.Title.ToLower().Contains(t))))
                .OrderByDescending(e => e.CreatedAt)
                .Take(100)
                .Select(e => new EventItem(
                    e.Id, e.Title, e.Description, e.Priority.ToString(),
                    e.ImpactScore, e.Trend.ToString(), e.Tags,
                    e.Section.Name, e.Section.Slug, e.StartDate,
                    e.Articles.Count(a => !a.IsDeleted),
                    e.Articles.Where(a => !a.IsDeleted)
                        .OrderByDescending(a => a.Relevance)
                        .Take(6)
                        .Select(a => new MoonArticle(a.Id, a.Title, a.SourceName))
                        .ToArray(),
                    e.Latitude, e.Longitude, e.Location,
                    e.StoryThreadId, e.SourceDiversity))
                .ToListAsync();

            Events = globalTop.Concat(geoEvents).ToList();
        }
        else
        {
            Events = globalTop;
        }

        CriticalAlerts = await Ctx.AlertTriggers
            .Where(a => !a.IsAcknowledged)
            .OrderByDescending(a => a.Severity)
            .Take(5)
            .Select(a => new AlertItem(a.Id, a.Title))
            .ToListAsync();

        LastUpdate = DateTime.Now;
    }

    private async Task SetupSignalRAsync()
    {
        try
        {
            _hub = new HubConnectionBuilder()
                .WithUrl(NavManager.ToAbsoluteUri("/newshub"))
                .WithAutomaticReconnect()
                .Build();

            _hub.On<object>("NewEvent", async _ =>
            {
                await LoadEventsAsync();
                await InvokeAsync(StateHasChanged);
                if (ViewMode == "universe")
                    try { await JS.InvokeVoidAsync("universe.updateData", FilteredEvents, Sections); } catch { }
            });

            _hub.On<object>("CriticalAlert", async _ =>
            {
                await LoadEventsAsync();
                await InvokeAsync(StateHasChanged);
            });

            await _hub.StartAsync();
            await _hub.SendAsync("JoinSection", SelectedSection);
        }
        catch
        {
            // Hub no disponible — modo sin actualización en tiempo real
        }
    }

