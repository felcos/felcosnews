    private static string FormatBriefText(string text)
    {
        if (string.IsNullOrEmpty(text)) return "";
        return System.Net.WebUtility.HtmlEncode(text)
            .Replace("\\n\\n", "<br/><br/>")
            .Replace("\\n", "<br/>")
            .Replace("\n\n", "<br/><br/>")
            .Replace("\n", "<br/>");
    }

    private async Task TrackActivity(ActivityType type, int? sectionId = null, int? eventId = null, int? articleId = null, int? threadId = null, string? metadata = null)
    {
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            if (!(auth.User.Identity?.IsAuthenticated ?? false)) return;
            var userName = auth.User.Identity?.Name;
            if (string.IsNullOrEmpty(userName)) return;
            var user = await Ctx.Users.FirstOrDefaultAsync(u => u.UserName == userName);
            if (user == null) return;

            // Check quota for content-consuming activities
            if (sectionId.HasValue && (type == ActivityType.EventOpened || type == ActivityType.ArticleRead || type == ActivityType.ArticleExpanded))
            {
                var periodStart = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1, 0, 0, 0, DateTimeKind.Utc);
                var quota = await Ctx.SectionQuotas.FirstOrDefaultAsync(q =>
                    q.UserId == user.Id && q.NewsSectionId == sectionId.Value && q.PeriodStart == periodStart);
                if (quota != null && quota.MaxReadsPerMonth >= 0 && quota.CurrentReads >= quota.MaxReadsPerMonth)
                {
                    _quotaPlanTier = quota.PlanTier.ToString();
                    _showQuotaModal = true;
                    await InvokeAsync(StateHasChanged);
                    return;
                }
                if (quota != null)
                {
                    quota.CurrentReads++;
                    Ctx.SectionQuotas.Update(quota);
                }
            }

            Ctx.UserActivities.Add(new UserActivity
            {
                UserId = user.Id,
                ActivityType = type,
                NewsSectionId = sectionId,
                NewsEventId = eventId,
                NewsArticleId = articleId,
                StoryThreadId = threadId,
                Metadata = metadata
            });
            await Ctx.SaveChangesAsync();
        }
        catch { /* Never block UI */ }
    }
