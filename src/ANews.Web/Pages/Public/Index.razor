    private async Task GenerateEnSummaryAsync(ArticleItem art)
    {
        if (_generatingEnSummary.Contains(art.Id)) return;
        _generatingEnSummary.Add(art.Id);
        StateHasChanged();
        try
        {
            var provider = await AiFactory.GetDefaultProviderAsync();
            var text = string.IsNullOrEmpty(art.Summary) ? art.Title : art.Summary;
            var response = await provider.CompleteAsync(new AiRequest
            {
                SystemPrompt = "You are an expert news editor. Summarize or translate the following into 2-3 clear, objective sentences in English.",
                UserPrompt = $"Title: {art.Title}\n\nContent: {text}",
                MaxTokens = 300,
                Temperature = 0.3,
                OperationTag = "article_summary_en"
            });
            if (response.Success && !string.IsNullOrEmpty(response.Content))
                _articleSummariesEn[art.Id] = response.Content.Trim();
        }
        catch { }
        finally
        {
            _generatingEnSummary.Remove(art.Id);
            await InvokeAsync(StateHasChanged);
        }
    }

