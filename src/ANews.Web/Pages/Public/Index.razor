@page "/"
@inject IJSRuntime JS
@inject AppDbContext Ctx
@inject AuthenticationStateProvider AuthStateProvider
@inject ANews.Infrastructure.AI.AiProviderFactory AiFactory
@using ANews.Infrastructure.Data
@using ANews.Infrastructure.AI
@using ANews.Domain.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.EntityFrameworkCore
@implements IAsyncDisposable

<PageTitle>AgenteNews — Noticias Inteligentes</PageTitle>

<div class="public-layout" id="app-root">

    <!-- Header -->
    <header class="site-header">
        <div class="header-brand">
            <i class="fa fa-satellite"></i>
            <span class="brand-name">AGENTE<strong>NEWS</strong></span>
            <span class="brand-beta">BETA</span>
        </div>

        <div class="header-right">
            <div class="live-status @(IsConnected ? "live" : "offline")">
                <span class="pulse-dot"></span>
                @(IsConnected ? "EN VIVO" : "OFFLINE")
            </div>
            <div class="view-switcher">
                <button class="view-btn @(ViewMode == "universe" ? "active" : "")"
                        @onclick="@(() => SetViewMode("universe"))" title="Vista universo">
                    <i class="fa fa-globe"></i>
                </button>
                <button class="view-btn @(ViewMode == "grid" ? "active" : "")"
                        @onclick="@(() => SetViewMode("grid"))" title="Vista grid">
                    <i class="fa fa-th"></i>
                </button>
                <button class="view-btn @(ViewMode == "list" ? "active" : "")"
                        @onclick="@(() => SetViewMode("list"))" title="Vista lista">
                    <i class="fa fa-list"></i>
                </button>
                <button class="view-btn @(ViewMode == "map" ? "active" : "")"
                        @onclick="@(() => SetViewMode("map"))" title="Vista mapa mundial">
                    <i class="fa fa-map-marked-alt"></i>
                </button>
            </div>
            <a href="/explore" class="explore-link"><i class="fa fa-calendar-alt"></i> Explorar</a>

            <!-- Theme selector -->
            <div class="theme-selector" @onclick:stopPropagation>
                <button class="theme-btn" @onclick="ToggleThemeMenu" title="Cambiar tema"></button>
                @if (_themeMenuOpen)
                {
                    <div class="theme-dropdown">
                        @foreach (var th in _themes)
                        {
                            <div class="theme-swatch-wrap">
                                <div class="theme-swatch @(_currentTheme == th.Key ? "active" : "")"
                                     style="background:@th.Value.Bg"
                                     title="@th.Value.Name"
                                     @onclick="@(() => SetTheme(th.Key))">
                                    <span style="color:@th.Value.Accent;font-size:10px;font-weight:900;">A</span>
                                </div>
                                <div class="theme-swatch-label">@th.Value.Name</div>
                            </div>
                        }
                    </div>
                }
            </div>

            <AuthorizeView>
                <Authorized>
                    <a href="/user" class="btn-user"><i class="fa fa-user"></i></a>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="btn-login">Entrar</a>
                    <a href="/register" class="btn-register">Registrarse</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </header>

    <!-- Section strip — sticky below header, icon chips that expand on hover/active -->
    <div class="section-strip">
        <button class="sec-scroll-btn" onclick="this.closest('.section-strip').querySelector('.sec-strip-scroll').scrollBy({left:-160,behavior:'smooth'})">
            <i class="fa fa-chevron-left"></i>
        </button>
        <div class="sec-strip-scroll">
            <button class="sec-chip @(SelectedSection == "all" ? "active" : "")"
                    @onclick="@(() => SelectSection("all"))"
                    title="Todo">
                <i class="fa fa-border-all"></i>
                <span class="sec-chip-name">Todo</span>
            </button>
            @foreach (var s in Sections)
            {
                <button class="sec-chip @(SelectedSection == s.Slug ? "active" : "")"
                        @onclick="@(() => SelectSection(s.Slug))"
                        style="--sc:@s.Color"
                        title="@s.Name">
                    <i class="fa @s.IconClass"></i>
                    <span class="sec-chip-name">@s.Name</span>
                </button>
            }
        </div>
        <button class="sec-scroll-btn" onclick="this.closest('.section-strip').querySelector('.sec-strip-scroll').scrollBy({left:160,behavior:'smooth'})">
            <i class="fa fa-chevron-right"></i>
        </button>
        @if (SelectedSection != "all" && !SelectedSection.StartsWith("module:"))
        {
            <button class="sec-clear-btn" @onclick="@(() => SelectSection("all"))" title="Quitar filtro">
                <i class="fa fa-times"></i>
            </button>
        }
    </div>

    @if (UserModules.Any())
    {
        <div class="module-nav-row">
            <span class="module-nav-label"><i class="fa fa-filter"></i> Mis módulos:</span>
            @foreach (var m in UserModules)
            {
                <button class="nav-tab module-tab @(SelectedSection == $"module:{m.Id}" ? "active" : "")"
                        style="--section-color:@m.Color"
                        @onclick="@(() => SelectSection($"module:{m.Id}"))">
                    <i class="fa fa-circle" style="color:@m.Color;font-size:8px"></i> @m.Name
                </button>
            }
            @if (SelectedSection.StartsWith("module:"))
            {
                <button class="nav-tab" @onclick="@(() => SelectSection("all"))" title="Quitar filtro de módulo">
                    <i class="fa fa-times"></i>
                </button>
            }
        </div>
    }

    <!-- Alertas críticas -->
    @if (CriticalAlerts.Any())
    {
        <div class="critical-banner">
            <i class="fa fa-exclamation-triangle"></i>
            <div class="alert-ticker">
                @foreach (var a in CriticalAlerts.Take(3))
                {
                    <span class="alert-item">@a.Title</span>
                }
            </div>
            <button class="close-banner" @onclick="DismissBanner"><i class="fa fa-times"></i></button>
        </div>
    }

    <!-- Stats bar + search -->
    <div class="stats-bar">
        <div class="stat-item">
            <span class="stat-num">@FilteredEvents.Count</span>
            <span class="stat-lbl">Eventos activos</span>
        </div>
        <div class="stat-item">
            <span class="stat-num">@Events.Sum(e => e.ArticleCount)</span>
            <span class="stat-lbl">Artículos</span>
        </div>
        <div class="stat-item">
            <span class="stat-num">@Events.Count(e => e.Priority == "Critical")</span>
            <span class="stat-lbl">Críticos</span>
        </div>
        <div class="stat-item">
            <span class="stat-num">@LastUpdate.ToString("HH:mm")</span>
            <span class="stat-lbl">Último update</span>
        </div>
        <div class="stat-search">
            <i class="fa fa-search"></i>
            <input type="text" placeholder="Buscar eventos..." @bind="_searchQuery" @bind:event="oninput"
                   class="search-input" />
            @if (!string.IsNullOrEmpty(_searchQuery))
            {
                <button class="search-clear" @onclick="@(() => _searchQuery = "")"><i class="fa fa-times"></i></button>
            }
        </div>
    </div>

    <!-- Main content area -->
    <main class="content-area" id="content-area">

        @if (IsLoading)
        {
            <div class="skeleton-grid">
                @for (int i = 0; i < 6; i++)
                {
                    <div class="skeleton-card">
                        <div class="skeleton-bar" style="width:40%"></div>
                        <div class="skeleton-bar title"></div>
                        <div class="skeleton-bar medium"></div>
                        <div class="skeleton-bar short"></div>
                        <div class="skeleton-bar" style="width:55%"></div>
                    </div>
                }
            </div>
        }
        else if (!Events.Any())
        {
            <div class="empty-universe">
                <i class="fa fa-satellite-dish"></i>
                <h2>Escaneando fuentes...</h2>
                <p>Los agentes están trabajando. Vuelve en unos minutos.</p>
            </div>
        }
        else if (ViewMode == "universe")
        {
            <!-- Universe canvas - gestionado por universe.js sin conflictos Blazor -->
            <div class="universe-container" id="universe-container">
                <canvas id="universe-canvas"></canvas>
                <!-- Tooltip overlay gestionado por JS -->
                <div id="universe-tooltip" class="universe-tooltip" style="display:none"></div>
            </div>
        }
        else if (ViewMode == "map")
        {
            <div class="map-container">
                <div id="map-view"></div>
            </div>
        }
        else if (ViewMode == "grid")
        {
            <div class="events-grid">
                @foreach (var ev in FilteredEvents)
                {
                    <div class="event-card priority-@ev.Priority.ToLower()" @onclick="() => OpenEvent(ev)">
                        <div class="event-card-header">
                            <span class="event-priority">@ev.Priority</span>
                            <span class="event-section">@ev.SectionName</span>
                            <span class="event-impact">@ev.ImpactScore.ToString("F0")</span>
                        </div>
                        <h3 class="event-title">@ev.Title</h3>
                        <p class="event-desc">@Truncate(ev.Description ?? "", 120)</p>
                        <div class="event-footer">
                            <span class="event-articles">@ev.ArticleCount art.</span>
                            <span class="event-trend trend-@ev.Trend.ToLower()">@TrendIcon(ev.Trend) @ev.Trend</span>
                            <span class="event-date">@ev.StartDate.ToString("dd/MM HH:mm")</span>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="events-list">
                @foreach (var ev in FilteredEvents)
                {
                    <div class="event-list-item priority-border-@ev.Priority.ToLower()" @onclick="() => OpenEvent(ev)">
                        <div class="eli-priority">
                            <span class="priority-dot priority-@ev.Priority.ToLower()"></span>
                        </div>
                        <div class="eli-content">
                            <h3>@ev.Title</h3>
                            <p>@Truncate(ev.Description ?? "", 150)</p>
                            <div class="eli-meta">
                                <span>@ev.SectionName</span>
                                <span>@ev.ArticleCount artículos</span>
                                <span>@TrendIcon(ev.Trend) @ev.Trend</span>
                            </div>
                        </div>
                        <div class="eli-impact">@ev.ImpactScore.ToString("F0")</div>
                    </div>
                }
            </div>
        }
    </main>
</div>

<!-- Event Detail Modal (unified chronology) -->
@if (SelectedEvent != null)
{
    <div class="event-modal-overlay" @onclick="CloseEvent">
        <div class="event-modal event-modal-full" @onclick:stopPropagation>
            <div class="em-header priority-bg-@SelectedEvent.Priority.ToLower()">
                <div class="em-badges">
                    <span class="em-priority">@SelectedEvent.Priority</span>
                    <span class="em-section">@SelectedEvent.SectionName</span>
                    @if (!_selectedEventIsActive)
                    {
                        <span class="em-badge-archived">Archivado</span>
                    }
                    <span class="em-trend-badge">@TrendIcon(SelectedEvent.Trend) @SelectedEvent.Trend</span>
                </div>
                <button class="em-close" @onclick="CloseEvent"><i class="fa fa-times"></i></button>
            </div>

            <div class="em-body-grid">
                <!-- Main: timeline -->
                <div class="em-main">
                    <h2 class="em-title">@SelectedEvent.Title</h2>
                    @if (!string.IsNullOrEmpty(SelectedEvent.Description))
                    {
                        <p class="em-desc">@SelectedEvent.Description</p>
                    }
                    <div class="em-meta-bar">
                        <span><i class="fa fa-calendar"></i> @SelectedEvent.StartDate.ToString("dd/MM/yyyy")</span>
                        @if (_selectedEventEnd.HasValue)
                        {
                            <span><i class="fa fa-flag-checkered"></i> @_selectedEventEnd.Value.ToString("dd/MM/yyyy")</span>
                        }
                        <span><i class="fa fa-file-alt"></i> @SelectedEventArticles.Count artículos</span>
                        <span><i class="fa fa-rss"></i> @SelectedEventArticles.Select(a => a.SourceName).Distinct().Count() fuentes</span>
                    </div>
                    @if (SelectedEvent.Tags.Any())
                    {
                        <div class="em-tags">
                            @foreach (var tag in SelectedEvent.Tags) { <span class="em-tag">#@tag</span> }
                        </div>
                    }

                    <div class="em-timeline-header">
                        <span><i class="fa fa-stream"></i> CRONOLOGÍA</span>
                        <div class="lang-toggle" title="Idioma de resúmenes">
                            <button class="lang-btn @(_modalSummaryLang == "es" ? "lang-active" : "")"
                                    @onclick="@(() => _modalSummaryLang = "es")">ES</button>
                            <button class="lang-btn @(_modalSummaryLang == "en" ? "lang-active" : "")"
                                    @onclick="@(() => _modalSummaryLang = "en")">EN</button>
                        </div>
                    </div>
                    <div class="em-timeline">
                        @if (!_articlesByDay.Any())
                        {
                            <p style="color:var(--text-muted);font-size:13px;padding:16px 0">Sin artículos asociados.</p>
                        }
                        @foreach (var day in _articlesByDay)
                        {
                            <div class="em-tl-day">
                                <div class="em-tl-day-label">@day.Key.ToString("dddd, dd MMM yyyy", new System.Globalization.CultureInfo("es-ES"))</div>
                                @foreach (var art in day.Value)
                                {
                                    var isExpanded = _expandedArticles.Contains(art.Id);
                                    <div class="em-tl-item @(isExpanded ? "em-tl-expanded" : "")"
                                         @onclick="@(() => ToggleArticlePreview(art.Id))">
                                        <div class="em-tl-dot priority-dot-@SelectedEvent.Priority.ToLower()"></div>
                                        <div class="em-tl-content">
                                            <div class="em-art-row">
                                                <span class="em-art-type">@art.ArticleType</span>
                                                <span class="em-tl-time">@art.PublishedAt.ToString("HH:mm")</span>
                                                <span class="em-art-title">@art.Title</span>
                                                <i class="fa @(isExpanded ? "fa-chevron-up" : "fa-chevron-down") em-art-chevron"></i>
                                            </div>
                                            @if (isExpanded)
                                            {
                                                <div class="em-art-detail" @onclick:stopPropagation>
                                                    <div class="em-art-meta">
                                                        <i class="fa fa-rss-square" style="color:var(--accent);font-size:10px"></i>
                                                        <span>@art.SourceName</span>
                                                        <span>@art.PublishedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                                    </div>
                                                    <div class="em-ai-label">
                                                        <i class="fa fa-robot"></i>
                                                        @(_modalSummaryLang == "en" ? "AI Analysis (EN)" : "Análisis IA (ES)")
                                                    </div>
                                                    @if (_modalSummaryLang == "en")
                                                    {
                                                        @if (_articleSummariesEn.TryGetValue(art.Id, out var enSum))
                                                        {
                                                            <p class="em-art-summary">@enSum</p>
                                                        }
                                                        else if (_generatingEnSummary.Contains(art.Id))
                                                        {
                                                            <p class="em-art-no-summary"><i class="fa fa-spinner fa-spin"></i> Translating...</p>
                                                        }
                                                        else
                                                        {
                                                            <button class="em-gen-btn" @onclick="@(async () => await GenerateEnSummaryAsync(art))">
                                                                <i class="fa fa-language"></i> Generate EN summary
                                                            </button>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        @if (!string.IsNullOrEmpty(art.Summary))
                                                        {
                                                            <p class="em-art-summary">@art.Summary</p>
                                                        }
                                                        else
                                                        {
                                                            <p class="em-art-no-summary">Sin resumen disponible aún.</p>
                                                        }
                                                    }
                                                    <a href="@art.SourceUrl" target="_blank" rel="noopener" class="em-art-source-link">
                                                        <i class="fa fa-external-link-alt"></i> @(_modalSummaryLang == "en" ? "Read at" : "Ver en") @art.SourceName
                                                    </a>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Sidebar -->
                <div class="em-sidebar">
                    <div class="em-side-card">
                        <div class="em-side-label">Impacto</div>
                        <div class="em-impact-display">
                            <span class="em-impact-num">@SelectedEvent.ImpactScore.ToString("F0")</span>
                            <span class="em-impact-max">/100</span>
                        </div>
                        <div class="em-impact-bar-wrap">
                            <div class="em-impact-bar priority-bar-@SelectedEvent.Priority.ToLower()" style="width:@(SelectedEvent.ImpactScore)%"></div>
                        </div>
                    </div>
                    <div class="em-side-card">
                        <div class="em-side-label">Estadísticas</div>
                        <div class="em-stat-row"><span>Prioridad</span><strong>@SelectedEvent.Priority</strong></div>
                        <div class="em-stat-row"><span>Tendencia</span><strong>@SelectedEvent.Trend</strong></div>
                        <div class="em-stat-row"><span>Artículos</span><strong>@SelectedEventArticles.Count</strong></div>
                        <div class="em-stat-row"><span>Fuentes</span><strong>@SelectedEventArticles.Select(a => a.SourceName).Distinct().Count()</strong></div>
                        @if (SelectedEventArticles.Any())
                        {
                            <div class="em-stat-row"><span>Primer art.</span><strong>@SelectedEventArticles.Min(a => a.PublishedAt).ToString("dd/MM")</strong></div>
                            <div class="em-stat-row"><span>Último art.</span><strong>@SelectedEventArticles.Max(a => a.PublishedAt).ToString("dd/MM")</strong></div>
                        }
                    </div>
                    @if (_articlesByDay.Count > 1)
                    {
                        <div class="em-side-card">
                            <div class="em-side-label">Actividad diaria</div>
                            @{ var maxDayCount = _articlesByDay.Max(d => d.Value.Count); }
                            @foreach (var day in _articlesByDay.OrderByDescending(d => d.Key).Take(7))
                            {
                                var pct = maxDayCount > 0 ? day.Value.Count * 100 / maxDayCount : 0;
                                <div class="em-day-bar-row">
                                    <span class="em-day-label-sm">@day.Key.ToString("dd/MM")</span>
                                    <div class="em-impact-bar-wrap" style="flex:1;margin:0 6px">
                                        <div class="em-impact-bar" style="width:@pct%"></div>
                                    </div>
                                    <span class="em-day-count">@day.Value.Count</span>
                                </div>
                            }
                        </div>
                    }
                    @if (_relatedEvents.Any())
                    {
                        <div class="em-side-card">
                            <div class="em-side-label">Eventos relacionados</div>
                            @foreach (var rel in _relatedEvents)
                            {
                                var relEv = Events.FirstOrDefault(e => e.Id == rel.Id);
                                <div class="em-related-item" @onclick="@(async () => { if (relEv != null) { await OpenEvent(relEv); } })">
                                    <span class="em-priority em-priority-sm priority-bg-@rel.Priority.ToLower()">@rel.Priority[0]</span>
                                    <span class="em-related-title">@rel.Title</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "eventId")]
    private int? AutoOpenEventId { get; set; }

    private HubConnection? _hub;
    private bool IsConnected => _hub?.State == HubConnectionState.Connected;
    private bool IsLoading = true;
    private string SelectedSection = "all";
    private string ViewMode = "grid";
    private DateTime LastUpdate = DateTime.Now;

    private string _searchQuery = "";
    private List<SectionItem> Sections = [];
    private List<EventItem> Events = [];
    private List<ModuleFilterItem> UserModules = [];

    record ModuleFilterItem(int Id, string Name, string Color, List<string> Keywords);

    private List<EventItem> FilteredEvents
    {
        get
        {
            IEnumerable<EventItem> q = Events;
            if (SelectedSection.StartsWith("module:") && int.TryParse(SelectedSection[7..], out var modId))
            {
                var mod = UserModules.FirstOrDefault(m => m.Id == modId);
                if (mod != null)
                {
                    var kws = mod.Keywords.Select(k => k.ToLowerInvariant()).ToList();
                    q = Events.Where(e =>
                    {
                        var txt = $"{e.Title} {e.Description} {string.Join(" ", e.Tags)}".ToLowerInvariant();
                        return kws.Any(k => txt.Contains(k));
                    });
                }
            }
            else if (SelectedSection != "all")
            {
                q = Events.Where(e => e.SectionSlug == SelectedSection);
            }
            if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                var s = _searchQuery.Trim().ToLowerInvariant();
                q = q.Where(e =>
                    (e.Title?.ToLowerInvariant().Contains(s) ?? false) ||
                    (e.Description?.ToLowerInvariant().Contains(s) ?? false) ||
                    e.Tags.Any(t => t.ToLowerInvariant().Contains(s)));
            }
            return q.ToList();
        }
    }

    private List<AlertItem> CriticalAlerts = [];
    private EventItem? SelectedEvent;
    private List<ArticleItem> SelectedEventArticles = [];
    private HashSet<int> _expandedArticles = [];
    private string _modalSummaryLang = "es";
    private Dictionary<int, string> _articleSummariesEn = [];
    private HashSet<int> _generatingEnSummary = [];
    private DotNetObjectReference<Index>? _dotnetRef;
    private Dictionary<DateTime, List<ArticleItem>> _articlesByDay = [];
    private List<RelatedEventItem> _relatedEvents = [];
    private DateTime? _selectedEventEnd;
    private bool _selectedEventIsActive = true;

    protected override async Task OnInitializedAsync()
    {
        Sections = await Ctx.NewsSections
            .Where(s => s.IsPublic && !s.IsDeleted)
            .OrderBy(s => s.SortOrder)
            .Select(s => new SectionItem(s.Id, s.Name, s.Slug, s.Color ?? "#4a90e2", s.IconClass ?? "fa-newspaper"))
            .ToListAsync();

        await LoadEventsAsync();
        IsLoading = false;
    }

    private async Task LoadEventsAsync()
    {
        Events = await Ctx.NewsEvents
            .Include(e => e.Section)
            .Where(e => e.IsActive && e.EventType != "Unclassified")
            .OrderByDescending(e => e.Priority)
            .ThenByDescending(e => e.ImpactScore)
            .Take(50)
            .Select(e => new EventItem(
                e.Id, e.Title, e.Description, e.Priority.ToString(),
                e.ImpactScore, e.Trend.ToString(), e.Tags,
                e.Section.Name, e.Section.Slug, e.StartDate,
                e.Articles.Count(a => !a.IsDeleted),
                e.Articles.Where(a => !a.IsDeleted)
                    .OrderByDescending(a => a.Relevance)
                    .Take(6)
                    .Select(a => new MoonArticle(a.Id, a.Title, a.SourceName))
                    .ToArray(),
                e.Latitude, e.Longitude, e.Location))
            .ToListAsync();

        CriticalAlerts = await Ctx.AlertTriggers
            .Where(a => !a.IsAcknowledged)
            .OrderByDescending(a => a.Severity)
            .Take(5)
            .Select(a => new AlertItem(a.Id, a.Title))
            .ToListAsync();

        LastUpdate = DateTime.Now;
    }

    private async Task SetupSignalRAsync()
    {
        try
        {
            _hub = new HubConnectionBuilder()
                .WithUrl(NavManager.ToAbsoluteUri("/newshub"))
                .WithAutomaticReconnect()
                .Build();

            _hub.On<object>("NewEvent", async _ =>
            {
                await LoadEventsAsync();
                await InvokeAsync(StateHasChanged);
                if (ViewMode == "universe")
                    try { await JS.InvokeVoidAsync("universe.updateData", FilteredEvents, Sections); } catch { }
            });

            _hub.On<object>("CriticalAlert", async _ =>
            {
                await LoadEventsAsync();
                await InvokeAsync(StateHasChanged);
            });

            await _hub.StartAsync();
            await _hub.SendAsync("JoinSection", SelectedSection);
        }
        catch
        {
            // Hub no disponible — modo sin actualización en tiempo real
        }
    }

    private bool _pendingUniverseInit = false;
    private bool _pendingMapInit = false;

    // ── Theme ──────────────────────────────────────────────
    private bool _themeMenuOpen = false;
    private string _currentTheme = "dark";
    record ThemeInfo(string Name, string Bg, string Accent);
    private static readonly Dictionary<string, ThemeInfo> _themes = new()
    {
        ["dark"]   = new ThemeInfo("Oscuro",  "#000511", "#4a90e2"),
        ["light"]  = new ThemeInfo("Claro",   "#f0f4f8", "#1a6fd4"),
        ["blue"]   = new ThemeInfo("Océano",  "#020c1b", "#00b4ff"),
