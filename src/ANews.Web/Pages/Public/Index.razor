    private void PickSerendipityEvent()
    {
        if (!UserModules.Any() || Events.Count < 10) { _serendipityEvent = null; return; }

        // Get sections the user follows via module keywords
        var userKeywords = UserModules.SelectMany(m => m.Keywords).Select(k => k.ToLowerInvariant()).ToHashSet();

        // Find high-impact events that DON'T match user keywords
        var candidates = Events
            .Where(e => e.ImpactScore >= 60 && !userKeywords.Any(kw =>
                (e.Title?.ToLowerInvariant().Contains(kw) ?? false) ||
                (e.Description?.ToLowerInvariant().Contains(kw) ?? false)))
            .OrderByDescending(e => e.ImpactScore)
            .Take(5)
            .ToList();

        // Pick a random one from top 5 so it changes each session
        if (candidates.Count > 0)
            _serendipityEvent = candidates[Random.Shared.Next(candidates.Count)];
        else
            _serendipityEvent = null;
    }

