    private void ToggleThemeMenu() => _themeMenuOpen = !_themeMenuOpen;

    private async Task SetTheme(string theme)
    {
        _currentTheme = theme;
        _themeMenuOpen = false;
        try { await JS.InvokeVoidAsync("themeManager.setTheme", theme); } catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { _currentTheme = await JS.InvokeAsync<string>("themeManager.getTheme") ?? "dark"; } catch { }
            await SetupSignalRAsync();

            if (AutoOpenEventId.HasValue)
            {
                var ev = Events.FirstOrDefault(e => e.Id == AutoOpenEventId.Value);
                if (ev != null) { await OpenEvent(ev); StateHasChanged(); }
            }

            await LoadUserKeywordsAsync();

            if (ViewMode == "universe")
                await InitUniverseAsync();
            return;
        }

        // Canvas is guaranteed in DOM here — safe to init universe
        if (_pendingUniverseInit)
        {
            _pendingUniverseInit = false;
            await InitUniverseAsync();
            await LoadUserKeywordsAsync();
        }
        if (_pendingMapInit)
        {
            _pendingMapInit = false;
            await InitMapAsync();
        }
    }

    private async Task LoadUserKeywordsAsync()
    {
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            if (!(auth.User.Identity?.IsAuthenticated ?? false)) return;

            var userName = auth.User.Identity?.Name;
            if (string.IsNullOrEmpty(userName)) return;

            var user = await Ctx.Users.FirstOrDefaultAsync(u => u.UserName == userName);
            if (user == null) return;

            var modules = await Ctx.Set<ANews.Domain.Entities.UserModule>()
                .Include(m => m.Keywords)
                .Where(m => m.UserId == user.Id && !m.IsDeleted && m.IsActive)
                .ToListAsync();

            UserModules = modules.Select(m => new ModuleFilterItem(
                m.Id, m.Name, m.Color ?? "#4a90e2",
                m.Keywords.Select(k => k.Keyword).ToList()
            )).ToList();

            var allKeywords = modules.SelectMany(m => m.Keywords).Select(k => k.Keyword).Distinct().ToList();
            if (allKeywords.Count > 0)
                try { await JS.InvokeVoidAsync("universe.setUserKeywords", allKeywords); } catch { }

            if (UserModules.Count > 0)
                await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    private async Task InitUniverseAsync()
    {
        _dotnetRef ??= DotNetObjectReference.Create(this);
        try { await JS.InvokeVoidAsync("universe.init", "universe-canvas", FilteredEvents, Sections, _dotnetRef); }
        catch { /* universe.js no disponible */ }
    }

    private async Task InitMapAsync()
    {
        _dotnetRef ??= DotNetObjectReference.Create(this);
        try { await JS.InvokeVoidAsync("newsMap.init", "map-view", Events, _dotnetRef); }
        catch { }
    }

    [JSInvokable]
    public async Task OpenEventById(int id)
    {
        var ev = Events.FirstOrDefault(e => e.Id == id);
        if (ev != null)
        {
            await OpenEvent(ev);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SetViewMode(string mode)
    {
        if (mode != "universe")
            try { await JS.InvokeVoidAsync("universe.destroy"); } catch { }
        if (mode != "map")
            try { await JS.InvokeVoidAsync("newsMap.destroy"); } catch { }

        ViewMode = mode;
        if (mode == "universe")
        {
            _pendingUniverseInit = true;
            StateHasChanged();
        }
        else if (mode == "map")
        {
            _pendingMapInit = true;
            StateHasChanged();
        }
    }

    private async Task SelectSection(string slug)
    {
        if (_hub?.State == HubConnectionState.Connected)
        {
            await _hub.SendAsync("LeaveSection", SelectedSection);
            await _hub.SendAsync("JoinSection", slug);
        }
        SelectedSection = slug;

        if (ViewMode == "universe")
        {
            // In universe mode, always show all events; use keywords for highlighting
            if (slug.StartsWith("module:") && int.TryParse(slug[7..], out var modId))
            {
                var mod = UserModules.FirstOrDefault(m => m.Id == modId);
                if (mod != null)
                    try { await JS.InvokeVoidAsync("universe.setUserKeywords", mod.Keywords); } catch { }
            }
            else
            {
                // Restore all user keywords
                var allKws = UserModules.SelectMany(m => m.Keywords).Distinct().ToList();
                try { await JS.InvokeVoidAsync("universe.setUserKeywords", allKws); } catch { }
            }
            try { await JS.InvokeVoidAsync("universe.updateData", FilteredEvents, Sections); } catch { }
        }
    }

    private async Task OpenEvent(EventItem ev)
    {
        SelectedEvent = ev;
        _expandedArticles.Clear();
        _articleSummariesEn.Clear();
        _generatingEnSummary.Clear();

        SelectedEventArticles = await Ctx.NewsArticles
            .Where(a => a.NewsEventId == ev.Id && !a.IsDeleted)
            .OrderByDescending(a => a.PublishedAt)
            .Select(a => new ArticleItem(a.Id, a.Title, a.SourceName, a.SourceUrl,
                a.Relevance, a.ArticleType.ToString(), a.Summary, a.PublishedAt))
            .ToListAsync();

        _articlesByDay = SelectedEventArticles
            .GroupBy(a => a.PublishedAt.Date)
            .OrderByDescending(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());

        var evDb = await Ctx.NewsEvents.FindAsync(ev.Id);
        if (evDb != null)
        {
            _selectedEventEnd = evDb.EndDate;
            _selectedEventIsActive = evDb.IsActive;
        }

        _relatedEvents = await Ctx.NewsEvents
            .Where(e => e.NewsSectionId == evDb!.NewsSectionId && e.Id != ev.Id && e.IsActive && !e.IsDeleted)
            .OrderByDescending(e => e.ImpactScore)
            .Take(5)
            .Select(e => new RelatedEventItem(e.Id, e.Title, e.Priority.ToString()))
            .ToListAsync();
    }

    private void CloseEvent() { SelectedEvent = null; _expandedArticles.Clear(); _articleSummariesEn.Clear(); _generatingEnSummary.Clear(); }

    private async Task GenerateEnSummaryAsync(ArticleItem art)
    {
        if (_generatingEnSummary.Contains(art.Id)) return;
        _generatingEnSummary.Add(art.Id);
        StateHasChanged();
        try
        {
            var provider = await AiFactory.GetDefaultProviderAsync();
            var text = string.IsNullOrEmpty(art.Summary) ? art.Title : art.Summary;
            var response = await provider.CompleteAsync(new AiRequest
            {
                SystemPrompt = "You are an expert news editor. Summarize or translate the following into 2-3 clear, objective sentences in English.",
                UserPrompt = $"Title: {art.Title}\n\nContent: {text}",
                MaxTokens = 300,
                Temperature = 0.3,
                OperationTag = "article_summary_en"
            });
            if (response.Success && !string.IsNullOrEmpty(response.Content))
                _articleSummariesEn[art.Id] = response.Content.Trim();
        }
        catch { }
        finally
        {
            _generatingEnSummary.Remove(art.Id);
            await InvokeAsync(StateHasChanged);
        }
    }

