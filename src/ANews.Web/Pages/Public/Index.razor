    [JSInvokable]
    public async Task OpenEventById(int id)
    {
        try
        {
            var ev = Events.FirstOrDefault(e => e.Id == id);
            if (ev == null)
            {
                // Event not in filtered list — load from DB
                var dbEv = await Ctx.NewsEvents.Include(e => e.Section)
                    .FirstOrDefaultAsync(e => e.Id == id && !e.IsDeleted);
                if (dbEv != null)
                    ev = new EventItem(dbEv.Id, dbEv.Title, dbEv.Description, dbEv.Priority.ToString(),
                        dbEv.ImpactScore, dbEv.Trend.ToString(), dbEv.Tags.ToArray(),
                        dbEv.Section?.Name ?? "", dbEv.Section?.Slug ?? "", dbEv.StartDate,
                        0, [], dbEv.Latitude, dbEv.Longitude, dbEv.Location,
                        dbEv.StoryThreadId, dbEv.SourceDiversity);
            }
            if (ev != null)
            {
                await OpenEvent(ev);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"OpenEventById error: {ex.Message}");
        }
    }

    private async Task SetViewMode(string mode)
    {
        if (mode != "universe")
            try { await JS.InvokeVoidAsync("universe.destroy"); } catch { }
        if (mode != "universe3d")
            try { await JS.InvokeVoidAsync("universe3d.destroy"); } catch { }
        if (mode != "map")
            try { await JS.InvokeVoidAsync("newsMap.destroy"); } catch { }

        ViewMode = mode;
        if (mode == "universe")
        {
            _pendingUniverseInit = true;
            StateHasChanged();
        }
        else if (mode == "universe3d")
        {
            _pendingUniverse3dInit = true;
            StateHasChanged();
        }
        else if (mode == "map")
        {
            _pendingMapInit = true;
            StateHasChanged();
        }
    }

    private async Task SelectSection(string slug)
    {
        if (_hub?.State == HubConnectionState.Connected)
        {
            await _hub.SendAsync("LeaveSection", SelectedSection);
            await _hub.SendAsync("JoinSection", slug);
        }
        SelectedSection = slug;

        var sectionId = Sections.FirstOrDefault(s => s.Slug == slug)?.Id;
        _ = TrackActivity(ActivityType.SectionFiltered, sectionId: sectionId, metadata: slug);

        if (ViewMode == "universe")
        {
            // In universe mode, always show all events; use keywords for highlighting
            if (slug.StartsWith("module:") && int.TryParse(slug[7..], out var modId))
            {
                var mod = UserModules.FirstOrDefault(m => m.Id == modId);
                if (mod != null)
                    try { await JS.InvokeVoidAsync("universe.setUserKeywords", mod.Keywords); } catch { }
            }
            else
            {
                // Restore all user keywords
                var allKws = UserModules.SelectMany(m => m.Keywords).Distinct().ToList();
                try { await JS.InvokeVoidAsync("universe.setUserKeywords", allKws); } catch { }
            }
            try { await JS.InvokeVoidAsync("universe.updateData", FilteredEvents, Sections); } catch { }
        }
    }

    private async Task OpenEvent(EventItem ev)
    {
        SelectedEvent = ev;
        _expandedArticles.Clear();
        _articleSummariesEn.Clear();
        _generatingEnSummary.Clear();

        var sectionId = Sections.FirstOrDefault(s => s.Slug == ev.SectionSlug)?.Id;
        _ = TrackActivity(ActivityType.EventOpened, sectionId: sectionId, eventId: ev.Id);

        SelectedEventArticles = await Ctx.NewsArticles
            .Include(a => a.Source)
            .Where(a => a.NewsEventId == ev.Id && !a.IsDeleted)
            .OrderByDescending(a => a.PublishedAt)
            .Select(a => new ArticleItem(a.Id, a.Title, a.SourceName, a.SourceUrl,
                a.Relevance, a.ArticleType.ToString(), a.Summary, a.PublishedAt,
                a.Source != null ? a.Source.CredibilityScore : 0,
                a.Source != null ? a.Source.Bias.ToString() : null))
            .ToListAsync();

        _articlesByDay = SelectedEventArticles
            .GroupBy(a => a.PublishedAt.Date)
            .OrderByDescending(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());

        var evDb = await Ctx.NewsEvents.FindAsync(ev.Id);
        if (evDb != null)
        {
            _selectedEventEnd = evDb.EndDate;
            _selectedEventIsActive = evDb.IsActive;
        }

        _relatedEvents = await Ctx.NewsEvents
            .Where(e => e.NewsSectionId == evDb!.NewsSectionId && e.Id != ev.Id && e.IsActive && !e.IsDeleted)
            .OrderByDescending(e => e.ImpactScore)
            .Take(5)
            .Select(e => new RelatedEventItem(e.Id, e.Title, e.Priority.ToString()))
            .ToListAsync();

        // Load contextual briefing
        _eventBriefing = await Ctx.EventBriefings
            .Where(b => b.NewsEventId == ev.Id && b.Type == ANews.Domain.Enums.BriefingType.EventContext)
            .OrderByDescending(b => b.GeneratedAt)
            .FirstOrDefaultAsync();

        // Load story thread if linked
        _selectedEventThread = evDb?.StoryThreadId != null
            ? await Ctx.StoryThreads.FindAsync(evDb.StoryThreadId)
            : null;
    }

    private void CloseEvent() { SelectedEvent = null; _expandedArticles.Clear(); _articleSummariesEn.Clear(); _generatingEnSummary.Clear(); StateHasChanged(); }

