@page "/planes"
@inject ANews.Infrastructure.Data.AppDbContext Ctx
@inject AuthenticationStateProvider AuthStateProvider
@using ANews.Infrastructure.Data
@using ANews.Domain.Entities
@using ANews.Domain.Enums
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore

<PageTitle>Planes — AgenteNews</PageTitle>

<div class="planes-page">
    <header class="site-header" style="background:var(--space-navy);border-bottom:1px solid var(--border);padding:12px 24px;display:flex;align-items:center;gap:12px">
        <a href="/" style="text-decoration:none;color:inherit;display:flex;align-items:center;gap:8px">
            <i class="fa fa-satellite" style="color:var(--accent)"></i>
            <span style="font-weight:700;font-size:15px">AGENTE<strong>NEWS</strong></span>
        </a>
    </header>

    <div class="planes-header">
        <h1>Planes de suscripción</h1>
        <p>Elige el plan que mejor se adapte a tu nivel de lectura.</p>
    </div>

    @if (_plans.Count == 0)
    {
        <p style="text-align:center;color:var(--text-muted);padding:40px">Cargando planes...</p>
    }
    else
    {
        <div class="planes-grid">
            @foreach (var plan in _plans)
            {
                var isFeatured = plan.Tier == PlanTier.Pro;
                <div class="plan-card @(isFeatured ? "plan-featured" : "")">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
                        <span class="plan-card-name">@plan.Name</span>
                        <span class="plan-tier-badge plan-tier-@plan.Tier.ToString().ToLower()">@plan.Tier</span>
                    </div>
                    <div class="plan-card-price">
                        @if (plan.MonthlyPrice == 0)
                        {
                            <span style="font-size:32px;font-weight:800">Gratis</span>
                        }
                        else
                        {
                            @:$@plan.MonthlyPrice.ToString("0.##") <span>/ mes</span>
                        }
                    </div>
                    <div class="plan-card-limit">
                        @if (plan.DefaultMaxReadsPerMonth < 0)
                        {
                            <span>Lecturas ilimitadas</span>
                        }
                        else
                        {
                            <span>@plan.DefaultMaxReadsPerMonth lecturas / mes por sección</span>
                        }
                    </div>
                    @if (plan.Features.Length > 0)
                    {
                        <ul class="plan-card-features">
                            @foreach (var feat in plan.Features)
                            {
                                <li><i class="fa fa-check-circle"></i> @feat</li>
                            }
                        </ul>
                    }
                    @if (!string.IsNullOrEmpty(plan.Description))
                    {
                        <p style="font-size:12px;color:var(--text-muted);margin-bottom:16px">@plan.Description</p>
                    }
                    <a href="@(_isAuthenticated ? "/user/profile" : "/auth/register")"
                       class="btn-plan @(isFeatured ? "btn-plan-primary" : "btn-plan-outline")">
                        @(_isAuthenticated ? "Gestionar plan" : "Seleccionar")
                    </a>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<SubscriptionPlan> _plans = [];
    private bool _isAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = auth.User.Identity?.IsAuthenticated ?? false;

        _plans = await Ctx.SubscriptionPlans
            .Where(p => p.IsActive)
            .OrderBy(p => p.SortOrder)
            .ThenBy(p => p.MonthlyPrice)
            .ToListAsync();
    }
}
