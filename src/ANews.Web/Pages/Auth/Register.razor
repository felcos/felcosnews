@page "/register"

<PageTitle>Registrarse — AgenteNews</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-logo">
            <i class="fa fa-satellite"></i>
            <span>AGENTE<strong>NEWS</strong></span>
        </div>
        <h2>Crear cuenta</h2>

        @if (Success == "check-email")
        {
            <div class="auth-success">
                <i class="fa fa-envelope"></i>
                <strong>Revisa tu email</strong>
                <p>Te hemos enviado un enlace de confirmación. Haz clic en él para activar tu cuenta.</p>
                <a href="/login" class="btn-auth" style="display:block;text-align:center;margin-top:12px;">Ir a iniciar sesión</a>
            </div>
        }
        else
        {

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="auth-error"><i class="fa fa-exclamation-circle"></i> @ErrorMessage</div>
        }

        <form method="post" action="/account/register">
            <div class="form-group">
                <label>Nombre</label>
                <input type="text" name="displayName" class="form-input" autocomplete="name" />
            </div>
            <div class="form-group">
                <label>Email *</label>
                <input type="email" name="email" class="form-input" autocomplete="email" required />
            </div>
            <div class="form-group">
                <label>Contraseña *</label>
                <input type="password" name="password" class="form-input" autocomplete="new-password" required minlength="8" />
            </div>
            <div class="form-group">
                <label>Confirmar contraseña *</label>
                <input type="password" name="confirmPassword" class="form-input" autocomplete="new-password" required />
            </div>
            <button type="submit" class="btn-auth">Registrarse</button>
        </form>

        <div class="auth-links">
            <a href="/login">¿Ya tienes cuenta? Inicia sesión</a>
        </div>
        } @* end else *@
    </div>
</div>

@code {
    [SupplyParameterFromQuery] private string? Error { get; set; }
    [SupplyParameterFromQuery] private string? Success { get; set; }

    private string? ErrorMessage => Error switch
    {
        "required" => "Email y contraseña son obligatorios.",
        "mismatch" => "Las contraseñas no coinciden.",
        _ => string.IsNullOrEmpty(Error) ? null : Uri.UnescapeDataString(Error)
    };
}
