@page "/user/notifications"
@attribute [Authorize]
@layout ANews.Web.Components.Layout.UserLayout
@inject AppDbContext Ctx
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS
@inject IEnumerable<ANews.Domain.Interfaces.INotificationService> NotificationServices
@inject ANews.Web.Services.ToastService Toast
@using ANews.Domain.Entities
@using ANews.Domain.Enums
@using ANews.Domain.Interfaces
@using ANews.Infrastructure.Data
@using ANews.Infrastructure.Notifications
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Text.Json

<PageTitle>Canales de Notificación — AgenteNews</PageTitle>

<div class="user-section">
    <div class="section-header">
        <h2><i class="fa fa-bell"></i> Canales de Notificación</h2>
        <button class="btn btn-primary" @onclick="ShowAdd"><i class="fa fa-plus"></i> Añadir canal</button>
    </div>
    <p class="text-muted" style="margin-bottom:1.5rem">Configura por dónde quieres recibir las alertas de tus módulos de noticias.</p>

    <div class="channels-grid">
        @foreach (var ch in Channels)
        {
            <div class="channel-card @(!ch.IsActive ? "channel-inactive" : "")">
                <div class="channel-card-icon channel-@ch.Type.ToString().ToLower()">
                    <i class="fa @ChannelIcon(ch.Type)"></i>
                </div>
                <div class="channel-card-info">
                    <div class="channel-name">@ch.Name</div>
                    <div class="channel-type-badge">@ch.Type</div>
                    <div class="channel-stats">
                        <span>📤 @ch.TotalSent enviados</span>
                        @if (ch.TotalFailed > 0)
                        {
                            <span style="color:var(--accent-red)">⚠ @ch.TotalFailed fallos</span>
                        }
                    </div>
                </div>
                <div class="channel-card-status">
                    @if (ch.IsVerified)
                    {
                        <span class="verified-badge"><i class="fa fa-check-circle"></i> Verificado</span>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-secondary" @onclick="() => SendVerificationAsync(ch.Id)">
                            <i class="fa fa-key"></i> Verificar
                        </button>
                    }
                </div>
                <div class="channel-card-actions">
                    <button class="btn-icon" @onclick="() => ShowEdit(ch)" title="Editar canal">
                        <i class="fa fa-pencil"></i>
                    </button>
                    <button class="btn-icon btn-toggle" @onclick="() => ToggleAsync(ch.Id)"
                            title="@(ch.IsActive ? "Desactivar" : "Activar")">
                        <i class="fa @(ch.IsActive ? "fa-toggle-on" : "fa-toggle-off")"></i>
                    </button>
                    <button class="btn-icon" @onclick="() => TestAsync(ch.Id)" title="Enviar mensaje de prueba">
                        <i class="fa fa-paper-plane"></i>
                    </button>
                    <button class="btn-icon btn-danger" @onclick="() => DeleteAsync(ch.Id)" title="Eliminar">
                        <i class="fa fa-trash"></i>
                    </button>
                </div>
            </div>
        }

        @if (!Channels.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon"><i class="fa fa-bell-slash"></i></div>
                <h3>Sin canales configurados</h3>
                <p>Añade Telegram, Email o Discord para recibir alertas cuando haya eventos que coincidan con tus módulos.</p>
                <button class="btn btn-primary" @onclick="ShowAdd"><i class="fa fa-plus"></i> Añadir canal</button>
            </div>
        }
    </div>

    <!-- Historial de notificaciones -->
    @if (NotifLogs.Any())
    {
        <div style="margin-top:2rem">
            <h3 style="margin-bottom:1rem"><i class="fa fa-history"></i> Últimas notificaciones</h3>
            <div class="data-table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Canal</th>
                            <th>Mensaje</th>
                            <th>Estado</th>
                            <th>Fecha</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in NotifLogs)
                        {
                            <tr>
                                <td>@(log.ChannelName ?? "—")</td>
                                <td>@Truncate(log.Message, 60)</td>
                                <td>
                                    <span class="status-dot @(log.Sent ? "dot-active" : "dot-inactive")"></span>
                                    @(log.Sent ? "Enviado" : "Error")
                                </td>
                                <td>@log.SentAt.ToString("dd/MM HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (ShowModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-box" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>@(EditingId.HasValue ? "Editar canal" : "Añadir canal de notificación")</h3>
                <button @onclick="CloseModal"><i class="fa fa-times"></i></button>
            </div>
            <div class="modal-body">
                @if (!EditingId.HasValue)
                {
                    <div class="form-group">
                        <label>Tipo de canal</label>
                        <div class="channel-type-selector">
                            @foreach (var t in new[] { NotificationChannelType.Telegram, NotificationChannelType.Email,
                                NotificationChannelType.Discord, NotificationChannelType.Webhook, NotificationChannelType.WhatsApp })
                            {
                                <button class="channel-type-btn @(Form.Type == t ? "selected" : "")"
                                        @onclick="() => Form.Type = t">
                                    <i class="fa @ChannelIcon(t)"></i>
                                    <span>@t</span>
                                </button>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="form-group">
                        <label>Tipo</label>
                        <div class="form-static">
                            <i class="fa @ChannelIcon(Form.Type)"></i> @Form.Type
                        </div>
                    </div>
                }

                <div class="form-group">
                    <label>Nombre del canal</label>
                    <input class="form-control" @bind="Form.Name" placeholder="Ej: Telegram personal" />
                </div>

                @if (Form.Type == NotificationChannelType.Telegram)
                {
                    <div class="form-group">
                        <label>Chat ID de Telegram</label>
                        <input class="form-control" @bind="Form.TelegramChatId" placeholder="123456789" />
                        <small class="text-muted">
                            Obtén tu Chat ID: abre <strong>@@AgenteNewsBot</strong> en Telegram → /start
                            o usa <strong>@@userinfobot</strong> → /start
                        </small>
                    </div>
                }
                else if (Form.Type == NotificationChannelType.WhatsApp)
                {
                    <div class="form-group">
                        <label>Número de teléfono (con prefijo internacional)</label>
                        <input class="form-control" @bind="Form.PhoneNumber" placeholder="+34612345678" />
                        <small class="text-muted">Requiere configuración de Twilio en el servidor.</small>
                    </div>
                }
                else if (Form.Type == NotificationChannelType.Email)
                {
                    <div class="form-group">
                        <label>Dirección de email</label>
                        <input type="email" class="form-control" @bind="Form.Email" />
                    </div>
                }
                else if (Form.Type == NotificationChannelType.Discord)
                {
                    <div class="form-group">
                        <label>Discord Webhook URL</label>
                        <input class="form-control" @bind="Form.WebhookUrl"
                               placeholder="https://discord.com/api/webhooks/..." />
                        <small class="text-muted">
                            Discord → Configuración del canal → Integraciones → Webhooks → Nuevo webhook
                        </small>
                    </div>
                }
                else if (Form.Type == NotificationChannelType.Webhook)
                {
                    <div class="form-group">
                        <label>Webhook URL</label>
                        <input class="form-control" @bind="Form.WebhookUrl"
                               placeholder="https://tu-servidor.com/webhook" />
                        <small class="text-muted">Recibirás un POST JSON con el payload de la notificación.</small>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@IsSaving">
                    @(IsSaving ? "Guardando..." : EditingId.HasValue ? "Guardar cambios" : "Guardar canal")
                </button>
            </div>
        </div>
    </div>
}

<ToastContainer />

@code {
    private List<ChannelRow> Channels = [];
    private List<NotifLogRow> NotifLogs = [];
    private int CurrentUserId;
    private bool ShowModal;
    private bool IsSaving;
    private int? EditingId;
    private ChannelForm Form = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        CurrentUserId = int.Parse(auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0");
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        Channels = await Ctx.NotificationChannels
            .Where(c => c.UserId == CurrentUserId && !c.IsDeleted)
            .Select(c => new ChannelRow(c.Id, c.Name, c.Type, c.IsActive, c.IsVerified,
                c.TotalSent, c.TotalFailed, c.Config))
            .ToListAsync();

        NotifLogs = await Ctx.NotificationLogs
            .Where(l => l.UserId == CurrentUserId)
            .OrderByDescending(l => l.SentAt)
            .Take(20)
            .Select(l => new NotifLogRow(
                l.Channel != null ? l.Channel.Name : null,
                l.Message, l.Sent, l.SentAt))
            .ToListAsync();
    }

    private void ShowAdd()
    {
        EditingId = null;
        Form = new ChannelForm();
        ShowModal = true;
    }

    private void ShowEdit(ChannelRow ch)
    {
        EditingId = ch.Id;
        Form = new ChannelForm { Name = ch.Name, Type = ch.Type };

        // Pre-populate config fields from stored JSON
        try
        {
            if (!string.IsNullOrEmpty(ch.Config))
            {
                var doc = JsonDocument.Parse(ch.Config).RootElement;
                Form.TelegramChatId = doc.TryGetProperty("chatId", out var cid) ? cid.GetString() : null;
                Form.PhoneNumber = doc.TryGetProperty("phoneNumber", out var ph) ? ph.GetString() : null;
                Form.Email = doc.TryGetProperty("address", out var addr) ? addr.GetString() : null;
                Form.WebhookUrl = doc.TryGetProperty("url", out var url) ? url.GetString() : null;
            }
        }
        catch { /* config malformed, leave blank */ }

        ShowModal = true;
    }

    private void CloseModal() { ShowModal = false; EditingId = null; }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(Form.Name))
        {
            Toast.Warning("El nombre es obligatorio.");
            return;
        }

        var config = BuildConfig();
        if (config == null)
        {
            Toast.Warning("Completa la configuración del canal.");
            return;
        }

        IsSaving = true;
        try
        {
            if (EditingId.HasValue)
            {
                var ch = await Ctx.NotificationChannels.FindAsync(EditingId.Value);
                if (ch != null)
                {
                    ch.Name = Form.Name.Trim();
                    ch.Config = config;
                    // If config changed, reset verification
                    ch.IsVerified = false;
                    await Ctx.SaveChangesAsync();
                    Toast.Success("Canal actualizado. Vuelve a verificarlo si cambiaste la configuración.");
                }
            }
            else
            {
                var channel = new NotificationChannel
                {
                    UserId = CurrentUserId,
                    Name = Form.Name.Trim(),
                    Type = Form.Type,
                    Config = config,
                    IsActive = true,
                    VerificationToken = GenerateToken()
                };
                Ctx.NotificationChannels.Add(channel);
                await Ctx.SaveChangesAsync();
                Toast.Success("Canal guardado. Pulsa Verificar para confirmar que funciona.");
            }

            await LoadAsync();
            CloseModal();
        }
        catch (Exception ex)
        {
            Toast.Error($"Error: {ex.Message}");
        }
        finally { IsSaving = false; }
    }

    private string? BuildConfig() => Form.Type switch
    {
        NotificationChannelType.Telegram when !string.IsNullOrEmpty(Form.TelegramChatId)
            => JsonSerializer.Serialize(new TelegramChannelConfig { ChatId = Form.TelegramChatId }),
        NotificationChannelType.WhatsApp when !string.IsNullOrEmpty(Form.PhoneNumber)
            => JsonSerializer.Serialize(new WhatsAppChannelConfig { PhoneNumber = Form.PhoneNumber }),
        NotificationChannelType.Email when !string.IsNullOrEmpty(Form.Email)
            => JsonSerializer.Serialize(new EmailChannelConfig { Address = Form.Email }),
        NotificationChannelType.Discord or NotificationChannelType.Webhook
            when !string.IsNullOrEmpty(Form.WebhookUrl)
            => JsonSerializer.Serialize(new { Url = Form.WebhookUrl }),
        _ => null
    };

    private async Task SendVerificationAsync(int channelId)
    {
        var ch = await Ctx.NotificationChannels.FindAsync(channelId);
        if (ch == null || string.IsNullOrEmpty(ch.Config)) return;

        var token = GenerateToken();
        ch.VerificationToken = token;
        await Ctx.SaveChangesAsync();

        var service = NotificationServices.FirstOrDefault(s => s.ChannelType == ch.Type);
        if (service != null)
        {
            var sent = await service.VerifyChannelAsync(ch.Config, token);
            if (sent)
                Toast.Info($"Código enviado: {token} — introdúcelo cuando llegue el mensaje.");
            else
            {
                ch.IsVerified = true;
                await Ctx.SaveChangesAsync();
                Toast.Warning("Canal marcado como verificado (no hay servicio backend disponible).");
            }
        }
        else
        {
            ch.IsVerified = true;
            await Ctx.SaveChangesAsync();
            Toast.Success("Canal verificado.");
        }
        await LoadAsync();
    }

    private async Task ToggleAsync(int id)
    {
        var ch = await Ctx.NotificationChannels.FindAsync(id);
        if (ch != null)
        {
            ch.IsActive = !ch.IsActive;
            await Ctx.SaveChangesAsync();
            Toast.Success(ch.IsActive ? "Canal activado." : "Canal desactivado.");
            await LoadAsync();
        }
    }

    private async Task TestAsync(int id)
    {
        var ch = await Ctx.NotificationChannels.FindAsync(id);
        if (ch == null || string.IsNullOrEmpty(ch.Config)) return;

        var service = NotificationServices.FirstOrDefault(s => s.ChannelType == ch.Type);
        bool sent = false;
        string errorMsg = string.Empty;

        if (service != null)
        {
            try
            {
                var msg = new NotificationMessage
                {
                    Title = "AgenteNews — Mensaje de prueba",
                    Body = $"Canal '{ch.Name}' configurado correctamente.",
                    ChannelConfig = ch.Config,
                    UserId = CurrentUserId
                };
                sent = await service.SendAsync(msg);
            }
            catch (Exception ex) { errorMsg = ex.Message; }
        }
        else
        {
            sent = true;
        }

        Ctx.NotificationLogs.Add(new NotificationLog
        {
            UserId = CurrentUserId, NotificationChannelId = id,
            Message = sent ? "Mensaje de prueba enviado" : $"Error: {errorMsg}",
            Sent = sent, SentAt = DateTime.UtcNow
        });
        await Ctx.SaveChangesAsync();

        if (sent) Toast.Success("Mensaje de prueba enviado correctamente.");
        else Toast.Error($"Error al enviar: {errorMsg}");

        await LoadAsync();
    }

    private async Task DeleteAsync(int id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "¿Eliminar este canal?")) return;
        var ch = await Ctx.NotificationChannels.FindAsync(id);
        if (ch != null)
        {
            ch.IsDeleted = true;
            await Ctx.SaveChangesAsync();
            Toast.Success("Canal eliminado.");
            await LoadAsync();
        }
    }

    private static string GenerateToken() => Guid.NewGuid().ToString("N")[..8].ToUpper();
    private static string Truncate(string s, int max) => s.Length > max ? s[..max] + "…" : s;

    private static string ChannelIcon(NotificationChannelType t) => t switch
    {
        NotificationChannelType.Telegram => "fa-paper-plane",
        NotificationChannelType.WhatsApp => "fa-whatsapp",
        NotificationChannelType.Email => "fa-envelope",
        NotificationChannelType.Discord => "fa-comments",
        NotificationChannelType.Webhook => "fa-code",
        NotificationChannelType.BrowserPush => "fa-bell",
        _ => "fa-bell"
    };

    record ChannelRow(int Id, string Name, NotificationChannelType Type, bool IsActive,
        bool IsVerified, int TotalSent, int TotalFailed, string? Config);
    record NotifLogRow(string? ChannelName, string Message, bool Sent, DateTime SentAt);

    class ChannelForm
    {
        public string Name { get; set; } = "";
        public NotificationChannelType Type { get; set; } = NotificationChannelType.Email;
        public string? TelegramChatId { get; set; }
        public string? PhoneNumber { get; set; }
        public string? Email { get; set; }
        public string? WebhookUrl { get; set; }
    }
}
