@page "/user/profile"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using ANews.Infrastructure.Data
@using ANews.Domain.Entities
@using ANews.Domain.Enums
@attribute [Authorize]
@layout ANews.Web.Components.Layout.UserLayout
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState
@inject ANews.Web.Services.ToastService Toast
@inject AppDbContext Ctx

<PageTitle>Mi Perfil — AgenteNews</PageTitle>

<div class="user-section">
    <div class="section-header">
        <h2><i class="fa fa-user-circle"></i> Mi Perfil</h2>
    </div>

    @if (_loading)
    {
        <div class="loading-spinner-wrap"><div class="loading-spinner"></div></div>
    }
    else if (_user != null)
    {
        <div class="profile-grid">

            <!-- Datos personales -->
            <div class="profile-card">
                <h3><i class="fa fa-id-card"></i> Datos de cuenta</h3>

                <div class="form-group">
                    <label>Nombre visible</label>
                    <input class="form-control" @bind="_displayName" placeholder="Tu nombre" />
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input class="form-control" value="@_user.Email" disabled />
                    @if (_user.EmailConfirmed)
                    {
                        <small style="color:var(--accent-green)"><i class="fa fa-check-circle"></i> Email verificado</small>
                    }
                    else
                    {
                        <small style="color:var(--accent-red)"><i class="fa fa-exclamation-circle"></i> Email no verificado</small>
                    }
                </div>
                <div class="form-group">
                    <label>Rol</label>
                    <input class="form-control" value="@_user.Role" disabled />
                </div>
                <div class="form-group">
                    <label>Miembro desde</label>
                    <input class="form-control" value="@_user.CreatedAt.ToString("dd/MM/yyyy")" disabled />
                </div>

                <button class="btn btn-primary" @onclick="SaveProfileAsync" disabled="@_savingProfile">
                    @(_savingProfile ? "Guardando..." : "Guardar cambios")
                </button>
            </div>

            <!-- Cambiar contraseña -->
            <div class="profile-card">
                <h3><i class="fa fa-lock"></i> Cambiar contraseña</h3>

                <div class="form-group">
                    <label>Contraseña actual</label>
                    <input type="password" class="form-control" @bind="_currentPassword" autocomplete="current-password" />
                </div>
                <div class="form-group">
                    <label>Nueva contraseña</label>
                    <input type="password" class="form-control" @bind="_newPassword" autocomplete="new-password" />
                    <small style="color:var(--text-muted)">Mínimo 8 caracteres con símbolo especial</small>
                </div>
                <div class="form-group">
                    <label>Confirmar nueva contraseña</label>
                    <input type="password" class="form-control" @bind="_confirmNewPassword" autocomplete="new-password" />
                </div>

                @if (!string.IsNullOrEmpty(_passwordError))
                {
                    <div class="alert alert-danger mt-2">@_passwordError</div>
                }

                <button class="btn btn-primary" @onclick="ChangePasswordAsync" disabled="@_savingPassword">
                    @(_savingPassword ? "Cambiando..." : "Cambiar contraseña")
                </button>
            </div>

            <!-- Preferencias de digest -->
            <div class="profile-card">
                <h3><i class="fa fa-newspaper"></i> Digest de noticias</h3>
                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="_receiveDigest" />
                        Recibir resumen periódico de eventos
                    </label>
                </div>
                @if (_receiveDigest)
                {
                    <div class="form-group">
                        <label>Frecuencia</label>
                        <select class="form-control" @bind="_digestFrequency">
                            @foreach (var f in Enum.GetValues<ANews.Domain.Enums.DigestionFrequency>())
                            {
                                <option value="@f">@f</option>
                            }
                        </select>
                    </div>
                }
                <button class="btn btn-secondary" @onclick="SavePreferencesAsync" disabled="@_savingPrefs">
                    @(_savingPrefs ? "Guardando..." : "Guardar preferencias")
                </button>
            </div>

            <!-- Plan y consumo -->
            <div class="profile-card">
                <h3><i class="fa fa-credit-card"></i> Mi plan</h3>
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
                    <span class="plan-tier-badge plan-tier-@_user.PlanTier.ToString().ToLower()">@_user.PlanTier</span>
                    @if (_currentPlan != null)
                    {
                        <span style="color:var(--text-secondary);font-size:13px">@_currentPlan.Name</span>
                        @if (_currentPlan.MonthlyPrice > 0)
                        {
                            <span style="color:var(--accent);font-size:13px;font-weight:600">$@_currentPlan.MonthlyPrice.ToString("F2")/mes</span>
                        }
                    }
                </div>
                @if (_quotas.Any())
                {
                    <div style="font-size:12px;color:var(--text-muted);margin-bottom:8px">Consumo mensual por seccion</div>
                    @foreach (var q in _quotas)
                    {
                        var pct = q.MaxReadsPerMonth > 0 ? Math.Min(100, (int)(q.CurrentReads * 100.0 / q.MaxReadsPerMonth)) : 0;
                        var isUnlimited = q.MaxReadsPerMonth < 0;
                        var isWarning = !isUnlimited && pct >= 80;
                        var isExceeded = !isUnlimited && q.CurrentReads >= q.MaxReadsPerMonth;
                        <div style="margin-bottom:8px">
                            <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:2px">
                                <span style="font-weight:500">@(q.Section?.Name ?? "Seccion")</span>
                                <span style="color:@(isExceeded ? "var(--accent-red)" : isWarning ? "var(--accent-yellow)" : "var(--text-muted)")">
                                    @q.CurrentReads / @(isUnlimited ? "ilimitado" : q.MaxReadsPerMonth.ToString())
                                </span>
                            </div>
                            @if (!isUnlimited)
                            {
                                <div style="height:4px;background:var(--border);border-radius:2px;overflow:hidden">
                                    <div style="width:@(pct)%;height:100%;border-radius:2px;background:@(isExceeded ? "var(--accent-red)" : isWarning ? "var(--accent-yellow)" : "var(--accent)")"></div>
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <div style="color:var(--text-muted);font-size:13px"><i class="fa fa-infinity"></i> Sin limites de lectura</div>
                }
            </div>

            <!-- Perfil de lectura -->
            @if (_readerProfile != null)
            {
                <div class="profile-card">
                    <h3><i class="fa fa-brain"></i> Mi perfil de lectura</h3>
                    <div style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:12px">
                        <div style="text-align:center">
                            <div style="font-size:20px;font-weight:700;color:var(--accent)">@_readerProfile.ArticlesRead</div>
                            <div style="font-size:10px;color:var(--text-muted)">Articulos leidos</div>
                        </div>
                        <div style="text-align:center">
                            <div style="font-size:20px;font-weight:700">@_readerProfile.EventsOpened</div>
                            <div style="font-size:10px;color:var(--text-muted)">Eventos vistos</div>
                        </div>
                        @if (!string.IsNullOrEmpty(_readerProfile.PreferredDepth))
                        {
                            <div style="text-align:center">
                                <div style="font-size:16px;font-weight:600;color:var(--accent-green)">@_readerProfile.PreferredDepth</div>
                                <div style="font-size:10px;color:var(--text-muted)">Profundidad</div>
                            </div>
                        }
                    </div>
                    @if (_readerProfile.TopInterests.Any())
                    {
                        <div style="font-size:12px;color:var(--text-muted);margin-bottom:4px">Tus intereses principales</div>
                        <div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:10px">
                            @foreach (var interest in _readerProfile.TopInterests)
                            {
                                <span style="padding:2px 8px;background:rgba(74,144,226,0.1);border:1px solid rgba(74,144,226,0.2);border-radius:4px;font-size:11px;color:var(--accent)">@interest</span>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_readerProfile.SemanticProfile))
                    {
                        <div style="font-size:12px;color:var(--text-secondary);line-height:1.5;background:rgba(255,255,255,0.02);padding:10px;border-radius:var(--radius);border:1px solid var(--border)">
                            @_readerProfile.SemanticProfile
                        </div>
                    }
                    @if (_readerProfile.LastAnalyzedAt.HasValue)
                    {
                        <div style="font-size:10px;color:var(--text-muted);margin-top:8px">
                            Ultimo analisis: @_readerProfile.LastAnalyzedAt.Value.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    }
                </div>
            }

        </div>
    }
</div>

@code {
    private ApplicationUser? _user;
    private bool _loading = true;

    private string _displayName = "";
    private bool _savingProfile;

    private string _currentPassword = "";
    private string _newPassword = "";
    private string _confirmNewPassword = "";
    private string _passwordError = "";
    private bool _savingPassword;

    private bool _receiveDigest;
    private ANews.Domain.Enums.DigestionFrequency _digestFrequency;
    private bool _savingPrefs;

    private List<SectionQuota> _quotas = [];
    private ReaderProfile? _readerProfile;
    private SubscriptionPlan? _currentPlan;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var userName = auth.User.Identity?.Name;
        if (userName != null)
            _user = await UserManager.FindByNameAsync(userName);

        if (_user != null)
        {
            _displayName = _user.DisplayName;
            _receiveDigest = _user.ReceiveDigest;
            _digestFrequency = _user.DigestFrequency;

            _quotas = await Ctx.SectionQuotas.Include(q => q.Section)
                .Where(q => q.UserId == _user.Id).ToListAsync();
            _readerProfile = await Ctx.ReaderProfiles
                .FirstOrDefaultAsync(r => r.UserId == _user.Id);
            if (_user.SubscriptionPlanId.HasValue)
                _currentPlan = await Ctx.SubscriptionPlans.FindAsync(_user.SubscriptionPlanId);
        }
        _loading = false;
    }

    private async Task SaveProfileAsync()
    {
        if (_user == null) return;
        if (string.IsNullOrWhiteSpace(_displayName)) { Toast.Warning("El nombre no puede estar vacío."); return; }

        _savingProfile = true;
        try
        {
            _user.DisplayName = _displayName.Trim();
            var result = await UserManager.UpdateAsync(_user);
            if (result.Succeeded)
                Toast.Success("Perfil actualizado");
            else
                Toast.Error(result.Errors.First().Description);
        }
        finally { _savingProfile = false; }
    }

    private async Task ChangePasswordAsync()
    {
        if (_user == null) return;
        _passwordError = "";

        if (string.IsNullOrWhiteSpace(_currentPassword) || string.IsNullOrWhiteSpace(_newPassword))
        { _passwordError = "Todos los campos son obligatorios."; return; }

        if (_newPassword != _confirmNewPassword)
        { _passwordError = "Las contraseñas no coinciden."; return; }

        _savingPassword = true;
        try
        {
            var result = await UserManager.ChangePasswordAsync(_user, _currentPassword, _newPassword);
            if (result.Succeeded)
            {
                Toast.Success("Contraseña cambiada correctamente");
                _currentPassword = _newPassword = _confirmNewPassword = "";
            }
            else
            {
                _passwordError = result.Errors.First().Description;
            }
        }
        finally { _savingPassword = false; }
    }

    private async Task SavePreferencesAsync()
    {
        if (_user == null) return;
        _savingPrefs = true;
        try
        {
            _user.ReceiveDigest = _receiveDigest;
            _user.DigestFrequency = _digestFrequency;
            var result = await UserManager.UpdateAsync(_user);
            if (result.Succeeded) Toast.Success("Preferencias guardadas");
            else Toast.Error(result.Errors.First().Description);
        }
        finally { _savingPrefs = false; }
    }
}
