        ["southeast asia"]  = (10.0, 108.0), ["east asia"]       = (35.0, 115.0),
        ["sub-saharan africa"]=(0.0,  20.0), ["north africa"]    = (27.0,  17.0),
        ["latin america"]   = (-15.0,-60.0), ["south america"]   = (-15.0,-55.0),
        ["central america"] = (12.0, -85.0), ["caribbean"]       = (18.0, -66.0),
        ["balkans"]         = (43.0,  20.0), ["caucasus"]        = (42.0,  45.0),
