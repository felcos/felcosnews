    private void InitAgentTriggers()
    {
        AgentTriggers =
        [
            new("NewsScannerAgent",             "Scanner RSS",          NewsScannerAgent),
            new("EventDetectorAgent",           "Detector Eventos",     EventDetectorAgent),
            new("AlertGeneratorAgent",          "Generador Alertas",    AlertGeneratorAgent),
            new("NotificationDispatcherAgent",  "Dispatcher Notif.",    NotificationDispatcherAgent),
            new("ArticleSummarizerAgent",       "Resumidor Artículos",  ArticleSummarizerAgent),
            new("DigestSenderAgent",            "Digest Email",         DigestSenderAgent),
