@page "/admin"
@page "/admin/godmode"
@attribute [Authorize(Policy = "RequireAdmin")]
@layout AdminLayout
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory
@inject ANews.Infrastructure.AI.AiProviderFactory AiFactory
@inject IHubContext<AdminHub> AdminHubCtx
@inject AppDbContext Ctx
@inject ANews.Infrastructure.Agents.NewsScannerAgent NewsScannerAgent
@inject ANews.Infrastructure.Agents.EventDetectorAgent EventDetectorAgent
@inject ANews.Infrastructure.Agents.AlertGeneratorAgent AlertGeneratorAgent
@inject ANews.Infrastructure.Agents.NotificationDispatcherAgent NotificationDispatcherAgent
@inject ANews.Infrastructure.Agents.ArticleSummarizerAgent ArticleSummarizerAgent
@inject ANews.Infrastructure.Agents.DigestSenderAgent DigestSenderAgent
@using ANews.Infrastructure.Data
@using ANews.Web.Hubs
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.SignalR
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@implements IAsyncDisposable

<PageTitle>God Mode — AgenteNews Admin</PageTitle>

<div class="god-mode">

    <!-- Top Header -->
    <div class="gm-header">
        <div class="gm-title">
            <i class="fa fa-eye"></i>
            <span>GOD MODE</span>
            <div class="gm-live @(IsConnected ? "live" : "offline")">
                <span class="pulse-dot"></span>
                @(IsConnected ? "EN VIVO" : "DESCONECTADO")
            </div>
        </div>
        <div class="gm-header-actions">
            <span class="gm-time">@DateTime.Now.ToString("HH:mm:ss")</span>
            <button class="btn-action" @onclick="RefreshAll" title="Actualizar todo">
                <i class="fa fa-sync @(IsLoading ? "fa-spin" : "")"></i>
            </button>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="gm-kpis">
        <div class="kpi-card @(Stats.AgentsRunningCount > 0 ? "kpi-active" : "")">
            <i class="fa fa-robot kpi-icon"></i>
            <div class="kpi-value">@Stats.AgentsRunningCount</div>
            <div class="kpi-label">Agentes activos</div>
            @if (Stats.AgentsRunningCount > 0)
            {
                <div class="kpi-detail">@string.Join(", ", Stats.RunningAgentNames)</div>
            }
        </div>
        <div class="kpi-card">
            <i class="fa fa-newspaper kpi-icon"></i>
            <div class="kpi-value">@Stats.ArticlesToday</div>
            <div class="kpi-label">Artículos hoy</div>
        </div>
        <div class="kpi-card">
            <i class="fa fa-bolt kpi-icon"></i>
            <div class="kpi-value">@Stats.EventsToday</div>
            <div class="kpi-label">Eventos hoy</div>
        </div>
        <div class="kpi-card @(Stats.CostToday > 5 ? "kpi-warn" : "")">
            <i class="fa fa-dollar-sign kpi-icon"></i>
            <div class="kpi-value">$@Stats.CostToday.ToString("F4")</div>
            <div class="kpi-label">Coste hoy</div>
            <div class="kpi-detail">Mes: $@Stats.CostMonth.ToString("F2")</div>
        </div>
        <div class="kpi-card @(Stats.PendingAlerts > 0 ? "kpi-alert" : "")">
            <i class="fa fa-bell kpi-icon"></i>
            <div class="kpi-value">@Stats.PendingAlerts</div>
            <div class="kpi-label">Alertas pendientes</div>
        </div>
        <div class="kpi-card">
            <i class="fa fa-users kpi-icon"></i>
            <div class="kpi-value">@Stats.ActiveUsers</div>
            <div class="kpi-label">Usuarios activos</div>
            <div class="kpi-detail">Total: @Stats.TotalUsers</div>
        </div>
    </div>

    <!-- Main Grid -->
    <div class="gm-grid">

        <!-- Agentes en tiempo real -->
        <div class="gm-panel gm-panel-wide">
            <div class="panel-header">
                <i class="fa fa-terminal"></i>
                <span>Monitor de Agentes — Logs en Tiempo Real</span>
                <div class="panel-actions">
                    <button class="btn-sm @(AgentFilter == "all" ? "active" : "")" @onclick="@(() => AgentFilter = "all")">Todos</button>
                    <button class="btn-sm @(AgentFilter == "error" ? "active" : "")" @onclick="@(() => AgentFilter = "error")">Errores</button>
                    <button class="btn-sm" @onclick="ClearLogs">Limpiar</button>
                </div>
            </div>
            <div class="agent-log-feed" id="agent-log-feed">
                @foreach (var log in FilteredLogs.TakeLast(200))
                {
                    <div class="log-entry log-@log.Level.ToLower()">
                        <span class="log-time">@log.Time.ToString("HH:mm:ss")</span>
                        <span class="log-badge badge-@log.Level.ToLower()">@log.Level</span>
                        <span class="log-agent">[@log.AgentName]</span>
                        <span class="log-msg">@log.Message</span>
                    </div>
                }
                @if (!LiveLogs.Any())
                {
                    <div class="log-empty">
                        <i class="fa fa-satellite-dish"></i>
                        Esperando actividad de agentes...
                    </div>
                }
            </div>

            <!-- Acciones rápidas de agentes -->
            <div class="agent-actions">
                @foreach (var agent in AgentTriggers)
                {
                    <button class="btn-trigger @(agent.IsRunning ? "running" : "")"
                            @onclick="() => TriggerAgentAsync(agent.Name)"
                            disabled="@agent.IsRunning">
                        <i class="fa @(agent.IsRunning ? "fa-spinner fa-spin" : "fa-play")"></i>
                        @agent.DisplayName
                    </button>
                }
            </div>
        </div>

        <!-- Utilidades de mapa -->
        <div class="gm-panel gm-panel-wide">
            <div class="panel-header">
                <i class="fa fa-map-marked-alt"></i>
                <span>Utilidades de Mapa</span>
            </div>
            <div class="agent-actions">
                <button class="btn-trigger @(_geocoding ? "running" : "")"
                        @onclick="GeocodeEventsAsync" disabled="@_geocoding">
                    <i class="fa @(_geocoding ? "fa-spinner fa-spin" : "fa-map-marker-alt")"></i>
                    @(_geocoding ? "Geocodificando..." : "Geocodificar eventos en mapa")
                </button>
                @if (_geocodeResult != null)
                {
                    <span style="font-size:12px;color:var(--accent-green);align-self:center">
                        <i class="fa fa-check-circle"></i> @_geocodeResult
                    </span>
                }
            </div>
        </div>

        <!-- Costes por proveedor -->
        <div class="gm-panel">
            <div class="panel-header">
                <i class="fa fa-chart-pie"></i>
                <span>Costes de IA</span>
                <select class="select-sm" @onchange="ChangeCostPeriod">
                    <option value="today">Hoy</option>
                    <option value="week">7 días</option>
                    <option value="month">Mes</option>
                </select>
            </div>
            <div class="cost-total">
                <span class="cost-amount">$@TotalCostSelected.ToString("F4")</span>
                <span class="cost-period">@CostPeriodLabel</span>
            </div>
            <canvas id="costChart" height="180"></canvas>
            <div class="provider-list">
                @foreach (var p in ProviderCosts)
                {
                    <div class="provider-row">
                        <span class="provider-name">@p.Name</span>
                        <div class="provider-bar">
                            <div class="bar-fill" style="width:@(p.Percent)%; background:@p.Color"></div>
                        </div>
                        <span class="provider-cost">$@p.Cost.ToString("F4")</span>
                    </div>
                }
            </div>
        </div>

        <!-- Health del sistema -->
        <div class="gm-panel">
            <div class="panel-header">
                <i class="fa fa-heartbeat"></i>
                <span>Sistema Health</span>
            </div>
            <div class="health-list">
                @foreach (var check in SystemHealth)
                {
                    <div class="health-row">
                        <div class="health-indicator @(check.IsOk ? "ok" : "fail")"></div>
                        <span class="health-name">@check.Name</span>
                        <span class="health-value">@check.Value</span>
                    </div>
                }
            </div>
        </div>

        <!-- Alertas críticas pendientes -->
        <div class="gm-panel">
            <div class="panel-header">
                <i class="fa fa-exclamation-triangle"></i>
                <span>Alertas Pendientes (@PendingAlerts.Count)</span>
            </div>
            <div class="alert-list">
                @foreach (var alert in PendingAlerts.Take(10))
                {
                    <div class="alert-row severity-@alert.Severity.ToLower()">
                        <div class="alert-info">
                            <span class="alert-title">@alert.Title</span>
                            <span class="alert-time">@alert.CreatedAt.ToString("dd/MM HH:mm")</span>
                        </div>
                        <button class="btn-ack" @onclick="() => AcknowledgeAlertAsync(alert.Id)">
                            <i class="fa fa-check"></i>
                        </button>
                    </div>
                }
                @if (!PendingAlerts.Any())
                {
                    <div class="no-alerts"><i class="fa fa-shield-check"></i> Sin alertas pendientes</div>
                }
            </div>
        </div>

        <!-- Últimas ejecuciones -->
        <div class="gm-panel gm-panel-wide">
            <div class="panel-header">
                <i class="fa fa-history"></i>
                <span>Últimas Ejecuciones de Agentes</span>
                <a href="/admin/agents" class="panel-link">Ver todo</a>
            </div>
            <table class="gm-table">
                <thead>
                    <tr>
                        <th>Agente</th>
                        <th>Inicio</th>
                        <th>Duración</th>
                        <th>Items</th>
                        <th>Coste IA</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var exec in RecentExecutions)
                    {
                        <tr @onclick="() => ShowExecutionLogs(exec.Id)" class="clickable-row">
                            <td>@exec.AgentName</td>
                            <td>@exec.StartedAt.ToString("dd/MM HH:mm:ss")</td>
                            <td>@FormatDuration(exec.DurationMs)</td>
                            <td>@exec.ItemsProcessed / @exec.ItemsCreated</td>
                            <td>$@exec.AiCost.ToString("F4")</td>
                            <td><span class="status-badge status-@exec.Status.ToLower()">@exec.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>

<!-- Modal logs de ejecución -->
@if (ShowLogsModal)
{
    <div class="modal-overlay" @onclick="CloseLogsModal">
        <div class="modal-box modal-large" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>Logs de Ejecución #@SelectedExecutionId</h3>
                <button @onclick="CloseLogsModal"><i class="fa fa-times"></i></button>
            </div>
            <div class="modal-body log-modal-body">
                @foreach (var log in ExecutionLogs)
                {
                    <div class="log-entry log-@log.Level.ToLower()">
                        <span class="log-time">@log.Timestamp.ToString("HH:mm:ss.fff")</span>
                        <span class="log-badge badge-@log.Level.ToLower()">@log.Level</span>
                        <span class="log-msg">@log.Message</span>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private HubConnection? _adminHub;
    private HubConnection? _agentHub;
    private bool IsConnected => _adminHub?.State == HubConnectionState.Connected;
    private bool IsLoading = false;
    private string AgentFilter = "all";
    private string CostPeriod = "today";
    private string CostPeriodLabel => CostPeriod switch { "week" => "7 días", "month" => "Mes", _ => "Hoy" };
    private bool ShowLogsModal = false;
    private int SelectedExecutionId;

    private DashboardStats Stats = new();
    private List<LiveLogEntry> LiveLogs = [];
    private List<AlertItem> PendingAlerts = [];
    private List<ExecutionItem> RecentExecutions = [];
    private List<ProviderCostItem> ProviderCosts = [];
    private List<HealthItem> SystemHealth = [];
    private List<AgentTriggerItem> AgentTriggers = [];
    private List<ExecutionLogItem> ExecutionLogs = [];
    private decimal TotalCostSelected;
    private bool _geocoding;
    private string? _geocodeResult;

    private IEnumerable<LiveLogEntry> FilteredLogs => AgentFilter == "error"
        ? LiveLogs.Where(l => l.Level is "Error" or "Warning")
        : LiveLogs;

    protected override async Task OnInitializedAsync()
    {
        InitAgentTriggers();
        await LoadInitialDataAsync();
        await LoadSystemHealthAsync();
    }

    private void InitAgentTriggers()
    {
        AgentTriggers =
        [
            new("NewsScannerAgent", "Scanner RSS"),
            new("EventDetectorAgent", "Detector Eventos"),
            new("AlertGeneratorAgent", "Generador Alertas"),
            new("NotificationDispatcherAgent", "Dispatcher Notif."),
            new("ArticleSummarizerAgent", "Resumidor Artículos"),
            new("DigestSenderAgent", "Digest Email")
        ];
    }

    private async Task LoadInitialDataAsync()
    {
        var today = DateTime.UtcNow.Date;

        RecentExecutions = await Ctx.AgentExecutions
            .OrderByDescending(e => e.StartedAt)
            .Take(10)
            .Select(e => new ExecutionItem(
                e.Id, e.AgentName, e.Status.ToString(), e.StartedAt,
                e.CompletedAt.HasValue ? (int)(e.CompletedAt.Value - e.StartedAt).TotalMilliseconds : -1,
                e.ItemsProcessed, e.ItemsCreated, e.AiCost, e.Error))
            .ToListAsync();

        PendingAlerts = await Ctx.AlertTriggers
            .Include(a => a.NewsEvent)
            .Where(a => !a.IsAcknowledged)
            .OrderByDescending(a => a.Severity)
            .ThenByDescending(a => a.CreatedAt)
            .Take(20)
            .Select(a => new AlertItem(a.Id, a.Title, a.Severity.ToString(), a.CreatedAt))
            .ToListAsync();

        await LoadCostDataAsync();
    }

    private async Task LoadCostDataAsync()
    {
        var cutoff = CostPeriod switch
        {
            "week" => DateTime.UtcNow.AddDays(-7),
            "month" => new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1),
            _ => DateTime.UtcNow.Date
        };

        var byProvider = await Ctx.CostEntries
            .Where(c => c.Date >= cutoff)
            .GroupBy(c => c.Provider.Name)
            .Select(g => new { Name = g.Key, Cost = g.Sum(c => c.Cost) })
            .ToListAsync();

        TotalCostSelected = byProvider.Sum(p => p.Cost);
        var colors = new[] { "#4a90e2", "#00ff88", "#ff6600", "#ff0080", "#ffcc00" };

        ProviderCosts = byProvider.Select((p, i) => new ProviderCostItem(
            p.Name, p.Cost,
            TotalCostSelected > 0 ? (double)(p.Cost / TotalCostSelected * 100) : 0,
            colors[i % colors.Length]
        )).ToList();
    }

    private async Task LoadSystemHealthAsync()
    {
        SystemHealth = [];

        // DB connectivity
        try
        {
            await Ctx.Database.ExecuteSqlRawAsync("SELECT 1");
            SystemHealth.Add(new("PostgreSQL", true, "Conectado"));
        }
        catch { SystemHealth.Add(new("PostgreSQL", false, "Error")); }

        // Recent agent activity
        var lastAgent = await Ctx.AgentExecutions
            .OrderByDescending(e => e.StartedAt)
            .FirstOrDefaultAsync();

        if (lastAgent != null)
        {
            var ago = DateTime.UtcNow - lastAgent.StartedAt;
            SystemHealth.Add(new("Ultimo agente", ago.TotalHours < 2, $"hace {(int)ago.TotalMinutes}min"));
        }

        var failedToday = await Ctx.NewsSources
            .CountAsync(s => s.IsActive && s.FailedScans > s.SuccessfulScans);
        SystemHealth.Add(new("Fuentes con errores", failedToday == 0, failedToday == 0 ? "OK" : $"{failedToday} degradadas"));

        var activeProviders = await Ctx.AiProviderConfigs.CountAsync(p => p.IsActive);
        SystemHealth.Add(new("Proveedores IA", activeProviders > 0, $"{activeProviders} activos"));
    }

    private async Task SetupHubsAsync()
    {
        _adminHub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/adminhub"))
            .WithAutomaticReconnect()
            .Build();

        _adminHub.On<object>("DashboardStats", stats =>
        {
            InvokeAsync(StateHasChanged);
        });

        _agentHub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/agenthub"))
            .WithAutomaticReconnect()
            .Build();

        _agentHub.On<object>("AgentLog", async (logObj) =>
        {
            var json = System.Text.Json.JsonSerializer.Serialize(logObj);
            var log = System.Text.Json.JsonSerializer.Deserialize<AgentLogMessage>(json,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (log != null)
            {
                LiveLogs.Add(new(log.AgentName ?? "Agent", log.Level ?? "Info", log.Message ?? "", DateTime.Now));
                if (LiveLogs.Count > 500) LiveLogs.RemoveAt(0);
                await InvokeAsync(StateHasChanged);
                try { await JS.InvokeVoidAsync("adminScrollToBottom", "agent-log-feed"); } catch { }
            }
        });

        try { await _adminHub.StartAsync(); } catch { }
        try { await _agentHub.StartAsync(); } catch { }
    }

    // Region overrides — same as map.js, prevents Nominatim from mapping regions to wrong countries
    private static readonly Dictionary<string, (double Lat, double Lng)> _regionCoords = new(StringComparer.OrdinalIgnoreCase)
    {
        ["middle east"]      = (29.5,  42.5),
        ["near east"]        = (29.5,  42.5),
        ["eastern europe"]   = (50.0,  30.0),
        ["western europe"]   = (48.0,  10.0),
        ["central europe"]   = (48.0,  16.0),
        ["northern europe"]  = (60.0,  15.0),
        ["southern europe"]  = (42.0,  14.0),
        ["central asia"]     = (45.0,  65.0),
        ["south asia"]       = (23.0,  77.0),
        ["southeast asia"]   = (10.0, 108.0),
        ["east asia"]        = (35.0, 115.0),
        ["sub-saharan africa"] = (0.0, 20.0),
        ["north africa"]     = (27.0,  17.0),
        ["west africa"]      = (12.0,  -2.0),
        ["east africa"]      = (0.0,   37.0),
        ["latin america"]    = (-15.0, -60.0),
        ["south america"]    = (-15.0, -55.0),
        ["central america"]  = (12.0, -85.0),
        ["caribbean"]        = (18.0, -66.0),
        ["balkans"]          = (43.0,  20.0),
        ["caucasus"]         = (42.0,  45.0),
        ["horn of africa"]   = (8.0,   42.0),
        ["persian gulf"]     = (26.0,  52.0),
        ["gulf states"]      = (24.0,  51.0),
        ["red sea"]          = (20.0,  38.0),
        ["mediterranean"]    = (38.0,  18.0),
    };

    private async Task GeocodeEventsAsync()
    {
        _geocoding = true;
        _geocodeResult = null;
        StateHasChanged();
        try
        {
            // All active events — reset coords to reprocess with correct region lookup
            var events = await Ctx.NewsEvents
                .Where(e => e.IsActive && !e.IsDeleted)
                .OrderByDescending(e => e.ImpactScore)
                .Take(50)
                .ToListAsync();

            ANews.Domain.Interfaces.IAiProvider ai;
            try { ai = await AiFactory.GetDefaultProviderAsync(); }
            catch { _geocodeResult = "No hay proveedor de IA configurado"; return; }

            var nominatim = HttpClientFactory.CreateClient("nominatim");
            int enriched = 0;

            foreach (var ev in events)
            {
                // Step 1: get location from AI if missing
                if (string.IsNullOrEmpty(ev.Location))
                {
                    var aiResp = await ai.CompleteAsync(new ANews.Domain.Interfaces.AiRequest
                    {
                        SystemPrompt = "You are a geography expert. Reply ONLY with the most specific geographic location name in English (city, country, or region like 'Latin America', 'Middle East'). If truly global with no location, reply: null",
                        UserPrompt = "What is the main geographic location of this news event?\nTitle: " + ev.Title + "\nDescription: " + (ev.Description ?? ""),
                        MaxTokens = 20,
                        Temperature = 0,
                        OperationTag = "location_enrichment"
                    }, CancellationToken.None);

                    if (!aiResp.Success) continue;
                    var loc = aiResp.Content.Trim().Trim('"').Trim('.');
                    if (string.IsNullOrWhiteSpace(loc) || loc.Equals("null", StringComparison.OrdinalIgnoreCase)) continue;
                    ev.Location = loc;
                }

                // Step 2: geocode with region override first
                var locKey = ev.Location!.Trim();
                if (_regionCoords.TryGetValue(locKey, out var rc))
                {
                    ev.Latitude  = rc.Lat;
                    ev.Longitude = rc.Lng;
                }
                else
                {
                    await Task.Delay(500);
                    try
                    {
                        var geoRes = await nominatim.GetAsync($"search?q={Uri.EscapeDataString(locKey)}&format=json&limit=1&accept-language=en");
                        if (geoRes.IsSuccessStatusCode)
                        {
                            var geoJson = await geoRes.Content.ReadAsStringAsync();
                            using var doc = System.Text.Json.JsonDocument.Parse(geoJson);
                            if (doc.RootElement.GetArrayLength() > 0)
                            {
                                var first = doc.RootElement[0];
                                if (double.TryParse(first.GetProperty("lat").GetString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lat))
                                    ev.Latitude = lat;
                                if (double.TryParse(first.GetProperty("lon").GetString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lon))
                                    ev.Longitude = lon;
                            }
                        }
                    }
                    catch { }
                }

                if (ev.Latitude.HasValue)
                {
                    enriched++;
                    _geocodeResult = $"Procesando... {enriched} eventos";
                    StateHasChanged();
                }
            }

            await Ctx.SaveChangesAsync();
            _geocodeResult = $"Completado: {enriched} de {events.Count} eventos geocodificados";
        }
        catch (Exception ex) { _geocodeResult = $"Error: {ex.Message}"; }
        finally { _geocoding = false; StateHasChanged(); }
    }

    private async Task RefreshAll()
    {
        IsLoading = true;
        await LoadInitialDataAsync();
        await LoadSystemHealthAsync();
        IsLoading = false;
    }


    private async Task TriggerAgentAsync(string agentName)
    {
        var trigger = AgentTriggers.FirstOrDefault(a => a.Name == agentName);
        if (trigger != null) trigger.IsRunning = true;
        StateHasChanged();

        try
        {
            var triggered = agentName.ToLower() switch
            {
                "newsscanner" or "newsscanneragent"                         => TriggerDirect(NewsScannerAgent),
                "eventdetector" or "eventdetectoragent"                     => TriggerDirect(EventDetectorAgent),
                "alertgenerator" or "alertgeneratoragent"                   => TriggerDirect(AlertGeneratorAgent),
                "notificationdispatcher" or "notificationdispatcheragent"   => TriggerDirect(NotificationDispatcherAgent),
                "articlesummarizer" or "articlesummarizeragent"             => TriggerDirect(ArticleSummarizerAgent),
                "digestsender" or "digestsenderagent"                       => TriggerDirect(DigestSenderAgent),
                _ => false
            };
            var msg = triggered ? $"Agente {agentName} activado" : $"Tipo de agente desconocido: {agentName}";
            LiveLogs.Add(new(agentName, triggered ? "Info" : "Error", msg, DateTime.Now));
            await Task.Delay(500); // Pequeña espera para que el agente empiece
        }
        catch (Exception ex)
        {
            LiveLogs.Add(new(agentName, "Error", $"Error: {ex.Message}", DateTime.Now));
        }
        finally
        {
            if (trigger != null) trigger.IsRunning = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static bool TriggerDirect(ANews.Infrastructure.Agents.BaseAgent agent)
    {
        agent.TriggerNow();
        return true;
    }

    private async Task AcknowledgeAlertAsync(int alertId)
    {
        var alert = await Ctx.AlertTriggers.FindAsync(alertId);
        if (alert != null)
        {
            alert.IsAcknowledged = true;
            alert.AcknowledgedAt = DateTime.UtcNow;
            await Ctx.SaveChangesAsync();
            PendingAlerts.RemoveAll(a => a.Id == alertId);
            Stats = Stats with { PendingAlerts = Stats.PendingAlerts - 1 };
        }
    }

    private async Task ShowExecutionLogs(int executionId)
    {
        SelectedExecutionId = executionId;
        ExecutionLogs = await Ctx.AgentLogs
            .Where(l => l.AgentExecutionId == executionId)
            .OrderBy(l => l.Timestamp)
            .Select(l => new ExecutionLogItem(l.Level.ToString(), l.Message, l.Timestamp))
            .ToListAsync();
        ShowLogsModal = true;
    }

    private void CloseLogsModal() => ShowLogsModal = false;
    private void ClearLogs() => LiveLogs.Clear();

    private async Task ChangeCostPeriod(ChangeEventArgs e)
    {
        CostPeriod = e.Value?.ToString() ?? "today";
        await LoadCostDataAsync();
        try { await JS.InvokeVoidAsync("adminRenderCostChart", ProviderCosts); } catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await SetupHubsAsync();
        try { await JS.InvokeVoidAsync("adminRenderCostChart", ProviderCosts); } catch { }
    }

    private static string FormatDuration(int ms)
    {
        if (ms < 0) return "—";
        if (ms < 1000) return $"{ms}ms";
        if (ms < 60000) return $"{ms / 1000}s";
        return $"{ms / 60000}m {(ms % 60000) / 1000}s";
    }

    public async ValueTask DisposeAsync()
    {
        if (_adminHub != null) await _adminHub.DisposeAsync();
        if (_agentHub != null) await _agentHub.DisposeAsync();
    }

