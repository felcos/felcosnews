    private async Task SetupHubsAsync()
    {
        _adminHub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/adminhub"))
            .WithAutomaticReconnect().Build();

        _adminHub.On<object>("DashboardStats", _ => InvokeAsync(StateHasChanged));

        _agentHub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/agenthub"))
            .WithAutomaticReconnect().Build();

        _agentHub.On<object>("AgentLog", async (logObj) =>
        {
            if (_logsPaused) return;
            var json = System.Text.Json.JsonSerializer.Serialize(logObj);
            var log = System.Text.Json.JsonSerializer.Deserialize<AgentLogMessage>(json,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (log != null)
            {
                LiveLogs.Add(new(log.AgentName ?? "Agent", log.Level ?? "Info", log.Message ?? "", DateTime.Now));
                if (LiveLogs.Count > 500) LiveLogs.RemoveAt(0);
                await InvokeAsync(StateHasChanged);
                try { await JS.InvokeVoidAsync("adminScrollToBottom", "agent-log-feed"); } catch { }
            }
        });

        try { await _adminHub.StartAsync(); } catch { }
        try { await _agentHub.StartAsync(); } catch { }

        // Auto-refresh KPIs every 30s
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            if (_cts.IsCancellationRequested) return;
            try
            {
                _now = DateTime.Now;
                await LoadInitialDataAsync();
                _kpiFlash = true;
                await InvokeAsync(StateHasChanged);
                await Task.Delay(500, _cts.Token);
                _kpiFlash = false;
                await InvokeAsync(StateHasChanged);
            }
            catch (ObjectDisposedException) { }
            catch (OperationCanceledException) { }
            catch { }
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private static readonly Dictionary<string, (double Lat, double Lng)> _regionCoords = new(StringComparer.OrdinalIgnoreCase)
    {
        ["middle east"]     = (29.5,  42.5), ["eastern europe"]  = (50.0,  30.0),
        ["western europe"]  = (48.0,  10.0), ["central europe"]  = (48.0,  16.0),
        ["northern europe"] = (60.0,  15.0), ["southern europe"] = (42.0,  14.0),
