    };

    private async Task GeocodeEventsAsync()
    {
        _geocoding = true; _geocodeResult = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            var events = await Ctx.NewsEvents
                .Where(e => e.IsActive && !e.IsDeleted)
                .OrderByDescending(e => e.ImpactScore).Take(50).ToListAsync();

            ANews.Domain.Interfaces.IAiProvider ai;
            try { ai = await AiFactory.GetDefaultProviderAsync(); }
            catch { _geocodeResult = "No hay proveedor de IA configurado"; return; }

            var nominatim = HttpClientFactory.CreateClient("nominatim");
            int enriched = 0;

            foreach (var ev in events)
            {
                if (string.IsNullOrEmpty(ev.Location))
                {
                    var aiResp = await ai.CompleteAsync(new ANews.Domain.Interfaces.AiRequest
                    {
                        SystemPrompt = "You are a geography expert. Reply ONLY with the most specific geographic location name in English. If truly global, reply: null",
                        UserPrompt = "Location of this news event?\nTitle: " + ev.Title,
                        MaxTokens = 20, Temperature = 0, OperationTag = "location_enrichment"
                    }, CancellationToken.None);
                    if (!aiResp.Success) continue;
                    var loc = aiResp.Content.Trim().Trim('"').Trim('.');
                    if (string.IsNullOrWhiteSpace(loc) || loc.Equals("null", StringComparison.OrdinalIgnoreCase)) continue;
                    ev.Location = loc;
                }

                var locKey = ev.Location!.Trim();
                if (_regionCoords.TryGetValue(locKey, out var rc))
                { ev.Latitude = rc.Lat; ev.Longitude = rc.Lng; }
                else
                {
                    await Task.Delay(500);
                    try
                    {
                        var geoRes = await nominatim.GetAsync($"search?q={Uri.EscapeDataString(locKey)}&format=json&limit=1&accept-language=en");
                        if (geoRes.IsSuccessStatusCode)
                        {
                            var geoJson = await geoRes.Content.ReadAsStringAsync();
                            using var doc = System.Text.Json.JsonDocument.Parse(geoJson);
                            if (doc.RootElement.GetArrayLength() > 0)
                            {
                                var first = doc.RootElement[0];
                                if (double.TryParse(first.GetProperty("lat").GetString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lat)) ev.Latitude = lat;
                                if (double.TryParse(first.GetProperty("lon").GetString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lon)) ev.Longitude = lon;
                            }
                        }
                    }
                    catch { }
                }

                if (ev.Latitude.HasValue)
                {
                    enriched++;
                    _geocodeResult = $"Procesando... {enriched} eventos";
                    await InvokeAsync(StateHasChanged);
                }
            }

            await Ctx.SaveChangesAsync();
            _geocodeResult = $"Completado: {enriched} de {events.Count} geocodificados";
        }
        catch (Exception ex) { _geocodeResult = $"Error: {ex.Message}"; }
        finally { _geocoding = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task RefreshAll()
    {
        IsLoading = true;
        await LoadInitialDataAsync();
        await LoadSystemHealthAsync();
        await LoadZonesAsync();
        await LoadSourcesAsync();
        await LoadAiProvidersAsync();
        IsLoading = false;
    }

    // ── Agent config ─────────────────────────────────
    private async Task SaveAgentConfigsAsync()
    {
        _savingConfigs = true;
        try
        {
            foreach (var cfg in _agentConfigs)
            {
                Ctx.AgentConfigs.Update(cfg);
                // Hot-patch running agents
                var agent = cfg.AgentType switch
                {
                    "NewsScannerAgent"             => (ANews.Infrastructure.Agents.BaseAgent?)NewsScannerAgent,
                    "EventDetectorAgent"           => EventDetectorAgent,
                    "AlertGeneratorAgent"          => AlertGeneratorAgent,
                    "NotificationDispatcherAgent"  => NotificationDispatcherAgent,
                    "ArticleSummarizerAgent"       => ArticleSummarizerAgent,
                    "DigestSenderAgent"            => DigestSenderAgent,
                    "SourceDiscoveryAgent"         => SourceDiscoveryAgent,
                    _                              => null
                };
                agent?.UpdateInterval(cfg.IntervalMinutes);
                agent?.SetEnabled(cfg.IsEnabled);
            }
            await Ctx.SaveChangesAsync();
            _configSaved = true;
            _ = Task.Delay(2000).ContinueWith(_ => { _configSaved = false; InvokeAsync(StateHasChanged); });
        }
        finally { _savingConfigs = false; }
    }

    // ── Source health ─────────────────────────────────
    private async Task ToggleSourceAsync(int id, bool currentlyActive)
    {
        var src = await Ctx.NewsSources.FindAsync(id);
        if (src == null) return;
        src.IsActive = !currentlyActive;
        await Ctx.SaveChangesAsync();
        await LoadSourcesAsync();
    }

    private async Task DisableFailedSourcesAsync()
    {
        var failed = await Ctx.NewsSources
            .Where(s => s.IsActive && s.FailedScans > s.SuccessfulScans && s.SuccessfulScans < 3)
            .ToListAsync();
        foreach (var s in failed) s.IsActive = false;
        await Ctx.SaveChangesAsync();
        await LoadSourcesAsync();
    }

    // ── Zones ─────────────────────────────────────────
    private async Task LoadZonesAsync()
    {
        _zones = await Ctx.WorkspaceZones.Where(z => !z.IsDeleted)
            .OrderBy(z => z.SortOrder).ThenBy(z => z.Name).ToListAsync();
    }

    private void OpenAddZone()
    {
        _editingZone = null;
        _zoneForm = new ZoneForm { SortOrder = _zones.Count > 0 ? _zones.Max(z => z.SortOrder) + 1 : 1 };
        _zoneError = "";
        _showZoneModal = true;
    }

    private void OpenEditZone(WorkspaceZone zone)
    {
        _editingZone = zone;
        _zoneForm = new ZoneForm
        {
            Name = zone.Name, Flag = zone.Flag, Description = zone.Description,
            GeoTermsText = string.Join(", ", zone.GeoTerms), SortOrder = zone.SortOrder
        };
        _zoneError = "";
        _showZoneModal = true;
    }

    private void CloseZoneModal() => _showZoneModal = false;

    private async Task SaveZoneAsync()
    {
        _zoneError = "";
        if (string.IsNullOrWhiteSpace(_zoneForm.Name)) { _zoneError = "El nombre es obligatorio"; return; }
        _savingZone = true;
        try
        {
            var terms = _zoneForm.GeoTermsText
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(t => !string.IsNullOrEmpty(t)).ToList();

            if (_editingZone?.Id > 0)
            {
                _editingZone.Name = _zoneForm.Name; _editingZone.Flag = _zoneForm.Flag;
                _editingZone.Description = _zoneForm.Description; _editingZone.GeoTerms = terms;
                _editingZone.SortOrder = _zoneForm.SortOrder;
                Ctx.WorkspaceZones.Update(_editingZone);
            }
            else
            {
                Ctx.WorkspaceZones.Add(new WorkspaceZone
                {
                    Name = _zoneForm.Name, Flag = _zoneForm.Flag, Description = _zoneForm.Description,
                    GeoTerms = terms, SortOrder = _zoneForm.SortOrder, IsActive = true
                });
            }
            await Ctx.SaveChangesAsync();
            await LoadZonesAsync();
            _showZoneModal = false;
        }
        catch (Exception ex) { _zoneError = ex.Message; }
        finally { _savingZone = false; }
    }

    private async Task DeleteZoneAsync(WorkspaceZone zone)
    {
        zone.IsDeleted = true;
        Ctx.WorkspaceZones.Update(zone);
        await Ctx.SaveChangesAsync();
        _zones.Remove(zone);
    }

    // ── Agent triggers ───────────────────────────────
    private async Task TriggerAgentAsync(string agentName)
    {
        var trigger = AgentTriggers.FirstOrDefault(a => a.Name == agentName);
        if (trigger != null) trigger.IsRunning = true;
        StateHasChanged();
        try
        {
            trigger?.Agent?.TriggerNow();
            LiveLogs.Add(new(agentName, "Info", $"Agente {agentName} activado manualmente", DateTime.Now));
            await Task.Delay(500);
        }
        catch (Exception ex) { LiveLogs.Add(new(agentName, "Error", $"Error: {ex.Message}", DateTime.Now)); }
        finally { if (trigger != null) trigger.IsRunning = false; await InvokeAsync(StateHasChanged); }
    }

    // ── Alerts ───────────────────────────────────────
    private async Task AcknowledgeAlertAsync(int alertId)
    {
        var alert = await Ctx.AlertTriggers.FindAsync(alertId);
        if (alert != null)
        {
            alert.IsAcknowledged = true; alert.AcknowledgedAt = DateTime.UtcNow;
            await Ctx.SaveChangesAsync();
            PendingAlerts.RemoveAll(a => a.Id == alertId);
            Stats = Stats with { PendingAlerts = Stats.PendingAlerts - 1 };
        }
    }

    private async Task ShowExecutionLogs(int executionId)
    {
        SelectedExecutionId = executionId;
        ExecutionLogs = await Ctx.AgentLogs
            .Where(l => l.AgentExecutionId == executionId).OrderBy(l => l.Timestamp)
            .Select(l => new ExecutionLogItem(l.Level.ToString(), l.Message, l.Timestamp))
            .ToListAsync();
        ShowLogsModal = true;
    }

    private void CloseLogsModal() => ShowLogsModal = false;
    private void ClearLogs() => LiveLogs.Clear();
    private void ToggleLogPause() => _logsPaused = !_logsPaused;

    private async Task ExportLogsAsync()
    {
        var text = string.Join("\n", FilteredLogs.Select(l => $"[{l.Time:HH:mm:ss}] [{l.Level}] [{l.AgentName}] {l.Message}"));
        try { await JS.InvokeVoidAsync("downloadTextFile", $"godmode-logs-{DateTime.Now:yyyyMMdd-HHmm}.txt", text); } catch { }
    }

    private async Task ChangeCostPeriod(ChangeEventArgs e)
    {
        CostPeriod = e.Value?.ToString() ?? "today";
        await LoadCostDataAsync();
        try { await JS.InvokeVoidAsync("adminRenderCostChart", ProviderCosts); } catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await SetupHubsAsync();
        try { await JS.InvokeVoidAsync("adminRenderCostChart", ProviderCosts); } catch { }
    }

    private static string FormatDuration(int ms)
    {
        if (ms < 0) return "—";
        if (ms < 1000) return $"{ms}ms";
        if (ms < 60000) return $"{ms / 1000}s";
        return $"{ms / 60000}m {(ms % 60000) / 1000}s";
    }

    private static string FormatInterval(int minutes)
    {
        if (minutes < 60) return $"{minutes}m";
        if (minutes < 1440) return $"{minutes / 60}h {minutes % 60}m";
        return $"{minutes / 1440}d";
    }

    public async ValueTask DisposeAsync()
    {
        _cts.Cancel();
        _refreshTimer?.Dispose();
        if (_adminHub != null) try { await _adminHub.DisposeAsync(); } catch { }
        if (_agentHub != null) try { await _agentHub.DisposeAsync(); } catch { }
        _cts.Dispose();
    }

