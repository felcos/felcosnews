    private async Task LoadInitialDataAsync()
    {
        var today = DateTime.UtcNow.Date;
        var monthStart = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1, 0, 0, 0, DateTimeKind.Utc);

        var articlesToday = await Ctx.NewsArticles.CountAsync(a => a.CreatedAt >= today);
        var eventsToday   = await Ctx.NewsEvents.CountAsync(e => e.IsActive && e.CreatedAt >= today);
        var totalUsers    = await Ctx.Users.CountAsync();
        var activeUsers   = await Ctx.Users.CountAsync(u => u.LastLoginAt >= DateTime.UtcNow.AddDays(-30));
        var pendingAlerts = await Ctx.AlertTriggers.CountAsync(a => !a.IsAcknowledged);
        var costToday     = await Ctx.CostEntries.Where(c => c.Date >= today).SumAsync(c => (decimal?)c.Cost) ?? 0;
        var costMonth     = await Ctx.CostEntries.Where(c => c.Date >= monthStart).SumAsync(c => (decimal?)c.Cost) ?? 0;

        var runningAgents = await Ctx.AgentExecutions
            .Where(e => e.StartedAt >= DateTime.UtcNow.AddMinutes(-10) && e.CompletedAt == null)
            .Select(e => e.AgentName).ToListAsync();

        Stats = new DashboardStats
        {
            ArticlesToday      = articlesToday,
            EventsToday        = eventsToday,
            TotalUsers         = totalUsers,
            ActiveUsers        = activeUsers,
            PendingAlerts      = pendingAlerts,
            CostToday          = costToday,
            CostMonth          = costMonth,
            AgentsRunningCount = runningAgents.Count,
            RunningAgentNames  = runningAgents
        };

        RecentExecutions = await Ctx.AgentExecutions
            .OrderByDescending(e => e.StartedAt).Take(10)
            .Select(e => new ExecutionItem(
                e.Id, e.AgentName, e.Status.ToString(), e.StartedAt,
                e.CompletedAt.HasValue ? (int)(e.CompletedAt.Value - e.StartedAt).TotalMilliseconds : -1,
                e.ItemsProcessed, e.ItemsCreated, e.AiCost, e.Error))
            .ToListAsync();

        PendingAlerts = await Ctx.AlertTriggers
            .Include(a => a.NewsEvent)
            .Where(a => !a.IsAcknowledged)
            .OrderByDescending(a => a.Severity).ThenByDescending(a => a.CreatedAt).Take(20)
            .Select(a => new AlertItem(a.Id, a.Title, a.Severity.ToString(), a.CreatedAt))
            .ToListAsync();

        await LoadCostDataAsync();
        UpdateNextRunCountdowns();
    }

    private void UpdateNextRunCountdowns()
    {
        // Match last execution per agent name and compute next run
        foreach (var trigger in AgentTriggers)
        {
            var cfg = _agentConfigs.FirstOrDefault(c => c.AgentType == trigger.Name);
            var lastRun = RecentExecutions.FirstOrDefault(e => e.AgentName == trigger.Name);
            if (cfg == null || lastRun == null) { trigger.NextRunIn = 0; continue; }
            var elapsed = (DateTime.UtcNow - lastRun.StartedAt).TotalMinutes;
            var remaining = (int)Math.Max(0, cfg.IntervalMinutes - elapsed);
            trigger.NextRunIn = remaining;
        }
    }

    private async Task LoadCostDataAsync()
    {
        var cutoff = CostPeriod switch
        {
            "week"  => DateTime.UtcNow.AddDays(-7),
            "month" => new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1),
            _       => DateTime.UtcNow.Date
        };

        var byProvider = await Ctx.CostEntries
            .Include(c => c.Provider)
            .Where(c => c.Date >= cutoff)
            .GroupBy(c => c.Provider.Name)
            .Select(g => new { Name = g.Key, Cost = g.Sum(c => c.Cost) })
            .ToListAsync();

        TotalCostSelected = byProvider.Sum(p => p.Cost);
        var colors = new[] { "#4a90e2", "#00ff88", "#ff6600", "#ff0080", "#ffcc00" };
        ProviderCosts = byProvider.Select((p, i) => new ProviderCostItem(
            p.Name, p.Cost,
            TotalCostSelected > 0 ? (double)(p.Cost / TotalCostSelected * 100) : 0,
            colors[i % colors.Length]
        )).ToList();
    }

    private async Task LoadSystemHealthAsync()
    {
        SystemHealth = [];

        // Process metrics
        try
        {
            var proc = System.Diagnostics.Process.GetCurrentProcess();
            _memMb = (proc.WorkingSet64 / 1024 / 1024).ToString();
            _threads = proc.Threads.Count;
            var uptimeMin = (int)(DateTime.UtcNow - proc.StartTime.ToUniversalTime()).TotalMinutes;
            _uptime = uptimeMin < 60 ? $"{uptimeMin}m" : $"{uptimeMin/60}h{uptimeMin%60:00}";
        }
        catch { _memMb = "—"; _uptime = "—"; }

        try { await Ctx.Database.ExecuteSqlRawAsync("SELECT 1"); SystemHealth.Add(new("PostgreSQL", true, "Conectado")); }
        catch { SystemHealth.Add(new("PostgreSQL", false, "Error")); }

        var lastAgent = await Ctx.AgentExecutions.OrderByDescending(e => e.StartedAt).FirstOrDefaultAsync();
        if (lastAgent != null)
        {
            var ago = DateTime.UtcNow - lastAgent.StartedAt;
            SystemHealth.Add(new("Último agente", ago.TotalHours < 2, $"hace {(int)ago.TotalMinutes}min"));
        }

        var failedSrcs = await Ctx.NewsSources.CountAsync(s => s.IsActive && s.FailedScans > s.SuccessfulScans);
        SystemHealth.Add(new("Fuentes degradadas", failedSrcs == 0, failedSrcs == 0 ? "OK" : $"{failedSrcs}"));

        var activeProviders = await Ctx.AiProviderConfigs.CountAsync(p => p.IsActive);
        SystemHealth.Add(new("Proveedores IA", activeProviders > 0, $"{activeProviders} activos"));
    }

    private async Task LoadAgentConfigsAsync()
    {
        _agentConfigs = await Ctx.AgentConfigs.OrderBy(c => c.AgentType).ToListAsync();
    }

    private async Task LoadSourcesAsync()
    {
        var srcs = await Ctx.NewsSources
            .Include(s => s.Section)
            .Where(s => !s.IsDeleted)
            .OrderByDescending(s => s.FailedScans)
            .Take(100)
            .ToListAsync();

        _sources = srcs.Select(s =>
        {
            var total = s.SuccessfulScans + s.FailedScans;
            var pct = total > 0 ? (int)(s.SuccessfulScans * 100.0 / total) : 100;
            var status = total == 0 ? "ok" : pct >= 70 ? "ok" : pct >= 40 ? "warn" : "fail";
            return new SourceHealthItem(s.Id, s.Name, s.Section?.Name ?? "—", s.SuccessfulScans, s.FailedScans, pct, status, s.LastScannedAt, s.IsActive);
        }).ToList();
    }

    private async Task LoadAiProvidersAsync()
