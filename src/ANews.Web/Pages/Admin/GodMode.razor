@page "/admin/godmode"
@attribute [Authorize(Policy = "RequireAdmin")]
@layout AdminLayout
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory
@inject ANews.Infrastructure.AI.AiProviderFactory AiFactory
@inject IHubContext<AdminHub> AdminHubCtx
@inject AppDbContext Ctx
@inject ANews.Infrastructure.Agents.NewsScannerAgent NewsScannerAgent
@inject ANews.Infrastructure.Agents.EventDetectorAgent EventDetectorAgent
@inject ANews.Infrastructure.Agents.AlertGeneratorAgent AlertGeneratorAgent
@inject ANews.Infrastructure.Agents.NotificationDispatcherAgent NotificationDispatcherAgent
@inject ANews.Infrastructure.Agents.ArticleSummarizerAgent ArticleSummarizerAgent
@inject ANews.Infrastructure.Agents.DigestSenderAgent DigestSenderAgent
@inject ANews.Infrastructure.Agents.SourceDiscoveryAgent SourceDiscoveryAgent
@using ANews.Infrastructure.Data
@using ANews.Web.Hubs
@using ANews.Domain.Entities
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.SignalR
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@implements IAsyncDisposable

<PageTitle>God Mode — AgenteNews Admin</PageTitle>

<div class="god-mode">

    <!-- Top Header -->
    <div class="gm-header">
        <div class="gm-title">
            <i class="fa fa-eye"></i>
            <span>GOD MODE</span>
            <div class="gm-live @(IsConnected ? "live" : "offline")">
                <span class="pulse-dot"></span>
                @(IsConnected ? "EN VIVO" : "DESCONECTADO")
            </div>
        </div>
        <div class="gm-header-actions">
            <span class="gm-time">@_now.ToString("HH:mm:ss")</span>
            <button class="btn-action" @onclick="RefreshAll" title="Actualizar todo">
                <i class="fa fa-sync @(IsLoading ? "fa-spin" : "")"></i>
            </button>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="gm-kpis">
        <div class="kpi-card @(Stats.AgentsRunningCount > 0 ? "kpi-active" : "") @(_kpiFlash ? "kpi-refreshing" : "")">
            <i class="fa fa-robot kpi-icon"></i>
            <div class="kpi-value">@Stats.AgentsRunningCount</div>
            <div class="kpi-label">Agentes activos</div>
            @if (Stats.AgentsRunningCount > 0)
            { <div class="kpi-detail">@string.Join(", ", Stats.RunningAgentNames)</div> }
        </div>
        <div class="kpi-card @(_kpiFlash ? "kpi-refreshing" : "")">
            <i class="fa fa-newspaper kpi-icon"></i>
            <div class="kpi-value">@Stats.ArticlesToday</div>
            <div class="kpi-label">Artículos hoy</div>
        </div>
        <div class="kpi-card @(_kpiFlash ? "kpi-refreshing" : "")">
            <i class="fa fa-bolt kpi-icon"></i>
            <div class="kpi-value">@Stats.EventsToday</div>
            <div class="kpi-label">Eventos hoy</div>
        </div>
        <div class="kpi-card @(Stats.CostToday > 5 ? "kpi-warn" : "") @(_kpiFlash ? "kpi-refreshing" : "")">
            <i class="fa fa-dollar-sign kpi-icon"></i>
            <div class="kpi-value">$@Stats.CostToday.ToString("F4")</div>
            <div class="kpi-label">Coste hoy</div>
            <div class="kpi-detail">Mes: $@Stats.CostMonth.ToString("F2")</div>
        </div>
        <div class="kpi-card @(Stats.PendingAlerts > 0 ? "kpi-alert" : "") @(_kpiFlash ? "kpi-refreshing" : "")">
            <i class="fa fa-bell kpi-icon"></i>
            <div class="kpi-value">@Stats.PendingAlerts</div>
            <div class="kpi-label">Alertas pendientes</div>
        </div>
        <div class="kpi-card @(_kpiFlash ? "kpi-refreshing" : "")">
            <i class="fa fa-users kpi-icon"></i>
            <div class="kpi-value">@Stats.ActiveUsers</div>
            <div class="kpi-label">Usuarios activos</div>
            <div class="kpi-detail">Total: @Stats.TotalUsers</div>
        </div>
    </div>

    <!-- Body: Sidebar + Content -->
    <div class="gm-body">

        <!-- Sidebar nav -->
        <nav class="gm-sidebar">
            <button class="gm-nav-btn @(_section == "dashboard" ? "active" : "")" @onclick='@(()=>_section="dashboard")'>
                <i class="fa fa-th-large"></i><span>Panel</span>
            </button>
            <button class="gm-nav-btn @(_section == "agentes" ? "active" : "")" @onclick='@(()=>_section="agentes")'>
                <i class="fa fa-robot"></i><span>Agentes</span>
            </button>
            <button class="gm-nav-btn @(_section == "fuentes" ? "active" : "")" @onclick='@(()=>_section="fuentes")'>
                <i class="fa fa-rss"></i><span>Fuentes</span>
            </button>
            <div class="gm-nav-sep"></div>
            <button class="gm-nav-btn @(_section == "sistema" ? "active" : "")" @onclick='@(()=>_section="sistema")'>
                <i class="fa fa-cog"></i><span>Sistema</span>
            </button>
        </nav>

        <!-- Main content area -->
        <div class="gm-content">

            <!-- ═══════ DASHBOARD section ═══════ -->
            @if (_section == "dashboard")
            {
                <div class="gm-grid">

                    <!-- Costes IA -->
                    <div class="gm-panel">
                        <div class="panel-header">
                            <i class="fa fa-chart-pie"></i>
                            <span>Costes de IA</span>
                            <select class="select-sm" @onchange="ChangeCostPeriod">
                                <option value="today">Hoy</option>
                                <option value="week">7 días</option>
                                <option value="month">Mes</option>
                            </select>
                        </div>
                        <div class="cost-total">
                            <span class="cost-amount">$@TotalCostSelected.ToString("F4")</span>
                            <span class="cost-period">@CostPeriodLabel</span>
                        </div>
                        <canvas id="costChart" height="90"></canvas>
                        <div class="provider-list">
                            @foreach (var p in ProviderCosts)
                            {
                                <div class="provider-row">
                                    <span class="provider-name">@p.Name</span>
                                    <div class="provider-bar"><div class="bar-fill" style="width:@(p.Percent)%;background:@p.Color"></div></div>
                                    <span class="provider-cost">$@p.Cost.ToString("F4")</span>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Health del sistema con métricas -->
                    <div class="gm-panel">
                        <div class="panel-header">
                            <i class="fa fa-heartbeat"></i>
                            <span>Sistema Health</span>
                        </div>
                        <div class="metrics-row">
                            <div class="metric-box">
                                <div class="metric-val" style="color:var(--accent)">@_memMb</div>
                                <div class="metric-label">MB RAM</div>
                            </div>
                            <div class="metric-box">
                                <div class="metric-val" style="color:var(--accent-green)">@_uptime</div>
                                <div class="metric-label">Uptime</div>
                            </div>
                            <div class="metric-box">
                                <div class="metric-val">@_threads</div>
                                <div class="metric-label">Hilos</div>
                            </div>
                            <div class="metric-box">
                                <div class="metric-val" style="color:var(--accent-yellow)">@Stats.ArticlesToday</div>
                                <div class="metric-label">Art/hoy</div>
                            </div>
                        </div>
                        <div class="health-list">
                            @foreach (var check in SystemHealth)
                            {
                                <div class="health-row">
                                    <div class="health-indicator @(check.IsOk ? "ok" : "fail")"></div>
                                    <span class="health-name">@check.Name</span>
                                    <span class="health-value">@check.Value</span>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Alertas pendientes -->
                    <div class="gm-panel">
                        <div class="panel-header">
                            <i class="fa fa-exclamation-triangle"></i>
                            <span>Alertas Pendientes (@PendingAlerts.Count)</span>
                        </div>
                        <div class="alert-list">
                            @foreach (var alert in PendingAlerts.Take(10))
                            {
                                <div class="alert-row severity-@alert.Severity.ToLower()">
                                    <div class="alert-info">
                                        <span class="alert-title">@alert.Title</span>
                                        <span class="alert-time">@alert.CreatedAt.ToString("dd/MM HH:mm")</span>
                                    </div>
                                    <button class="btn-ack" @onclick="() => AcknowledgeAlertAsync(alert.Id)">
                                        <i class="fa fa-check"></i>
                                    </button>
                                </div>
                            }
                            @if (!PendingAlerts.Any())
                            { <div class="no-alerts"><i class="fa fa-shield-alt"></i> Sin alertas pendientes</div> }
                        </div>
                    </div>

                    <!-- Acciones rápidas -->
                    <div class="gm-panel">
                        <div class="panel-header">
                            <i class="fa fa-bolt"></i>
                            <span>Acciones Rápidas</span>
                        </div>
                        <div class="agent-actions" style="flex-wrap:wrap">
                            <button class="btn-trigger @(_geocoding ? "running" : "")"
                                    @onclick="GeocodeEventsAsync" disabled="@_geocoding">
                                <i class="fa @(_geocoding ? "fa-spinner fa-spin" : "fa-map-marker-alt")"></i>
                                @(_geocoding ? "Geocodificando..." : "Geocodificar eventos")
                            </button>
                            <button class="btn-trigger" @onclick='() => TriggerAgentAsync("EventDetectorAgent")'>
                                <i class="fa fa-brain"></i> Reclasificar artículos
                            </button>
                            <button class="btn-trigger" @onclick='() => TriggerAgentAsync("NewsScannerAgent")'>
                                <i class="fa fa-rss"></i> Escanear fuentes
                            </button>
                            @if (_geocodeResult != null)
                            {
                                <span style="font-size:12px;color:var(--accent-green);align-self:center">
                                    <i class="fa fa-check-circle"></i> @_geocodeResult
                                </span>
                            }
                        </div>
                    </div>

                    <!-- Últimas ejecuciones -->
                    <div class="gm-panel gm-panel-wide">
                        <div class="panel-header">
                            <i class="fa fa-history"></i>
                            <span>Últimas Ejecuciones</span>
                            <a href="/admin/agents" class="panel-link" @onclick:preventDefault @onclick='() => Nav.NavigateTo("/admin/agents", true)'>Ver todo</a>
                        </div>
                        <table class="gm-table">
                            <thead><tr>
                                <th>Agente</th><th>Inicio</th><th>Duración</th>
                                <th>Items</th><th>Coste IA</th><th>Estado</th>
                            </tr></thead>
                            <tbody>
                                @foreach (var exec in RecentExecutions)
                                {
                                    <tr @onclick="() => ShowExecutionLogs(exec.Id)" class="clickable-row">
                                        <td>@exec.AgentName</td>
                                        <td>@exec.StartedAt.ToString("dd/MM HH:mm:ss")</td>
                                        <td>@FormatDuration(exec.DurationMs)</td>
                                        <td>@exec.ItemsProcessed / @exec.ItemsCreated</td>
                                        <td>$@exec.AiCost.ToString("F4")</td>
                                        <td><span class="status-badge status-@exec.Status.ToLower()">@exec.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                </div>
            }

            <!-- ═══════ AGENTES section ═══════ -->
            @if (_section == "agentes")
            {
                <div class="gm-grid">

                    <!-- Monitor logs -->
                    <div class="gm-panel gm-panel-wide">
                        <div class="panel-header">
                            <i class="fa fa-terminal"></i>
                            <span>Monitor en Tiempo Real</span>
                            <div class="panel-actions">
                                <div class="log-search">
                                    <input @bind="_logSearch" @bind:event="oninput"
                                           placeholder="Filtrar logs..." />
                                </div>
                                <button class="btn-sm @(AgentFilter == "all" ? "active" : "")" @onclick='@(()=>AgentFilter="all")'>Todos</button>
                                <button class="btn-sm @(AgentFilter == "error" ? "active" : "")" @onclick='@(()=>AgentFilter="error")'>Errores</button>
                                <button class="btn-pause @(_logsPaused ? "paused" : "")" @onclick="ToggleLogPause">
                                    <i class="fa @(_logsPaused ? "fa-play" : "fa-pause")"></i>
                                    @(_logsPaused ? "Reanudar" : "Pausar")
                                </button>
                                <button class="btn-export" @onclick="ExportLogsAsync" title="Exportar logs">
                                    <i class="fa fa-download"></i>
                                </button>
                                <button class="btn-sm" @onclick="ClearLogs">Limpiar</button>
                            </div>
                        </div>
                        <div class="agent-log-feed" id="agent-log-feed">
                            @foreach (var log in FilteredLogs.TakeLast(200))
                            {
                                <div class="log-entry log-@log.Level.ToLower()">
                                    <span class="log-time">@log.Time.ToString("HH:mm:ss")</span>
                                    <span class="log-badge badge-@log.Level.ToLower()">@log.Level</span>
                                    <span class="log-agent">[@log.AgentName]</span>
                                    <span class="log-msg">@log.Message</span>
                                </div>
                            }
                            @if (!FilteredLogs.Any())
                            {
                                <div class="log-empty">
                                    <i class="fa fa-satellite-dish"></i>
                                    @(_logsPaused ? "Logs pausados" : "Esperando actividad de agentes...")
                                </div>
                            }
                        </div>
                        <div class="agent-actions">
                            @foreach (var agent in AgentTriggers)
                            {
                                <button class="btn-trigger @(agent.IsRunning ? "running" : "")"
                                        @onclick="() => TriggerAgentAsync(agent.Name)"
                                        disabled="@agent.IsRunning">
                                    <i class="fa @(agent.IsRunning ? "fa-spinner fa-spin" : "fa-play")"></i>
                                    @agent.DisplayName
                                    @if (!agent.IsRunning && agent.NextRunIn > 0)
                                    {
                                        <span class="next-run-badge">en @agent.NextRunIn&#x2009;m</span>
                                    }
                                </button>
                            }
                        </div>
                    </div>

                    <!-- Configuración de intervalos -->
                    <div class="gm-panel gm-panel-wide">
                        <div class="panel-header">
                            <i class="fa fa-sliders-h"></i>
                            <span>Configuración de Agentes</span>
                            <div class="panel-actions">
                                <button class="btn-sm" @onclick="SaveAgentConfigsAsync" disabled="@_savingConfigs">
                                    @if (_savingConfigs) { <i class="fa fa-spinner fa-spin"></i> }
                                    Guardar cambios
                                </button>
                                @if (_configSaved)
                                { <span style="color:var(--accent-green);font-size:12px"><i class="fa fa-check"></i> Guardado</span> }
                            </div>
                        </div>
                        <div style="display:grid;grid-template-columns:44px 1fr 130px 130px;gap:0;padding:6px 16px;border-bottom:1px solid var(--admin-border)">
                            <span></span>
                            <span style="font-size:10px;text-transform:uppercase;color:var(--text-muted)">Agente</span>
                            <span style="font-size:10px;text-transform:uppercase;color:var(--text-muted)">Intervalo</span>
                            <span style="font-size:10px;text-transform:uppercase;color:var(--text-muted)">Máx. Items / ciclo</span>
                        </div>
                        <div class="agent-config-grid">
                            @foreach (var cfg in _agentConfigs)
                            {
                                <div class="agent-cfg-row @(!cfg.IsEnabled ? "disabled-agent" : "")">
                                    <label class="toggle-sw" title="@(cfg.IsEnabled ? "Habilitado" : "Deshabilitado")">
                                        <input type="checkbox" @bind="cfg.IsEnabled" />
                                        <span class="toggle-track"><span class="toggle-thumb"></span></span>
                                    </label>
                                    <span class="agent-cfg-name">@cfg.AgentType</span>
                                    <div class="agent-cfg-interval">
                                        <input type="number" @bind="cfg.IntervalMinutes" min="1" max="10080" />
                                        <span class="cfg-unit">min <span style="color:var(--text-muted)">(@FormatInterval(cfg.IntervalMinutes))</span></span>
                                    </div>
                                    <div class="agent-cfg-maxtokens">
                                        <input type="number" @bind="cfg.MaxItemsPerCycle" placeholder="—" min="1" max="10000" />
                                        <span class="cfg-unit">items</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                </div>
            }

            <!-- ═══════ FUENTES section ═══════ -->
            @if (_section == "fuentes")
            {
                <div class="gm-grid">

                    <!-- Zonas de workspace -->
                    <div class="gm-panel gm-panel-wide">
                        <div class="panel-header">
                            <i class="fa fa-globe-europe"></i>
                            <span>Zonas de Workspace</span>
                            <small style="color:var(--text-muted);font-size:11px">Configuran el selector y la semilla de fuentes</small>
                            <button class="btn-sm" style="margin-left:auto" @onclick="OpenAddZone">
                                <i class="fa fa-plus"></i> Nueva zona
                            </button>
                        </div>
                        <div style="display:flex;flex-wrap:wrap;gap:8px;padding:12px 16px">
                            @foreach (var zone in _zones)
                            {
                                <div style="display:flex;align-items:center;gap:6px;padding:6px 12px;border-radius:8px;border:1px solid var(--border);background:var(--card-bg);font-size:13px">
                                    <span style="font-size:16px">@zone.Flag</span>
                                    <span style="font-weight:600">@zone.Name</span>
                                    <span style="color:var(--text-muted);font-size:11px">(@zone.GeoTerms.Count términos)</span>
                                    <button class="btn-icon" @onclick="@(() => OpenEditZone(zone))"><i class="fa fa-edit"></i></button>
                                    <button class="btn-icon text-danger" @onclick="@(() => DeleteZoneAsync(zone))"><i class="fa fa-trash"></i></button>
                                </div>
                            }
                            @if (!_zones.Any())
                            { <span style="color:var(--text-muted);font-size:13px">Sin zonas configuradas</span> }
                        </div>
                    </div>

                    <!-- Source health table -->
                    <div class="gm-panel gm-panel-wide">
                        <div class="panel-header">
                            <i class="fa fa-heartbeat"></i>
                            <span>Salud de Fuentes</span>
                            <span style="font-size:11px;color:var(--text-muted)">
                                @_sources.Count(s => s.HealthStatus == "ok") OK ·
                                <span style="color:var(--accent-yellow)">@_sources.Count(s => s.HealthStatus == "warn") degradadas</span> ·
                                <span style="color:var(--accent-red)">@_sources.Count(s => s.HealthStatus == "fail") caídas</span>
                            </span>
                            <button class="btn-sm" style="margin-left:auto" @onclick="DisableFailedSourcesAsync">
                                Deshabilitar caídas
                            </button>
                        </div>
                        <div style="overflow-x:auto">
                            <table class="source-health-table">
                                <thead><tr>
                                    <th></th><th>Fuente</th><th>Sección</th>
                                    <th>OK / Fail</th><th>Fiabilidad</th><th>Último scan</th><th>Acciones</th>
                                </tr></thead>
                                <tbody>
                                    @foreach (var src in _sources.OrderBy(s => s.HealthStatus == "ok" ? 2 : s.HealthStatus == "warn" ? 1 : 0))
                                    {
                                        <tr>
                                            <td><span class="src-status-dot src-@src.HealthStatus"></span></td>
                                            <td style="font-weight:500;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@src.Name</td>
                                            <td style="color:var(--text-muted)">@src.SectionName</td>
                                            <td>
                                                <span style="color:var(--accent-green)">@src.SuccessfulScans</span>
                                                /
                                                <span style="color:var(--accent-red)">@src.FailedScans</span>
                                            </td>
                                            <td>
                                                <span class="health-bar">
                                                    <span class="health-bar-fill"
                                                          style="width:@(src.ReliabilityPct)%;background:@(src.HealthStatus == "ok" ? "var(--accent-green)" : src.HealthStatus == "warn" ? "var(--accent-yellow)" : "var(--accent-red)")"></span>
                                                </span>
                                                <span style="font-size:11px;margin-left:4px">@src.ReliabilityPct%</span>
                                            </td>
                                            <td style="color:var(--text-muted);font-size:11px">
                                                @(src.LastScannedAt.HasValue ? src.LastScannedAt.Value.ToString("dd/MM HH:mm") : "—")
                                            </td>
                                            <td>
                                                <button class="btn-sm" @onclick="@(() => ToggleSourceAsync(src.Id, src.IsActive))"
                                                        style="font-size:11px">
                                                    @(src.IsActive ? "Deshab." : "Habilitar")
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Geocodificación -->
                    <div class="gm-panel gm-panel-wide">
                        <div class="panel-header">
                            <i class="fa fa-map-marked-alt"></i>
                            <span>Geocodificación de Eventos</span>
                        </div>
                        <div class="agent-actions">
                            <button class="btn-trigger @(_geocoding ? "running" : "")"
                                    @onclick="GeocodeEventsAsync" disabled="@_geocoding">
                                <i class="fa @(_geocoding ? "fa-spinner fa-spin" : "fa-map-marker-alt")"></i>
                                @(_geocoding ? "Geocodificando..." : "Geocodificar eventos en mapa")
                            </button>
                            @if (_geocodeResult != null)
                            {
                                <span style="font-size:12px;color:var(--accent-green);align-self:center">
                                    <i class="fa fa-check-circle"></i> @_geocodeResult
                                </span>
                            }
                        </div>
                    </div>

                </div>
            }

            <!-- ═══════ SISTEMA section ═══════ -->
            @if (_section == "sistema")
            {
                <div class="gm-grid">

                    <!-- Proveedores IA -->
                    <div class="gm-panel gm-panel-wide">
                        <div class="panel-header">
                            <i class="fa fa-brain"></i>
                            <span>Proveedores de IA</span>
                            <a href="/admin/ai" class="panel-link" @onclick:preventDefault @onclick='() => Nav.NavigateTo("/admin/ai", true)'>Gestionar completo</a>
                        </div>
                        <table class="gm-table">
                            <thead><tr>
                                <th>Proveedor</th><th>Modelo</th><th>Coste hoy</th>
                                <th>Coste mes</th><th>Max tokens</th><th>Estado</th>
                            </tr></thead>
                            <tbody>
                                @foreach (var p in _aiProviders)
                                {
                                    <tr>
                                        <td>
                                            @p.Name
                                            @if (p.IsDefault) { <span class="badge-default" style="margin-left:6px">default</span> }
                                        </td>
                                        <td style="font-family:monospace;font-size:11px;color:var(--text-muted)">@p.Model</td>
                                        <td style="font-variant-numeric:tabular-nums">$@p.TotalCostToday.ToString("F4")</td>
                                        <td style="font-variant-numeric:tabular-nums">$@p.TotalCostMonth.ToString("F4")</td>
                                        <td>@p.MaxTokens</td>
                                        <td>
                                            <span style="color:@(p.IsActive ? "var(--accent-green)" : "var(--text-muted)")">
                                                @(p.IsActive ? "Activo" : "Inactivo")
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Audit log -->
                    <div class="gm-panel gm-panel-wide">
                        <div class="panel-header">
                            <i class="fa fa-clipboard-list"></i>
                            <span>Audit Log</span>
                            <span style="font-size:11px;color:var(--text-muted)">Últimas 100 acciones de admin</span>
                        </div>
                        <div class="audit-list">
                            @foreach (var entry in _auditLogs)
                            {
                                <div class="audit-row">
                                    <span class="audit-time">@entry.CreatedAt.ToString("dd/MM HH:mm")</span>
                                    <span class="audit-user">@entry.UserName</span>
                                    <span class="audit-action">@entry.Action</span>
                                    <span class="audit-entity">@entry.EntityName</span>
                                </div>
                            }
                            @if (!_auditLogs.Any())
                            { <div style="padding:20px;text-align:center;color:var(--text-muted)">Sin entradas de auditoría</div> }
                        </div>
                    </div>

                </div>
            }

        </div><!-- /gm-content -->
    </div><!-- /gm-body -->
</div>

<!-- Zone modal -->
@if (_showZoneModal)
{
    <div class="modal-overlay" @onclick="CloseZoneModal">
        <div class="modal-box" style="max-width:540px" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>@(_editingZone?.Id > 0 ? "Editar" : "Nueva") Zona de Workspace</h3>
                <button @onclick="CloseZoneModal"><i class="fa fa-times"></i></button>
            </div>
            <div class="modal-body" style="display:flex;flex-direction:column;gap:14px">
                <div style="display:grid;grid-template-columns:80px 1fr;gap:10px">
                    <div>
                        <label style="font-size:12px;color:var(--text-muted)">Emoji</label>
                        <input class="form-control" @bind="_zoneForm.Flag" style="font-size:20px;text-align:center" maxlength="8"/>
                    </div>
                    <div>
                        <label style="font-size:12px;color:var(--text-muted)">Nombre *</label>
                        <input class="form-control" @bind="_zoneForm.Name" placeholder="España, Brasil…" />
                    </div>
                </div>
                <div>
                    <label style="font-size:12px;color:var(--text-muted)">Descripción</label>
                    <input class="form-control" @bind="_zoneForm.Description" />
                </div>
                <div>
                    <label style="font-size:12px;color:var(--text-muted)">
                        Términos geográficos <span style="color:var(--accent)">(coma separados)</span>
                    </label>
                    <textarea class="form-control" rows="3" @bind="_zoneForm.GeoTermsText"
                              placeholder="Spain, España, Madrid, Barcelona…"></textarea>
                </div>
                <div>
                    <label style="font-size:12px;color:var(--text-muted)">Orden</label>
                    <input type="number" class="form-control" @bind="_zoneForm.SortOrder" style="width:80px"/>
                </div>
                @if (!string.IsNullOrEmpty(_zoneError))
                { <div class="alert alert-danger" style="padding:8px 12px;font-size:13px">@_zoneError</div> }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseZoneModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveZoneAsync" disabled="@_savingZone">
                    @if (_savingZone) { <i class="fa fa-spinner fa-spin"></i> } Guardar
                </button>
            </div>
        </div>
    </div>
}

<!-- Modal logs de ejecución -->
@if (ShowLogsModal)
{
    <div class="modal-overlay" @onclick="CloseLogsModal">
        <div class="modal-box modal-large" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>Logs de Ejecución #@SelectedExecutionId</h3>
                <button @onclick="CloseLogsModal"><i class="fa fa-times"></i></button>
            </div>
            <div class="modal-body log-modal-body">
                @foreach (var log in ExecutionLogs)
                {
                    <div class="log-entry log-@log.Level.ToLower()">
                        <span class="log-time">@log.Timestamp.ToString("HH:mm:ss.fff")</span>
                        <span class="log-badge badge-@log.Level.ToLower()">@log.Level</span>
                        <span class="log-msg">@log.Message</span>
                    </div>
                }
            </div>
        </div>
    </div>
}

