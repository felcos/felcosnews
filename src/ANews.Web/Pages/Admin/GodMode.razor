    private IEnumerable<LiveLogEntry> FilteredLogs
    {
        get
        {
            var q = AgentFilter == "error"
                ? LiveLogs.Where(l => l.Level is "Error" or "Warning")
                : LiveLogs.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(_logSearch))
