@page "/admin/sources"
@using Microsoft.AspNetCore.Authorization
@using ANews.Infrastructure.Data
@using ANews.Infrastructure.AI
@using ANews.Domain.Entities
@using ANews.Domain.Enums
@using ANews.Domain.Interfaces
@using Microsoft.EntityFrameworkCore
@using System.Text.Json
@using System.Collections.Generic
@attribute [Authorize(Policy = "RequireAdmin")]
@layout ANews.Web.Components.Layout.AdminLayout
@inject AppDbContext Db
@inject IJSRuntime JS
@inject AiProviderFactory AiFactory

<PageTitle>Fuentes de Noticias - Admin</PageTitle>

<div @onclick="@(() => _seedMenuOpen = false)">
<div class="admin-page-header">
    <div>
        <h2>Fuentes de Noticias</h2>
        <p class="text-muted">Gestion de fuentes RSS, APIs y scrapers</p>
    </div>
    <div style="display:flex;gap:8px">
        <button class="btn btn-secondary" @onclick="OpenDiscoverModal" title="La IA propone feeds RSS de calidad para añadir">
            <i class="fa fa-magic"></i> Descubrir con IA
        </button>
        <div style="position:relative" @onclick:stopPropagation>
            <button class="btn btn-secondary" @onclick="ToggleSeedMenu" disabled="@_seeding" title="Carga feeds conocidos según zona geográfica">
                @if (_seeding) { <i class="fa fa-spinner fa-spin"></i> } else { <i class="fa fa-flag"></i> }
                Semilla de fuentes <i class="fa fa-caret-down" style="font-size:10px;margin-left:2px"></i>
            </button>
            @if (_seedMenuOpen)
            {
                <div style="position:absolute;top:calc(100% + 4px);right:0;background:var(--card-bg);border:1px solid var(--border);border-radius:8px;padding:6px;z-index:999;min-width:220px;box-shadow:0 8px 24px rgba(0,0,0,.4)">
                    @if (!_seedWorkspaces.Any())
                    {
                        <div style="padding:8px 12px;font-size:12px;color:var(--text-muted)">
                            Sin zonas configuradas.<br/>
                            <a href="/admin/godmode" style="color:var(--accent)">Configúralas en GodMode</a>
                        </div>
                    }
                    @foreach (var ws in _seedWorkspaces)
                    {
                        var wsName = ws.Name;
                        <button style="@($"display:flex;gap:8px;align-items:center;width:100%;padding:7px 12px;border:none;color:var(--text);cursor:pointer;border-radius:6px;font-size:13px;background:{(_seedHover == wsName ? "rgba(255,255,255,.06)" : "none")}")"
                                @onmouseover="@(e => _seedHover = wsName)" @onmouseout="@(e => _seedHover = "")"
                                @onclick="@(() => SeedSourcesForWorkspace(wsName))">
                            <span style="font-size:16px">@ws.Flag</span>
                            <span>@wsName</span>
                        </button>
                    }
                </div>
            }
        </div>
        <button class="btn btn-primary" @onclick="OpenAddModal">
            <i class="fa fa-plus"></i> Nueva Fuente
        </button>
    </div>
</div>

<!-- Filters + Bulk actions -->
<div class="filter-bar">
    <input class="form-control search-input" placeholder="Buscar por nombre o URL..."
           @bind="_search" @bind:event="oninput" />
    <select class="form-control" @bind="_filterType">
        <option value="">Todos los tipos</option>
        @foreach (var t in Enum.GetValues<NewsSourceType>())
        { <option value="@t">@t</option> }
    </select>
    <select class="form-control" @bind="_filterSection">
        <option value="">Todas las secciones</option>
        @foreach (var s in _sections)
        { <option value="@s.Id">@s.Name</option> }
    </select>
    <select class="form-control" @bind="_filterActive">
        <option value="">Todos</option>
        <option value="true">Activos</option>
        <option value="false">Inactivos</option>
    </select>
    <select class="form-control" @bind="_filterHealth">
        <option value="">Cualquier salud</option>
        <option value="ok">Sin errores</option>
        <option value="error">Con errores</option>
        <option value="never">Nunca escaneados</option>
    </select>
</div>

<!-- Bulk actions -->
<div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:wrap">
    <span style="font-size:12px;color:var(--text-muted)">
        @FilteredSources.Count() fuentes filtradas
    </span>
    <button class="btn btn-sm btn-secondary" @onclick="BulkEnableFilteredAsync" disabled="@_bulkWorking">
        <i class="fa fa-toggle-on"></i> Activar filtradas
    </button>
    <button class="btn btn-sm btn-secondary" @onclick="BulkDisableFilteredAsync" disabled="@_bulkWorking">
        <i class="fa fa-toggle-off"></i> Desactivar filtradas
    </button>
    <button class="btn btn-sm btn-secondary" @onclick="BulkResetErrorsAsync" disabled="@_bulkWorking">
        <i class="fa fa-eraser"></i> Limpiar errores
    </button>
    <button class="btn btn-sm btn-danger" @onclick="BulkDeleteFilteredAsync" disabled="@_bulkWorking">
        <i class="fa fa-trash"></i> Eliminar filtradas
    </button>
    @if (_bulkMsg != "")
    {
        <span style="font-size:12px;color:var(--accent-green)">@_bulkMsg</span>
    }
</div>

<!-- Stats bar -->
<div class="source-stats">
    <div class="source-stat">
        <span class="stat-number">@_sources.Count(s => s.IsActive)</span>
        <span class="stat-label">Activas</span>
    </div>
    <div class="source-stat">
        <span class="stat-number text-danger">@_sources.Count(s => !s.IsActive)</span>
        <span class="stat-label">Inactivas</span>
    </div>
    <div class="source-stat">
        <span class="stat-number text-warning">@_sources.Count(s => s.LastError != null)</span>
        <span class="stat-label">Con errores</span>
    </div>
    <div class="source-stat">
        <span class="stat-number text-info">@_sources.Sum(s => s.SuccessfulScans)</span>
        <span class="stat-label">Scans exitosos</span>
    </div>
</div>

@if (!string.IsNullOrEmpty(_seedMsg))
{
    <div class="alert @(_seedMsg.StartsWith("✓") ? "alert-success" : "alert-info")" style="margin-bottom:12px">
        @_seedMsg
        <button style="float:right;background:none;border:none;cursor:pointer;color:inherit" @onclick="@(() => _seedMsg = "")">×</button>
    </div>
}

<!-- Table -->
<div class="data-table-wrapper">
    <table class="data-table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>URL</th>
                <th>Tipo</th>
                <th>Credibilidad</th>
                <th>Ultimo scan</th>
                <th>Exito / Error</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var src in FilteredSources)
            {
                <tr class="@(src.LastError != null ? "row-warning" : "")">
                    <td>
                        <strong>@src.Name</strong>
                        @if (src.Section?.Name != null)
                        {
                            <br /><small class="text-muted">@src.Section.Name</small>
                        }
                    </td>
                    <td>
                        <span class="url-cell" title="@src.Url">@TruncateUrl(src.Url)</span>
                        <button class="btn-icon" @onclick="() => CopyUrl(src.Url)" title="Copiar URL">
                            <i class="fa fa-copy"></i>
                        </button>
                    </td>
                    <td><span class="badge badge-type-@src.Type.ToString().ToLower()">@src.Type</span></td>
                    <td>
                        <div class="credibility-bar">
                            <div class="credibility-fill" style="width: @src.CredibilityScore%"></div>
                            <span>@src.CredibilityScore%</span>
                        </div>
                    </td>
                    <td>
                        @if (src.LastScannedAt.HasValue)
                        {
                            <span title="@src.LastScannedAt.Value.ToString("dd/MM/yyyy HH:mm")">
                                @GetTimeAgo(src.LastScannedAt.Value)
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">Nunca</span>
                        }
                    </td>
                    <td>
                        <span class="text-success">@src.SuccessfulScans</span>
                        <span class="text-muted"> / </span>
                        <span class="@(src.FailedScans > 0 ? "text-danger" : "text-muted")">@src.FailedScans</span>
                        @if (src.LastError != null)
                        {
                            <button class="btn-icon text-warning" @onclick="() => ShowError(src)" title="Ver ultimo error">
                                <i class="fa fa-exclamation-triangle"></i>
                            </button>
                        }
                    </td>
                    <td>
                        <button class="toggle-btn @(src.IsActive ? "active" : "")" @onclick="() => ToggleActive(src)">
                            @(src.IsActive ? "Activa" : "Inactiva")
                        </button>
                    </td>
                    <td class="actions-cell">
                        <button class="btn-icon" @onclick="() => OpenEditModal(src)" title="Editar">
                            <i class="fa fa-edit"></i>
                        </button>
                        <button class="btn-icon text-danger" @onclick="() => ConfirmDelete(src)" title="Eliminar">
                            <i class="fa fa-trash"></i>
                        </button>
                    </td>
                </tr>
            }
            @if (!FilteredSources.Any())
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">No se encontraron fuentes</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Add/Edit Modal -->
@if (_showModal)
{
    <div class="modal-backdrop" @onclick="CloseModal"></div>
    <div class="modal-panel">
        <div class="modal-header">
            <h3>@(_editingSource?.Id > 0 ? "Editar Fuente" : "Nueva Fuente")</h3>
            <button class="modal-close" @onclick="CloseModal"><i class="fa fa-times"></i></button>
        </div>
        <div class="modal-body">
            <div class="form-grid">
                <div class="form-group">
                    <label>Nombre *</label>
                    <input class="form-control" @bind="_form.Name" placeholder="Ej: El Pais RSS" />
                </div>
                <div class="form-group">
                    <label>Tipo *</label>
                    <select class="form-control" @bind="_form.Type">
                        @foreach (var t in Enum.GetValues<NewsSourceType>())
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="form-group form-group-full">
                    <label>URL *</label>
                    <input class="form-control" @bind="_form.Url" placeholder="https://..." />
                </div>
                <div class="form-group">
                    <label>Seccion</label>
                    <select class="form-control" @bind="_form.NewsSectionId">
                        <option value="">Sin seccion</option>
                        @foreach (var sec in _sections)
                        {
                            <option value="@sec.Id">@sec.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Credibilidad (0-100)</label>
                    <input type="number" class="form-control" @bind="_form.CredibilityScore" min="0" max="100" />
                </div>
                <div class="form-group">
                    <label>Idioma</label>
                    <input class="form-control" @bind="_form.Language" placeholder="es" maxlength="10" />
                </div>
                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="_form.IsActive" />
                        Activa
                    </label>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_formError))
            {
                <div class="alert alert-danger">@_formError</div>
            }
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
            <button class="btn btn-primary" @onclick="SaveSource" disabled="@_saving">
                @if (_saving) { <i class="fa fa-spinner fa-spin"></i> }
                Guardar
            </button>
        </div>
    </div>
}

<!-- Error detail modal -->
@if (_errorSource != null)
{
    <div class="modal-backdrop" @onclick="() => _errorSource = null"></div>
    <div class="modal-panel modal-sm">
        <div class="modal-header">
            <h3>Ultimo Error - @_errorSource.Name</h3>
            <button class="modal-close" @onclick="() => _errorSource = null"><i class="fa fa-times"></i></button>
        </div>
        <div class="modal-body">
            <pre class="error-detail">@_errorSource.LastError</pre>
            @if (_errorSource.LastScannedAt.HasValue)
            {
                <p class="text-muted mt-2">Ocurrio: @_errorSource.LastScannedAt.Value.ToString("dd/MM/yyyy HH:mm:ss")</p>
            }
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" @onclick="() => { _errorSource = null; }">Cerrar</button>
            <button class="btn btn-warning" @onclick="() => ClearError(_errorSource)">Limpiar Error</button>
        </div>
    </div>
}

<!-- AI Source Discovery Modal -->
@if (_showDiscoverModal)
{
    <div class="modal-backdrop" @onclick="CloseDiscoverModal"></div>
    <div class="modal-panel" style="max-width:760px;max-height:90vh;display:flex;flex-direction:column" @onclick:stopPropagation>
        <div class="modal-header">
            <h3><i class="fa fa-magic" style="color:var(--accent)"></i> Descubrir fuentes RSS con IA</h3>
            <button class="modal-close" @onclick="CloseDiscoverModal"><i class="fa fa-times"></i></button>
        </div>
        <div class="modal-body" style="overflow-y:auto;flex:1">
            @if (!_discoveredSources.Any() && !_discovering)
            {
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">
                    <div class="form-group">
                        <label>Tema / Categoría <small style="color:var(--text-muted)">(dejar vacío = todo)</small></label>
                        <input class="form-control" @bind="_discoveryTopic"
                               placeholder="Ej: tecnología, deportes, economía..." />
                    </div>
                    <div class="form-group">
                        <label>Sección asignada por defecto</label>
                        <select class="form-control" @bind="_discoveryDefaultSection">
                            @foreach (var sec in _sections)
                            {
                                <option value="@sec.Id">@sec.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Idioma preferido</label>
                        <select class="form-control" @bind="_discoveryLang">
                            <option value="any">Cualquiera</option>
                            <option value="es">Español</option>
                            <option value="en">Inglés</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Cantidad a generar</label>
                        <select class="form-control" @bind="_discoveryCount">
                            <option value="10">10 fuentes</option>
                            <option value="20">20 fuentes</option>
                            <option value="30">30 fuentes</option>
                            <option value="50">50 fuentes</option>
                        </select>
                    </div>
                </div>
                <p style="font-size:12px;color:var(--text-muted);margin-bottom:8px">
                    <i class="fa fa-info-circle"></i> Las fuentes se añadirán como <strong>inactivas</strong> — tú decides cuáles activar.
                </p>
            }

            @if (_discovering)
            {
                <div style="padding:24px 0">
                    <div style="text-align:center;margin-bottom:16px">
                        <div class="loading-spinner" style="margin:0 auto 12px"></div>
                        <p style="color:var(--text-muted);font-size:13px">@(_discoveryProgress != "" ? _discoveryProgress : "Iniciando búsqueda exhaustiva...")</p>
                    </div>
                    @if (_discoveredSources.Any())
                    {
                        <div style="font-size:12px;color:var(--accent);text-align:center;margin-bottom:12px">
                            <i class="fa fa-check-circle"></i> @_discoveredSources.Count fuentes encontradas hasta ahora
                        </div>
                        <div style="display:flex;flex-direction:column;gap:4px;max-height:200px;overflow-y:auto;opacity:0.7">
                            @foreach (var ds in _discoveredSources.TakeLast(8))
                            {
                                <div style="font-size:11px;padding:4px 8px;background:var(--card-bg);border-radius:4px;display:flex;gap:8px">
                                    <span style="color:var(--accent-green)">✓</span>
                                    <span style="color:var(--text)">@ds.Name</span>
                                    <span style="color:var(--text-muted);font-size:10px;word-break:break-all">@ds.Url</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else if (_discoveryError != null)
            {
                <div class="alert alert-danger"><i class="fa fa-warning"></i> @_discoveryError</div>
            }
            else if (_discoveredSources.Any())
            {
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
                    <span style="font-size:13px;color:var(--text-muted)">
                        @_discoveredSources.Count fuentes encontradas — @_discoveredSources.Count(s => s.Selected) seleccionadas
                    </span>
                    <div style="display:flex;gap:8px">
                        <button class="btn btn-secondary" style="font-size:12px;padding:4px 10px"
                                @onclick="@(() => _discoveredSources.ForEach(s => s.Selected = true))">Seleccionar todo</button>
                        <button class="btn btn-secondary" style="font-size:12px;padding:4px 10px"
                                @onclick="@(() => _discoveredSources.ForEach(s => s.Selected = false))">Ninguno</button>
                    </div>
                </div>
                <div style="display:flex;flex-direction:column;gap:6px">
                    @foreach (var ds in _discoveredSources)
                    {
                        var alreadyExists = _sources.Any(s => s.Url == ds.Url);
                        <div style="display:flex;align-items:flex-start;gap:10px;padding:10px;border-radius:8px;border:1px solid var(--border);background:var(--card-bg);@(alreadyExists ? "opacity:0.5" : "")">
                            <input type="checkbox" @bind="ds.Selected" disabled="@alreadyExists" style="margin-top:3px;flex-shrink:0" />
                            <div style="flex:1;min-width:0">
                                <div style="display:flex;align-items:center;gap:8px;margin-bottom:2px">
                                    <strong style="font-size:13px">@ds.Name</strong>
                                    <span style="font-size:10px;padding:1px 6px;border-radius:3px;background:rgba(74,144,226,0.15);color:var(--accent)">@ds.Language</span>
                                    <span style="font-size:10px;color:var(--text-muted)">Credibilidad: @ds.Credibility%</span>
                                    @if (alreadyExists) { <span style="font-size:10px;color:var(--accent-yellow)">Ya existe</span> }
                                </div>
                                <div style="font-size:11px;color:var(--text-muted);margin-bottom:4px">@ds.Topic</div>
                                <div style="font-size:11px;color:var(--text-muted);word-break:break-all">@ds.Url</div>
                            </div>
                            <select style="font-size:11px;padding:2px 4px;background:var(--card-bg);border:1px solid var(--border);color:var(--text-primary);border-radius:4px;flex-shrink:0"
                                    @bind="ds.SectionId">
                                @foreach (var sec in _sections)
                                {
                                    <option value="@sec.Id">@sec.Name</option>
                                }
                            </select>
                        </div>
                    }
                </div>
            }
        </div>
        <div class="modal-footer">
            @if (_discoveredSources.Any())
            {
                <button class="btn btn-secondary" @onclick="OpenDiscoverModal">Nueva búsqueda</button>
                <button class="btn btn-primary" @onclick="AddSelectedSources"
                        disabled="@(!_discoveredSources.Any(s => s.Selected && !_sources.Any(e => e.Url == s.Url)))">
                    <i class="fa fa-plus"></i> Añadir @(_discoveredSources.Count(s => s.Selected && !_sources.Any(e => e.Url == s.Url))) fuentes
                </button>
            }
            else if (!_discovering)
            {
                <button class="btn btn-secondary" @onclick="CloseDiscoverModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="RunDiscovery" disabled="@_discovering">
                    <i class="fa fa-magic"></i> Descubrir
                </button>
            }
        </div>
    </div>
}

</div><!-- close outer click-to-close wrapper -->

@code {
    private List<NewsSource> _sources = new();
    private List<NewsSection> _sections = new();
    private string _search = "";
    private string _filterType = "";
    private string _filterActive = "";
    private string _filterSection = "";
    private string _filterHealth = "";
    private bool _bulkWorking;
    private string _bulkMsg = "";
    private bool _showModal;
    private bool _saving;

    private bool _seeding;
    private bool _seedMenuOpen;
    private string _seedHover = "";
    private string _seedMsg = "";
    private List<WorkspaceZone> _seedWorkspaces = [];

    // ── AI Discovery ──────────────────────────────────────
    private bool _showDiscoverModal;
    private bool _discovering;
    private string _discoveryTopic = "";
    private string _discoveryLang = "any";
    private int _discoveryCount = 20;
    private int _discoveryDefaultSection;
    private string? _discoveryError;
    private string _discoveryProgress = "";
    private List<DiscoveredSource> _discoveredSources = new();

    class DiscoveredSource
    {
        public string Name { get; set; } = "";
        public string Url { get; set; } = "";
        public string Language { get; set; } = "en";
        public int Credibility { get; set; } = 75;
        public string Topic { get; set; } = "";
        public int SectionId { get; set; }
        public bool Selected { get; set; } = true;
    }
    private string _formError = "";
    private NewsSource? _editingSource;
    private NewsSource? _errorSource;

    private SourceForm _form = new();

    private IEnumerable<NewsSource> FilteredSources => _sources.Where(s =>
        (string.IsNullOrEmpty(_search) ||
         s.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
         s.Url.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_filterType) || s.Type.ToString() == _filterType) &&
        (string.IsNullOrEmpty(_filterSection) || s.NewsSectionId.ToString() == _filterSection) &&
        (string.IsNullOrEmpty(_filterActive) || s.IsActive.ToString().ToLower() == _filterActive) &&
        (_filterHealth switch
        {
            "ok"    => s.LastError == null,
            "error" => s.LastError != null,
            "never" => !s.LastScannedAt.HasValue,
            _       => true
        }));

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _sources = await Db.NewsSources
            .Include(s => s.Section)
            .OrderByDescending(s => s.CreatedAt)
            .ToListAsync();

        _sections = await Db.NewsSections
            .OrderBy(s => s.Name)
            .ToListAsync();

        _seedWorkspaces = await Db.WorkspaceZones
            .Where(z => z.IsActive && !z.IsDeleted)
            .OrderBy(z => z.SortOrder)
            .ToListAsync();
    }

    private void OpenAddModal()
    {
        _editingSource = null;
        _form = new SourceForm { IsActive = true, CredibilityScore = 70, Language = "es", Type = NewsSourceType.Rss };
        _formError = "";
        _showModal = true;
    }

    private void OpenEditModal(NewsSource src)
    {
        _editingSource = src;
        _form = new SourceForm
        {
            Name = src.Name,
            Url = src.Url,
            Type = src.Type,
            NewsSectionId = src.NewsSectionId,
            CredibilityScore = src.CredibilityScore,
            Language = src.Language ?? "es",
            IsActive = src.IsActive
        };
        _formError = "";
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
        _editingSource = null;
    }

    private async Task SaveSource()
    {
        _formError = "";
        if (string.IsNullOrWhiteSpace(_form.Name)) { _formError = "El nombre es requerido."; return; }
        if (string.IsNullOrWhiteSpace(_form.Url)) { _formError = "La URL es requerida."; return; }

        _saving = true;
        try
        {
            if (_editingSource?.Id > 0)
            {
                _editingSource.Name = _form.Name;
                _editingSource.Url = _form.Url;
                _editingSource.Type = _form.Type;
                _editingSource.NewsSectionId = _form.NewsSectionId;
                _editingSource.CredibilityScore = _form.CredibilityScore;
                _editingSource.Language = _form.Language;
                _editingSource.IsActive = _form.IsActive;
                Db.NewsSources.Update(_editingSource);
            }
            else
            {
                var newSource = new NewsSource
                {
                    Name = _form.Name,
                    Url = _form.Url,
                    Type = _form.Type,
                    NewsSectionId = _form.NewsSectionId,
                    CredibilityScore = _form.CredibilityScore,
                    Language = _form.Language,
                    IsActive = _form.IsActive
                };
                await Db.NewsSources.AddAsync(newSource);
            }

            await Db.SaveChangesAsync();
            CloseModal();
            await LoadData();
        }
        catch (Exception ex)
        {
            _formError = $"Error al guardar: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ToggleActive(NewsSource src)
    {
        src.IsActive = !src.IsActive;
        Db.NewsSources.Update(src);
        await Db.SaveChangesAsync();
    }

    private async Task BulkEnableFilteredAsync()
    {
        _bulkWorking = true; _bulkMsg = "";
        var targets = FilteredSources.Where(s => !s.IsActive).ToList();
        foreach (var s in targets) s.IsActive = true;
        await Db.SaveChangesAsync();
        _bulkMsg = $"✓ {targets.Count} fuentes activadas";
        _bulkWorking = false;
        _ = Task.Delay(3000).ContinueWith(_ => { _bulkMsg = ""; InvokeAsync(StateHasChanged); });
    }

    private async Task BulkDisableFilteredAsync()
    {
        _bulkWorking = true; _bulkMsg = "";
        var targets = FilteredSources.Where(s => s.IsActive).ToList();
        foreach (var s in targets) s.IsActive = false;
        await Db.SaveChangesAsync();
        _bulkMsg = $"✓ {targets.Count} fuentes desactivadas";
        _bulkWorking = false;
        _ = Task.Delay(3000).ContinueWith(_ => { _bulkMsg = ""; InvokeAsync(StateHasChanged); });
    }

    private async Task BulkResetErrorsAsync()
    {
        _bulkWorking = true; _bulkMsg = "";
        var targets = FilteredSources.Where(s => s.LastError != null).ToList();
        foreach (var s in targets) { s.LastError = null; s.FailedScans = 0; }
        await Db.SaveChangesAsync();
        _bulkMsg = $"✓ Errores limpiados en {targets.Count} fuentes";
        _bulkWorking = false;
        _ = Task.Delay(3000).ContinueWith(_ => { _bulkMsg = ""; InvokeAsync(StateHasChanged); });
    }

    private async Task BulkDeleteFilteredAsync()
    {
        var count = FilteredSources.Count();
        var confirmed = await JS.InvokeAsync<bool>("confirmDialog", $"¿Eliminar {count} fuentes filtradas?");
        if (!confirmed) return;
        _bulkWorking = true; _bulkMsg = "";
        var targets = FilteredSources.ToList();
        foreach (var s in targets) { s.IsDeleted = true; _sources.Remove(s); }
        await Db.SaveChangesAsync();
        _bulkMsg = $"✓ {targets.Count} fuentes eliminadas";
        _bulkWorking = false;
        _ = Task.Delay(3000).ContinueWith(_ => { _bulkMsg = ""; InvokeAsync(StateHasChanged); });
    }

    private async Task ConfirmDelete(NewsSource src)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirmDialog", $"Eliminar fuente '{src.Name}'?");
        if (confirmed)
        {
            src.IsDeleted = true;
            Db.NewsSources.Update(src);
            await Db.SaveChangesAsync();
            _sources.Remove(src);
        }
    }

    private async Task ClearError(NewsSource src)
    {
        src.LastError = null;
        Db.NewsSources.Update(src);
        await Db.SaveChangesAsync();
        _errorSource = null;
        await LoadData();
    }

    private void ShowError(NewsSource src) => _errorSource = src;

    private async Task CopyUrl(string url) =>
        await JS.InvokeVoidAsync("copyToClipboard", url);

    private static string TruncateUrl(string url)
    {
        if (url.Length <= 50) return url;
        return url[..47] + "...";
    }

    private static string GetTimeAgo(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 60) return $"hace {(int)diff.TotalMinutes}m";
        if (diff.TotalHours < 24) return $"hace {(int)diff.TotalHours}h";
        return $"hace {(int)diff.TotalDays}d";
    }

