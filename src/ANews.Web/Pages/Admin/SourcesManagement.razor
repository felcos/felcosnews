    {
        public string Name { get; set; } = "";
        public string Url { get; set; } = "";
        public NewsSourceType Type { get; set; } = NewsSourceType.Rss;
        public int NewsSectionId { get; set; }
        public int CredibilityScore { get; set; } = 70;
        public string Language { get; set; } = "es";
        public bool IsActive { get; set; } = true;
    }

    // ── Seed feeds by workspace ───────────────────────────
    private void ToggleSeedMenu() => _seedMenuOpen = !_seedMenuOpen;

    private async Task SeedSourcesForWorkspace(string workspace)
    {
        _seedMenuOpen = false;
        _seeding = true;
        _seedMsg = "";
        await InvokeAsync(StateHasChanged);

        try
        {
            var feeds = GetSeedFeeds(workspace);
            var existingUrls = _sources.Select(s => s.Url).ToHashSet();
            int added = 0;

            foreach (var (name, url, lang, cred, topic) in feeds)
            {
                if (existingUrls.Contains(url)) continue;

                var sectionId = ResolveSectionId(topic);

                await Db.NewsSources.AddAsync(new NewsSource
                {
                    Name = name,
                    Url = url,
                    Type = NewsSourceType.Rss,
                    Language = lang,
                    CredibilityScore = cred,
                    NewsSectionId = sectionId,
                    IsActive = false
                });
                existingUrls.Add(url);
                added++;
            }

            if (added > 0)
            {
                await Db.SaveChangesAsync();
                await LoadData();
                _seedMsg = $"✓ {added} fuentes de {workspace} añadidas (inactivas — actívalas desde la tabla)";
            }
            else
            {
                _seedMsg = $"Todas las fuentes de {workspace} ya estaban en el sistema.";
            }
        }
        catch (Exception ex)
        {
            _seedMsg = $"Error: {ex.Message}";
        }
        finally
        {
            _seeding = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private int ResolveSectionId(string topic)
    {
        // Try exact or partial match on section name
        var match = _sections.FirstOrDefault(s =>
            s.Name.Contains(topic, StringComparison.OrdinalIgnoreCase) ||
            topic.Contains(s.Name, StringComparison.OrdinalIgnoreCase));
        if (match != null) return match.Id;
        // Specific slug overrides
        if (topic is "Farándula" or "Sociedad")
        {
            var sec = _sections.FirstOrDefault(s => s.Slug is "farandula" or "social");
            if (sec != null) return sec.Id;
        }
        return _sections.FirstOrDefault()?.Id ?? 1;
    }

