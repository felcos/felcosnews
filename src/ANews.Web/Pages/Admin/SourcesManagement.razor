    private void OpenDiscoverModal()
    {
        _showDiscoverModal = true;
        _discoveredSources.Clear();
        _discoveryError = null;
        _discoveryTopic = "";
        _discoveryDefaultSection = _sections.FirstOrDefault()?.Id ?? 0;
    }

    private void CloseDiscoverModal()
    {
        _showDiscoverModal = false;
        _discoveredSources.Clear();
        _discoveryError = null;
    }

    record DiscoveryRound(string Label, string Prompt);

    private List<DiscoveryRound> BuildDiscoveryRounds()
    {
        var hasTopic = !string.IsNullOrWhiteSpace(_discoveryTopic);
        var topic = _discoveryTopic.Trim();
        var rounds = new List<DiscoveryRound>();
        var langNote = _discoveryLang switch { "es" => "en ESPAÑOL únicamente", "en" => "in ENGLISH only", _ => "in English and Spanish" };

        if (hasTopic)
        {
            // Topic-focused: 4 rounds drilling deep into that topic
            rounds.Add(new($"Medios principales sobre «{topic}»",
                $"List 20 RSS/Atom feeds from MAJOR mainstream news outlets covering \"{topic}\" {langNote}. " +
                "Include newspapers, TV networks, wire services (AP, Reuters, AFP). " +
                "Only use feeds you are certain exist and are currently active."));

            rounds.Add(new($"Medios especializados en «{topic}»",
                $"List 20 RSS/Atom feeds from SPECIALIST and NICHE publications about \"{topic}\" {langNote}. " +
                "Think trade press, industry blogs, academic news sites, think tanks, NGOs related to this topic. " +
                "Avoid repeating mainstream outlets from previous searches."));

            rounds.Add(new($"Fuentes regionales / locales sobre «{topic}»",
                $"List 15 RSS/Atom feeds from REGIONAL or LOCAL news sources covering \"{topic}\" {langNote}. " +
                "Include sources from different countries or regions that cover this topic actively."));

            rounds.Add(new($"Podcasts, newsletters y alternativos sobre «{topic}»",
                $"List 15 RSS/Atom feeds from newsletters, podcast feeds, alternative media, and independent journalists covering \"{topic}\" {langNote}. " +
                "Include Substack feeds, podcast RSS, independent outlets."));
        }
        else if (_discoveryLang == "es")
        {
            rounds.Add(new("Grandes diarios españoles",
                "List 20 RSS/Atom feeds from major SPANISH newspapers and portals: El País, El Mundo, ABC, La Vanguardia, El Confidencial, elDiario.es, El Economista, Cinco Días, Expansión, Abc.es, La Razón, 20minutos, El Periódico, El Español, OKDiario, InfoLibre, Publico.es, La Sexta Noticias, Antena3 Noticias, RTVE. Include their section feeds (política, economía, tecnología, deportes)."));

            rounds.Add(new("Medios latinoamericanos en español",
                "List 20 RSS/Atom feeds from LATIN AMERICAN news outlets: Infobae, Clarín, La Nación (Argentina), El Universal (Mexico), Milenio, La Jornada, El Tiempo (Colombia), El Comercio (Peru/Ecuador), El País (Uruguay), El Nacional (Venezuela), Últimas Noticias, TalCual Digital, El Pitazo, La República, BBC Mundo, CNN en Español, RT en Español, Deutsche Welle Español, France24 Español."));

            rounds.Add(new("Tecnología, ciencia y economía en español",
                "List 20 RSS/Atom feeds from Spanish-language TECH, SCIENCE and ECONOMY sources: Xataka, Hipertextual, Genbeta, Incognitosis, MIT Technology Review Español, El País Tecnología, Muy Interesante, National Geographic España, Investigación y Ciencia, SINC, Eleconomista.es, Expansión Economía, Cinco Días Mercados, CincoDías Tecnología."));

            rounds.Add(new("Deportes, cultura y sociedad en español",
                "List 20 RSS/Atom feeds from Spanish-language SPORTS, CULTURE and SOCIETY: Marca, AS, Sport, Mundo Deportivo, El Confidencial Deportes, Radio Marca, SER Deportivos, UEFA, FIFA, LaLiga, El Cultural, El País Cultura, ABC Cultural, Cadena SER, COPE, RNE, eldiario.es Sociedad, La Vanguardia Vida."));
        }
        else if (_discoveryLang == "en")
        {
            rounds.Add(new("International wire services and newspapers",
                "List 20 RSS/Atom feeds from top INTERNATIONAL English news: Reuters, AP, AFP, BBC News, BBC World Service, The Guardian, The Times, Financial Times, The Economist, The Telegraph, Independent, The New York Times, Washington Post, Wall Street Journal, Los Angeles Times, USA Today, Chicago Tribune, Politico, NPR, PBS NewsHour."));

            rounds.Add(new("Technology and science in English",
                "List 20 RSS/Atom feeds from top ENGLISH tech, science and innovation: TechCrunch, Wired, The Verge, Ars Technica, Engadget, MIT Technology Review, IEEE Spectrum, Nature News, Science Magazine, New Scientist, Popular Science, Popular Mechanics, Gizmodo, 9to5Mac, 9to5Google, AndroidPolice, AnandTech, Tom's Hardware, ExtremeTech, Hacker News."));

            rounds.Add(new("Business, economy and markets in English",
                "List 20 RSS/Atom feeds from ENGLISH business and economy: Bloomberg, Forbes, Fortune, Business Insider, CNBC, MarketWatch, Investopedia, Financial Times, The Economist, Harvard Business Review, Inc Magazine, Fast Company, Quartz, Rest of World, The Information, Morning Brew, Axios Markets, Yahoo Finance, Seeking Alpha, Barron's."));

            rounds.Add(new("TV, politics, world affairs in English",
                "List 20 RSS/Atom feeds from ENGLISH TV news, politics and world affairs: CNN, Fox News, MSNBC, Al Jazeera English, France24 English, DW English, Euronews English, Sky News, Channel 4 News, ABC News, CBS News, NBC News, Axios, Politico, The Hill, Foreign Policy, Foreign Affairs, The Atlantic, New Yorker, Mother Jones."));
        }
        else
        {
            // Any language — broad mix
            rounds.Add(new("Medios internacionales principales",
                "List 25 RSS/Atom feeds from top INTERNATIONAL mainstream news in both English and Spanish: BBC, Reuters, AP, El País, CNN, Al Jazeera, Deutsche Welle, France24, Euronews, RTVE, Infobae, The Guardian, El Mundo, Clarín, La Vanguardia, ABC Spain, NPR, Bloomberg, Forbes, El Economista. Include section-specific feeds where available."));

            rounds.Add(new("Tecnología y ciencia (ES+EN)",
                "List 25 RSS/Atom feeds from TOP TECHNOLOGY and SCIENCE sources in Spanish and English: TechCrunch, The Verge, Wired, Ars Technica, MIT Technology Review, Xataka, Hipertextual, Genbeta, Nature, Science Magazine, New Scientist, IEEE Spectrum, Engadget, 9to5Mac, Gizmodo, El País Tecnología, Muy Interesante, SINC, Popular Science."));

            rounds.Add(new("Economía, política y geopolítica",
                "List 25 RSS/Atom feeds from ECONOMY, POLITICS and GEOPOLITICS: Financial Times, The Economist, Bloomberg, Wall Street Journal, Forbes, Expansión, Cinco Días, El Economista, Foreign Policy, Foreign Affairs, Politico, The Hill, Axios, El Confidencial, Mercado Financiero, Project Syndicate, Council on Foreign Relations, Brookings Institution, IISS, Chatham House."));

            rounds.Add(new("Deportes, cultura, salud y sociedad",
                "List 20 RSS/Atom feeds from SPORTS, CULTURE, HEALTH and SOCIETY: Marca, AS, ESPN, BBC Sport, Sky Sports, Olympic Channel, El País Cultura, The Guardian Culture, Rolling Stone, Pitchfork, NPR Music, WHO News, WebMD, Healthline, National Geographic, Smithsonian Magazine, TED Talks, Medium, Longreads, Aeon."));
        }

        return rounds;
    }

    private List<DiscoveredSource> ParseDiscoveryResponse(string content, HashSet<string> existingUrls)
    {
        var result = new List<DiscoveredSource>();
        try
        {
            var start = content.IndexOf('{');
            var end = content.LastIndexOf('}');
            if (start < 0 || end <= start) return result;
            var json = content[start..(end + 1)];
            using var doc = JsonDocument.Parse(json);
            if (!doc.RootElement.TryGetProperty("sources", out var arr)) return result;
            foreach (var el in arr.EnumerateArray())
            {
                var url = (el.TryGetProperty("url", out var u) ? u.GetString() : null) ?? "";
                var name = (el.TryGetProperty("name", out var n) ? n.GetString() : null) ?? "";
                if (string.IsNullOrWhiteSpace(url) || string.IsNullOrWhiteSpace(name)) continue;
                // Normalize URL
                url = url.Trim();
                if (!url.StartsWith("http")) continue;
                if (existingUrls.Contains(url)) continue;
                if (_discoveredSources.Any(s => s.Url == url)) continue;
                result.Add(new DiscoveredSource
                {
                    Name = name,
                    Url = url,
                    Language = (el.TryGetProperty("language", out var l) ? l.GetString() : null) ?? (_discoveryLang == "es" ? "es" : "en"),
                    Credibility = el.TryGetProperty("credibility", out var c) ? Math.Clamp(c.GetInt32(), 40, 100) : 75,
                    Topic = (el.TryGetProperty("topic", out var t) ? t.GetString() : null) ?? _discoveryTopic,
                    SectionId = _discoveryDefaultSection,
                    Selected = true
                });
            }
        }
        catch { }
        return result;
    }

    private async Task RunDiscovery()
    {
        _discovering = true;
        _discoveryError = null;
        _discoveryProgress = "";
        _discoveredSources.Clear();
        await InvokeAsync(StateHasChanged);

        try
        {
            var provider = await AiFactory.GetDefaultProviderAsync();
            var existingUrls = _sources.Select(s => s.Url).ToHashSet();
            var rounds = BuildDiscoveryRounds();
            var systemPrompt =
                "You are a journalism and digital media expert with encyclopedic knowledge of RSS/Atom feeds worldwide. " +
                "You only list feeds that you are CERTAIN exist and are currently active. " +
                "You always provide the exact, full RSS/Atom URL — not the website homepage. " +
                "Common RSS URL patterns: /feed, /rss, /rss.xml, /atom.xml, /feed.xml, /news/rss, /rss/all.xml. " +
                "You respond ONLY with valid JSON, no markdown, no explanations.";

            var exampleJson =
                "{\"sources\":[" +
                "{\"name\":\"BBC World News\",\"url\":\"http://feeds.bbci.co.uk/news/world/rss.xml\",\"language\":\"en\",\"credibility\":97,\"topic\":\"General\"}," +
                "{\"name\":\"El País\",\"url\":\"https://feeds.elpais.com/mrss-s/pages/ep/site/elpais.com/portada\",\"language\":\"es\",\"credibility\":92,\"topic\":\"General\"}" +
                "]}";

            int roundNum = 0;
            foreach (var round in rounds)
            {
                roundNum++;
                _discoveryProgress = $"Ronda {roundNum}/{rounds.Count}: {round.Label}";
                await InvokeAsync(StateHasChanged);

                var alreadyFoundUrls = _discoveredSources.Select(s => s.Url).Take(20).ToList();
                var skipNote = alreadyFoundUrls.Any()
                    ? $"\nDo NOT repeat these already found URLs: {string.Join(", ", alreadyFoundUrls.Take(10))}"
                    : "";

                var prompt = round.Prompt + skipNote +
                    $"\n\nRespond ONLY with valid JSON, no markdown. Exact format:\n{exampleJson}";

                try
                {
                    var response = await provider.CompleteAsync(new AiRequest
                    {
                        SystemPrompt = systemPrompt,
                        UserPrompt = prompt,
                        MaxTokens = 4000,
                        Temperature = 0.6,
                        OperationTag = "source_discovery"
                    });

                    if (response.Success && !string.IsNullOrEmpty(response.Content))
                    {
                        var newSources = ParseDiscoveryResponse(response.Content, existingUrls);
                        _discoveredSources.AddRange(newSources);
                        foreach (var s in newSources) existingUrls.Add(s.Url);
                        await InvokeAsync(StateHasChanged);
                    }
                    else
                    {
                        _discoveryProgress = $"Ronda {roundNum}/{rounds.Count}: sin respuesta, continuando...";
                        await InvokeAsync(StateHasChanged);
                    }
                }
                catch (Exception roundEx)
                {
                    _discoveryProgress = $"Ronda {roundNum}/{rounds.Count}: error ({roundEx.Message}), continuando...";
                    await InvokeAsync(StateHasChanged);
                }
            }

            _discoveryProgress = "";
            if (!_discoveredSources.Any())
                _discoveryError = "No se encontraron fuentes válidas. Verifica que el proveedor de IA esté activo en GodMode.";
        }
        catch (Exception ex)
        {
            _discoveryError = $"Error: {ex.Message}";
        }
        finally
        {
            _discovering = false;
            _discoveryProgress = "";
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task AddSelectedSources()
    {
        var toAdd = _discoveredSources
            .Where(s => s.Selected && !_sources.Any(e => e.Url == s.Url))
            .ToList();

        foreach (var ds in toAdd)
        {
            await Db.NewsSources.AddAsync(new NewsSource
            {
                Name = ds.Name,
                Url = ds.Url,
                Type = NewsSourceType.Rss,
                Language = ds.Language,
                CredibilityScore = ds.Credibility,
                NewsSectionId = ds.SectionId > 0 ? ds.SectionId : (_sections.FirstOrDefault()?.Id ?? 1),
                IsActive = false  // inactive by default — admin activates manually
            });
        }

        await Db.SaveChangesAsync();
        CloseDiscoverModal();
        await LoadData();
    }
