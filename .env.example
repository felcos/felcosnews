# Database
POSTGRES_DB=anews
POSTGRES_USER=anews
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_CONNECTION=Host=postgres;Database=anews;Username=anews;Password=change_me_strong_password

# Redis
REDIS_PASSWORD=change_me_redis_password
REDIS_CONNECTION=redis:6379,password=change_me_redis_password

# Security
JWT_SECRET=change_me_jwt_secret_at_least_32_characters_long_for_security
AI_ENCRYPTION_KEY=change_me_encryption_key_32chars

# AI Providers (configurables desde el panel admin, estas son las defaults)
# OPENAI_API_KEY se configura en el panel admin
# ANTHROPIC_API_KEY se configura en el panel admin
# KIMI_API_KEY se configura en el panel admin
# GEMINI_API_KEY se configura en el panel admin

# Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@yourdomain.com

# Admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=Admin@123456!

# URLs
APP_URL=https://yourdomain.com
